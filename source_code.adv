booleans {
   # game state (noncritical)
   xme_yet : boolean "false" ;
   showed_first_note : boolean "false" ;
   noted_upper_right : boolean "false" ;
   have_won : boolean "false" scope="survivor" ;
   in_number_choice : boolean "false" ;
   hint_zero_warn : boolean "false" ;
   hinted_yet : boolean "false" ;
   sunshine_xed : boolean "false" ;
   on_off_note : boolean "false" ;
   drawing_map : boolean "false" ;
   map_note : boolean "false" ;
   widget_nudge : boolean "false" ;
   hint_awning_note : boolean "false" ;
   hints_clarified_yet : boolean "false" ;
   demo_or_meadow_tried : boolean "false" ;
   widget_noun_note : boolean "false" ;
   map_first_warn : boolean "false" ;
   graphics_unwon_warn : boolean "false" ;
   graphics_note : boolean "false" scope="survivor" ;

   # game state (critical or procedural e.g. changes in narrative visiting a place the first time)
   listen_demo_meadow : boolean "false" ;
   smell_rocky_caves : boolean "false" ;
   placed_flaming_towers : boolean "false" ;
   buns_taken : boolean "false" ;
   fax_examined : boolean "false" ;
   porch_in_tower : boolean "false" ;
   kelp_placed : boolean "false" ;
   center_sign_fell : boolean "false" ;

   key_found : boolean "false" ;
   key_duplicated : boolean "false" ;
   key_used : boolean "false" ;
   ever_keyhole : boolean "false" ;

   # game state (bonus-related)
   feel_yet : boolean "false" ;

   # game state (tutorials)
   skip_tutorial_cue : boolean "false" ; # not a tutorial but skip every-turn note when it is implied
   tutorial_0_in_tutorial : boolean "false" ;
   tutorial_1_about : boolean "false" ;
   tutorial_2_verbs : boolean "false" ;
   tutorial_3_x_me : boolean "false" ;
   tutorial_4_inventory : boolean "false" ;
   tutorial_5_think : boolean "false" ;
   tutorial_6_tool_stall : boolean "false" ;
   tutorial_7_south_first : boolean "false" ;
   tutorial_8_leery_owner_1 : boolean "false" ;
   tutorial_9_north : boolean "false" ;
   tutorial_10_listen : boolean "false" ;
   tutorial_11_rocky_caves : boolean "false" ;
   tutorial_12_down : boolean "false" ;
   tutorial_13_smell : boolean "false" ;
   tutorial_14_steel_wrench : boolean "false" ;
   tutorial_15_up : boolean "false" ;
   tutorial_16_south_twice : boolean "false" ;
   tutorial_17_leery_owner_2 : boolean "false" ;
   tutorial_done : boolean "false" ;

   # game state (point scoring) (alphabetical, with number in half-guess array)
   point_bake_tons       : boolean "false" ; # 9
   point_best_notes      : boolean "false" ; # 23
   point_chop_drain      : boolean "false" ; # 13
   point_cool_plan       : boolean "false" ; # 25
   point_creaky_stove    : boolean "false" ; # 10
   point_formed_wax      : boolean "false" ; # 15
   point_fumbling_wrist  : boolean "false" ; # 26
   point_great_book      : boolean "false" ; # 28
   point_grow_dupes      : boolean "false" ; # 8
   point_hard_maze       : boolean "false" ; # 17
   point_help_card       : boolean "false" ; # 27
   point_key_trove       : boolean "false" ; # 11
   point_leery_owner     : boolean "false" ; # 3
   point_lodging_doc     : boolean "false" ; # 14
   point_minister_south  : boolean "false" ; # 16
   point_platinum_chain  : boolean "false" ; # 12
   point_pull_file       : boolean "false" ; # 7
   point_push_best       : boolean "false" ; # 6
   point_rocky_caves     : boolean "false" ; # 0
   point_penny_mounds    : boolean "false" ; # 18
   point_power_torch     : boolean "false" ; # 22
   point_sail_tide       : boolean "false" ; # 21
   point_sick_bride      : boolean "false" ; # 20
   point_sold_guide      : boolean "false" ; # 19
   point_steel_wrench    : boolean "false" ; # 1
   point_taming_flowers  : boolean "false" ; # 5
   point_tight_rules     : boolean "false" ; # 4
   point_tool_stall      : boolean "false" ; # 2
   point_written_specs   : boolean "false" ; # 24

   # bonus point(s) (alphabetize)
   bonus_point_clock_jerk : boolean "false" scope="survivor" ;
   bonus_point_dig_below : boolean "false" scope="survivor" ;
   bonus_point_golden_fate : boolean "false" scope="survivor" ;
   bonus_point_map_all : boolean "false" scope="survivor" ;
   bonus_point_real_phase : boolean "false" scope="survivor" ;
   bonus_point_weary_biz : boolean "false" scope="survivor" ;

   # think variables
   think_bake_tons     : boolean "false" ;
   think_chop_drain    : boolean "false" ;
   think_great_book    : boolean "false" ;
   think_grow_dupes    : boolean "false" ;
   think_leery_owner   : boolean "false" ;
   think_sold_guide    : boolean "false" ;
   think_written_specs : boolean "false" ;
   think_available     : dynamic_boolean {( think_bake_tons || think_chop_drain || think_great_book || think_grow_dupes || think_leery_owner || think_sold_guide || think_written_specs )} ;

   # dynamic booleans for ease of coding
   known_leery_owner : dynamic_boolean {( think_leery_owner || point_leery_owner )} ;
   cocky_raves_present : dynamic_boolean {( listen_demo_meadow && !point_rocky_caves )} ;
   flaming_towers_present : dynamic_boolean {( placed_flaming_towers && !point_taming_flowers )} ;
   three_awning_sides_done : dynamic_boolean {( point_sold_guide && point_sick_bride && point_sail_tide )} ;

   # think-relevant booleans
   already_got_command : boolean "false" ;
   think_any : dynamic_boolean {( think_leery_owner || think_great_book || think_grow_dupes || think_bake_tons || think_chop_drain )} ;
   first_half : boolean "false" ;
   half_bonus : boolean "false" ;
   bonus_obfuscated_note_yet : boolean "false" ;
   bonus_half_note : boolean "false" ;
   think_core_yet : boolean "false" ;
   think_bonus_yet : boolean "false" ;
   think_text_yet : boolean "false" ;
   print_bonus_nag_after : boolean "false" scope="survivor" ;
   print_core_nag_after : boolean "false" ;
   solved_both_parts_core_nag : boolean "false" ;
   solved_both_parts_bonus_nag : boolean "false" ;

   ambiguous_awning_hints : dynamic_boolean {( is_at "gnawing_awning" && awning_doable > 1 && !hint_awning_note )} ;

   in_bonus_half : boolean "false" ;
   unneeded_half : dynamic_boolean {( tempint == 0 && !in_bonus_half )} ;

   # option(s)
   option_asked_once : boolean "false" scope="survivor" ;
   opt_block_done : boolean "false" scope="survivor" ;
   opt_color_coding : boolean "false" scope="survivor" ;
   opt_score_notify : boolean "true" scope="survivor" ;
   can_reveal_block_opt : dynamic_boolean {( score > 0 || option_asked_once || have_won )} ;

   widget_blurry : boolean "false" ;
   show_overlay : boolean "true" ;

   # auxiliary variables
   opt_on_off : boolean "false" ;
   already_flag : boolean "true" ;

   # blocker variables
   doneblock_10_rocky_caves : dynamic_boolean {( opt_block_done && point_steel_wrench )} ;
   doneblock_20_app_mall : dynamic_boolean {( opt_block_done && point_leery_owner )} ;
   doneblock_11_chattin_em_plain : dynamic_boolean {( opt_block_done && point_platinum_chain )} ;
   doneblock_21_tool_stall : dynamic_boolean {( opt_block_done && point_tight_rules && is_at "demo_meadow" )} ;
   doneblock_31_streaky_cove : dynamic_boolean {( opt_block_done && key_found )} ;
   doneblock_02_cache_shack : dynamic_boolean {( opt_block_done && buns_taken )} ;
   doneblock_12_newbies_boonies : dynamic_boolean {( opt_block_done && is_at "demo_meadow" && doneblock_02_cache_shack && doneblock_11_chattin_em_plain && doneblock_13_moldin_dolmen )} ;
   doneblock_22_demo_meadow : dynamic_boolean {( opt_block_done && is_at "outer_tower" && key_duplicated )} ;
   doneblock_32_backin_cabin : dynamic_boolean {( opt_block_done && is_at "demo_meadow" && doneblock_42_yankin_canyon && point_grow_dupes && key_found )} ;
   doneblock_42_yankin_canyon : dynamic_boolean {( opt_block_done && point_chop_drain )} ;
   doneblock_13_moldin_dolmen : dynamic_boolean {( opt_block_done && key_duplicated )} ;
   doneblock_23_outer_tower : dynamic_boolean {( opt_block_done && is_at "tenser_center" && point_power_torch )} ;
   doneblock_33_collation_location : dynamic_boolean {( opt_block_done && point_grow_dupes )} ;
   doneblock_14_ailer_lair : dynamic_boolean {( opt_block_done && point_best_notes && three_awning_sides_done && is_at "tenser_center" )} ;
   doneblock_24_tenser_center : dynamic_boolean {( opt_block_done && doneblock_14_ailer_lair && doneblock_34_jeerin_region && is_at "oopster_stupor" )} ;
   doneblock_34_jeerin_region : dynamic_boolean {( opt_block_done && point_help_card && is_at "tenser_center" && point_cool_plan )} ;
   doneblock_15_gnawing_awning : dynamic_boolean {( opt_block_done && three_awning_sides_done && is_at "ailer_lair"  )} ;
   doneblock_25_oopster_stupor : dynamic_boolean {( opt_block_done && is_at "foldin_gate" && point_help_card )} ;
   doneblock_35_taller_altar : dynamic_boolean {( opt_block_done && point_cool_plan && is_at "jeerin_region" )} ;

   # debug variables
   track_digits : boolean "false" ;
   track_hints : boolean "false" ;
}

vocabulary {

   : verb / aliases = [ch, colorhint] ;
   : verb / aliases = [opt, opts, option, options] ;

}

locations {
   ailer_lair : location "{loc_ailer_lair}" header="{header_ailer_lair}" graphic="r_ailer_lair" {
      on_command {
         : if (has_visited "foldin_gate") {
            : match "help card" {
               : if (point_help_card) {
                  : print "You already found the help card!" ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (27) content -> ("true") } ;
               : print "The kelp is tough to pick through, which is discouraging, but then you remember if it's tough to pick through, it can catch a lot of stuff. And you find a help card! Actually, it's more a cold hard hold card, like for a library or something." ;
               : set_true "point_help_card" ;
               : pocket "hold_card" ;
               : gosub "add_point" ;
               : done ;
            }
         }
         : if (!point_help_card) {
            : match "help _;_ card" {
               : set_integer var="tempint" "27" ;
               : set_false "first_half" ;
               : match "help _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : if (point_sail_tide) {
            : match "best notes" {
               : if (point_best_notes) {
                  : print {( "But the nest boats are gone. And the notes they gave " + (point_written_specs ? "were" : "are") + " already the best!" )} ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (23) content -> ("true") } ;
               : pocket "best_notes" ;
               : print "Yes! That is what you need. The ailers are happy with this and leave you with the notes. They go off to complain elsewhere, about more first-worldly problems." ;
               : set_true "point_best_notes" ;
               : gosub "add_point" ;
               : done ;
            }
         }
         : if (point_sail_tide && !point_best_notes) {
            : match "best _;_ notes" {
               : set_integer var="tempint" "23" ;
               : set_false "first_half" ;
               : match "best _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   app_mall : location "{loc_app_mall}" header="{header_app_mall}" graphic="r_app_mall" {
      on_command {
         : match "map all" {
            : if (bonus_point_map_all) {
               : print "You already gained map-all capabilities!" ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_bonus" index -> (3) content -> ("true") } ;
            : print "The jock clerk nods. \"Yup, good, practical, simple. I think it'll serve you well. From now on, just say MAP whenever you want to map something.\"" ;
            : set_true "bonus_point_map_all" ;
            : gosub "add_bonus" ;
            : done ;
         }
         : match "cock _" {
            : print {( "There's no hidden poultry farm, if that's what you're wondering." + (bonus_point_clock_jerk ? "" : " However, you could help the jock clerk, although it's optional.") )} ;
            : done ;
         }
         : if (!bonus_point_map_all) {
            : match "map _;_ all" {
               : set_integer var="tempint" "3" ;
               : set_false "first_half" ;
               : match "map _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half_b" ;
               : done ;
            }
         }
         : match "clock jerk" {
            : if (bonus_point_clock_jerk) {
               : print "You already alerted the clerk to the riff-raff. They will know what to do if said riff-raff return." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_bonus" index -> (4) content -> ("true") } ;
            : print "You suggest a plan of action to the clerk, to get rid of the marginally audible kvetching. They wonder if it is too drastic. No, no, it is just right." ;
            : print "You locate the source of the kvetching about how apps sold here are too simplistic and dumb people shouldn't have luxuries that make their lives simple. The jock clerk looks determined before pulling out ..." ;
            : press_any_key ;
            : print "A stopwatch. All jocks have that, to test speed or endurance or whatever. The kvetcher still goes on. Tick, tick, goes the stopwatch. After five minutes the kvetcher asks if the clerk has anything better to do. The clerk asks back: pal, you've been complaining for more than five minutes. Oh no! That's different! They are spreading wisdom to the masses! You know, the ones who don't deserve efficiency!" ;
            : print "The jock clerk has little to say. The ticking of the stopwatch finally makes the kvetcher snap. \"ANYTHING to get away from that noise.\" And they do run away. The jock clerk thanks you for your help, embarrassed they didn't think of that themselves. But they'll know for next time." ;
            : set_true "bonus_point_clock_jerk" ;
            : gosub "add_bonus" ;
            : done ;
         }
         : if (!bonus_point_clock_jerk) {
            : match "clock _;_ jerk" {
               : set_integer var="tempint" "4" ;
               : set_false "first_half" ;
               : match "clock _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   backin_cabin : location "{loc_backin_cabin}" header="{header_backin_cabin}" graphic="r_backin_cabin" {
      on_command {
         : match "pull file" {
            : collection_modify { collection = "tried_combo_core" index -> (7) content -> ("true") } ;
            : if (point_pull_file) {
               : print "You already pulled the file and made the cabin neater to make a path through!" ;
               : done ;
            }
            : print "Now you know what you're looking for in the full pile, or you're pretty sure you do, you can at least sort out the junk. Then you find a file. It describes where the secret passages in the cabin are. It's not pretty, but you dump some of the piles into the secret passages, as there's enough space in them, and things look a little cleaner. Those passages lead north, south and east." ;
            : set_true "point_pull_file" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_pull_file) {
            : match "pull _;_ file" {
               : set_integer var="tempint" "7" ;
               : set_false "first_half" ;
               : match "pull _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   cache_shack : location "{loc_cache_shack}" header="{header_cache_shack}" graphic="r_cache_shack" {
      on_command {
         : if (!buns_taken) {
            : match "take buns" {
               : if (original "verb" == "get") {
                  : print "You suddenly have this overwhelming fear of getting shot. Perhaps there's some other very similar way to acquire the buns." ;
                  : done ;
               }
               : print "Why, yes, it is that simple. You take the buns! Perhaps finding what to do next with them, or the resources to help you, will be trickier." ;
               : set_true "buns_taken" ;
               : update_graphic ;
               : pocket "buns" ;
               : done ;
            }
            : match "_ buns" {
               : print "You can't do much with the buns. At least not here. Maybe there's a simple command you could use to pick them up and carry them around to where you need to take them. One that's usually used a lot in text adventures." ;
               : print "A brief inspection turns up that they look sort of raw." ;
               : done ;
            }
         }
      }
      on_describe {
         : if (!buns_taken) {
            : print "There are BUNS just sitting around. They're packaged up and all. Shouldn't be hard to get them." ;
         }
      }
   }
   chattin_em_plain : location "{loc_chattin_em_plain}" header="{header_chattin_em_plain}" graphic="r_chattin_em_plain" {
      on_command {
         : match "platinum chain" {
            : if (point_platinum_chain) {
               : print "You already attracted the platinum chain to yourself." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (12) content -> ("true") } ;
            : print "Well, you pushed your luck ... a platinum chain slithers from the ground onto your wrist. It feels heavy. You try to shake it off, but it stays. You grab it and throw it to the ground, but it leaps back up onto your wrist. You're obviously going to need help taking it off." ;
            : set_true "point_platinum_chain" ;
            : pocket "chain" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_platinum_chain) {
            : match "platinum _;_ chain" {
               : set_integer var="tempint" "12" ;
               : set_false "first_half" ;
               : match "platinum _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : match "weary biz" {
            : if (bonus_point_weary_biz) {
               : print "Don't rub it in." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_bonus" index -> (6) content -> ("true") } ;
            : print "You listen to the beery whiz for a bit, almost convincing yourself they're not as interesting as they think they are. Then they look at you and ask what's the matter. Why hadn;t you offered any proper feedback? They are bringing all the energy to the conversation, here!\nYou have nothing to say. They go back to mumbling a bit softer, because you don't deserve to hear their wisdom. (Which is true. Just not in the way they think.)" ;
            : set_true "bonus_point_weary_biz" ;
            : gosub "add_bonus" ;
            : done ;
         }
         : if (!bonus_point_weary_biz) {
            : match "weary _;_ biz" {
               : set_integer var="tempint" "6" ;
               : set_false "first_half" ;
               : match "weary _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half_b" ;
               : done ;
            }
         }
      }
   }
   collation_location : location "{loc_collation_location}" header="{header_cl}" graphic="r_collation_location" {
      on_command {
         : match "grow dupes" {
            : if (point_grow_dupes) {
               : print "The dough groups are happy enough now! If you created too many, there'd be overpopulation." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (8) content -> ("true") } ;
            : if (!buns_taken) {
               : print "That seems right, but you have no raw materials with which to help the {puz_point_dough_groups_l} regenerate!" ;
               : set_true "think_grow_dupes" ;
               : done ;
            }
            : print "The buns you took manage to crumble off just enough. The {puz_point_dough_groups_l}, renewed, grow and -- somehow, when you're not looking -- reproduce. Mitosis! (Not meiosis, right?) They thank you and take a look at the buns. \"The regenerative properties are almost used up. But we can infuse them with one last boost, when you need them.\" You're not sure how, but given they seem happy with your acts, you trust them." ;
            : set_true "point_grow_dupes" ;
            : set_false "think_grow_dupes" ;
            : gosub "add_point" ;
            : update_graphic ;
            : done ;
         }
         : if (!point_grow_dupes) {
            : match "grow _;_ dupes" {
               : set_integer var="tempint" "8" ;
               : set_false "first_half" ;
               : match "grow _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   demo_meadow : location "{loc_demo_meadow}" header="{header_demo_meadow}" graphic="r_demo_meadow" {
      on_command {
         : if (!demo_or_meadow_tried) {
            : match "_ demo;_ meadow" {
               : print "{one_time}you don't have to do anything with the meadow itself. It's more what's in it. Titles like the demo meadow are a clue you don't have to do anything with that entity." ;
               : set_true "demo_or_meadow_tried" ;
               : done ;
            }
         }
         : match "s _" {
            : if (tutorial_0_in_tutorial && tutorial_9_north && !point_steel_wrench) {
               : print "You don't need to go back to the tool stall yet. You don't have what you need at the moment." ;
               : done ;
            }
         }
         : match "d _" {
            : if (tutorial_0_in_tutorial && point_steel_wrench) {
               : print "You don't need to go back to the rocky caves for the tutorial. You got what you needed." ;
               : done ;
            }
         }
         : if (point_tool_stall) {
            : match "tool stall" {
               : print "You already found a way {dir_s} to the tool stall. It will stay open." ;
               : done ;
            }
         }
         : if (!point_tool_stall) {
            : match "_ stool;_ tall" {
               : print "You're not sure why you think of the {puz_point_stool_tall} that way instead of a tall stool. It's weird -- dealing with it directly doesn't seem like the way to go. Perhaps it's indicating something else." ;
               : done ;
            }
            : match "tool stall" {
               : if (tutorial_0_in_tutorial && !tutorial_5_think) {
                  : print "That's how to score the first point, but we're in the tutorial right now, where we'll visit some help commands first." ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (2) content -> ("true") } ;
               : print "The {puz_point_stool_tall} shakes and falls over and rolls around more than you thought possible. As it does, its legs point to a passage you haven't seen before, to the {dir_s}." ;
               : set_true "point_tool_stall" ;
               : set_true "tutorial_6_tool_stall" ;
               : increment "tutorial_score" ;
               : gosub "add_point" ;
               : update_graphic ;
               : done ;
            }
            : match "tool _;_ stall" {
               : set_integer var="tempint" "2" ;
               : set_false "first_half" ;
               : match "tool _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : if (placed_flaming_towers) {
            : match "taming flowers" {
               : if (point_taming_flowers) {
                  : print "You already picked some taming flowers! You should probably let them grow back in case someone else needs them." ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (5) content -> ("true") } ;
               : print "You look for taming flowers. You figure weapons won't work. What sort of flowers would tame fire? Why, cold ones. You find ones that look really frosty, and what do you know? They feel frosty, too!\nYou walk up to each tower, and the flowers stand up surprisingly well to the heat. The towers dissolve in heaps of ash. You can go {dir_n} and {dir_e} and {dir_w} now." ;
               : set_true "point_taming_flowers" ;
               : gosub "add_point" ;
               : update_graphic ;
               : done ;
            }
         }
         : if (flaming_towers_present) {
            : if (!point_taming_flowers) {
               : match "taming _;_ flowers" {
                  : set_integer var="tempint" "5" ;
                  : set_false "first_half" ;
                  : match "taming _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
         : if (listen_demo_meadow) {
            : match "rocky caves" {
               : collection_modify { collection = "tried_combo_core" index -> (0) content -> ("true") } ;
               : if (point_rocky_caves) {
                  : print "You already know where the rocky caves are." ;
                  : done ;
               }
               : print "The cockiness seems to recede as you look around with a purpose. Then you find it. A passage {dir_d} to rocky caves!" ;
               : set_true "point_rocky_caves" ;
               : set_true "tutorial_11_rocky_caves" ;
               : increment "tutorial_score" ;
               : gosub "add_point" ;
               : done ;
            }
            : if (!point_rocky_caves) {
               : match "rocky _;_ caves" {
                  : set_integer var="tempint" "0" ;
                  : set_false "first_half" ;
                  : match "rocky _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
         : match "listen _" {
            : if (point_rocky_caves) {
               : print "Quieter, with the cocky raves gone." ;
               : done ;
            } : else_if (!listen_demo_meadow) {
               : if (tutorial_0_in_tutorial && !tutorial_9_north) {
                  : print "You'll want to do that later in the tutorial, but not yet." ;
                  : done ;
               }
               : print {( "What's that? {puz_point_cocky_raves_u}! Saying you won't find any" + (point_tool_stall ? " other" : "" ) + " way out of the meadow." )} ;
               : set_true "listen_demo_meadow" ;
               : if (!tutorial_10_listen) {
                  : set_true "tutorial_10_listen" ;
                  : increment "tutorial_score" ;
               }
               : update_graphic ;
            } : else {
               : print "{puz_point_cocky_raves_u} continue to mock your inability to go anywhere interesting." ;
            }
            : done ;
         }
      }
      on_describe {
         : if (flaming_towers_present) {
            : print "Those flaming towers are still flaming, exposing passage {dir_n}, {dir_e} and {dir_w} but not letting you by." ;
         } : else_if (point_tight_rules && !placed_flaming_towers) {
            : print {( (placed_flaming_towers ? "Flaming towers still block your way" : "Yeah, that was worth the eerie loner making a scene over. Flaming towers have now popped up") + " to the {dir_n}, {dir_e} and {dir_w}!" )} ;
            : set_true "placed_flaming_towers" ;
            : update_graphic ;
         }
      }
      on_pre_describe {
         : if (point_steel_wrench && !tutorial_15_up) {
            : set_true "tutorial_15_up" ;
            : increment "tutorial_score" ;
         } : else_if (think_leery_owner && !tutorial_9_north) {
            : set_true "tutorial_9_north" ;
            : increment "tutorial_score" ;
         }
      }
   }
   foldin_gate : location "{loc_foldin_gate}" header="{header_foldin_gate}" graphic="r_foldin_gate" {
      on_command {
         : match "great book" {
            : collection_modify { collection = "tried_combo_core" index -> (28) content -> ("true") } ;
            : if (!point_help_card) {
               : print "You'd like that, but you realize you'd need a special card or something to check it out. You don't have one." ;
               : set_true "think_great_book" ;
               : done ;
            }
            : print "Narrative text." ;
            : set_false "think_great_book" ;
            : set_true "point_great_book" ;
            : gosub "add_point" ;
            : win_game ;
            : done ;
         }
         : if (!point_great_book) {
            : match "great _;_ book" {
               : set_integer var="tempint" "28" ;
               : set_false "first_half" ;
               : match "great _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : match "n _" {
            : if (!bonus_point_golden_fate) {
               : print "You'll need to open the gate first. What could be behind it?" ;
            } : else {
               : cycle key = "thru_gate" predictable_order = "true" skip_interval = "0" max_loops = "1" {
                  : print "The trowel jiggles and seems to pull you away." ;
                  : print "You enter and achieve riches beyond your wildest dreams. But your life gets boring that way." ;
               }
            }
            : done ;
         }
         : match "golden fate" {
            : if (bonus_point_golden_fate) {
               : print "You already opened the foldin' gate!" ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_bonus" index -> (9) content -> ("true") } ;
            : print "The foldin' gate opens to reveal a golden fate behind it! What could be better than gold? Lots of it?" ;
            : set_true "bonus_point_golden_fate" ;
            : gosub "add_bonus" ;
            : done ;
         }
         : if (!bonus_point_golden_fate) {
            : match "golden _;_ fate" {
               : set_integer var="tempint" "9" ;
               : set_false "first_half" ;
               : match "golden _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half_b" ;
               : done ;
            }
         }
      }
   }
   gnawing_awning : location "{loc_gnawing_awning}" header="{header_gnawing_awning}" graphic="r_gnawing_awning" {
      on_command {
         : match "sail tide" {
            : if (point_sail_tide) {
               : print "You already made a sail tide from the tail side! You don't want to mess with nature too much." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (21) content -> ("true") } ;
            : print "The tail side creaks and somehow sets off a Rube Goldberg-esque sequence of events that results in a waterway opening and the tide rising. You see a boat sail south out of view and then hear yelling to the south." ;
            : set_true "point_sail_tide" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_sail_tide) {
            : match "sail _;_ tide" {
               : set_integer var="tempint" "21" ;
               : set_false "first_half" ;
               : match "sail _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : match "sick bride" {
            : if (point_sick_bride) {
               : print "You already discovered and helped the sick bride. She is busy making herself less sick, and as only a fleeting acquaintance you can't really help her any more." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (20) content -> ("true") } ;
            : print "You are sort of surprised, and not, to find a sick bride. She talks about why she can't go through with a wedding. What she found that she couldn't even have told her friends. They are probably looking for her. But it is embarrassing. You say you'll keep a look out." ;
            : set_true "point_sick_bride" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_sick_bride) {
            : match "sick _;_ bride" {
               : set_integer var="tempint" "20" ;
               : set_false "first_half" ;
               : match "sick _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : match "sold guide" {
            : if (point_sold_guide) {
               : print "You already bought a guide. You don't need a duplicate." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (19) content -> ("true") } ;
            : if (!point_penny_mounds) {
               : print "It could be sold, once you have a way to pay for it." ;
               : set_true "think_sold_guide" ;
               : done ;
            }
            : print "Hooray! Thanks to the penny mounds you found, you are able to purchase a sold guide. Reading it briefly, it notes you need a torch. Where to get one, it says, well, the perspicacious reader should be able to figure that out." ;
            : set_false "think_sold_guide" ;
            : set_true "point_sold_guide" ;
            : gosub "add_point" ;
            : pocket "sold_guide" ;
            : done ;
         }
         : if (!point_sold_guide) {
            : match "sold _;_ guide" {
               : set_integer var="tempint" "19" ;
               : set_false "first_half" ;
               : match "sold _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   jeerin_region : location "{loc_jeerin_region}" header="{header_jeerin_region}" graphic="r_jeerin_region" {
      on_command {
         : if (kelp_placed) {
            : match "_ hard;_ kelp" {
               : print {( point_help_card ? "You pick through the kelp but find nothing else." : "There's a lot of kelp. It would help to know what to pick through." )} ;
               : done ;
            }
         }
         : match "written specs" {
            : if (point_written_specs) {
               : print "No, you have enough written specs. Asking for more might make the spittin' wrecks beat you down for your greed." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (24) content -> ("true") } ;
            : if (!point_best_notes) {
               : print "The {puz_point_spittin_wrecks} almost look interested for a moment before yelling at you for not giving them guidelines to figure out such a thing. Sure, it can be done, but ..." ;
               : set_true "think_written_specs" ;
               : done ;
            }
            : print "You give the spittin' wrecks the best notes. They nod. After a while, they hand back some written specs, which seem to detail a labyrinth. They note where the walls are thin and that you need to knock down a wall to get through. You wonder if they are pulling your leg, but you don't have much else to work with. They ask if they can keep the notes. They tell you it would be selfish to keep them, which suits you fine for clearing up inventory space, then they find you a bit of a sucker for handing the notes over so quickly." ;
            : destroy "best_notes" ;
            : set_false "think_written_specs" ;
            : set_true "point_written_specs" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_written_specs) {
            : match "written _;_ specs" {
               : set_integer var="tempint" "24" ;
               : set_false "first_half" ;
               : match "written _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
      on_describe {
         : if (has_visited "foldin_gate" && !kelp_placed) {
            : print "The destruction of the hard maze must have sent across some serious shockwaves. Some kelp (hard) has appeared along the sandy area." ;
            : set_true "kelp_placed" ;
         }
      }
   }
   moldin_dolmen : location "{loc_moldin_dolmen}" header="{header_moldin_dolmen}" graphic="r_moldin_dolmen" {
      on_command {
         : match "_ fax;_ machine" {
            : print {( point_formed_wax ? "There's no trace of the fax machine, but it's not useful to you any more." : "When you walk over by the machine, it spits out a fax every couple minutes. Each fax is warmed but quickly cools off and disintegrates. What on earth could you do with a {puz_point_warmed_fax}?" )} ;
            : set_true "fax_examined" ;
            : done ;
         }
         : if (fax_examined) {
            : match "formed wax" {
               : if (point_formed_wax) {
                  : print "You got enough formed wax. Besides, the fax machine is gone." ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (15) content -> ("true") } ;
               : print "You grab a warmed fax as it comes out. Not sure what to do with it, or how to make formed wax, you crumple it in a ball and throw it at the dolmen. The dolmen throws a lump of formed wax back at you. It's not fully formed, but it's in a block that will fit nicely into your pocket while still being able to take impressions of whatever you need to make impressions of.\nYou're so busy fumbling in your pocket you don't notice the fax machine has stopped appearing. You doubt you need more wax, though." ;
               : pocket "wax" ;
               : set_true "point_formed_wax" ;
               : gosub "dolmen_key_form" ;
               : gosub "add_point" ;
               : done ;
            }
            : if (!point_formed_wax) {
               : match "formed _;_ wax" {
                  : set_integer var="tempint" "15" ;
                  : set_false "first_half" ;
                  : match "formed _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
      }
      on_describe {
         : gosub "dolmen_key_form" ;
      }
   }
   newbies_boonies : location "{loc_newbies_boonies}" header="{header_newbies_boonies}" graphic="r_newbies_boonies" {
      on_command {
         : match "push best" {
            : if (point_push_best) {
               : print "You already pushed the bush pest away." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (5) content -> ("true") } ;
            : set_true "point_push_best" ;
            : print "It's an interesting little rassling match. Direct pushing doesn't work, but you have an idea. You move to your right, then as the bush comes to the right, you pull a Reggie White club move on it, pushing it the direction it was already going..." ;
            : press_any_key ;
            : update_graphic ;
            : set_integer var="newbies_cutscene" value="1";
            : print "It screams, then ..." ;
            : press_any_key ;
            : update_graphic ;
            : print "Oh no! You're worried you did permanent damage to it. You walk over to make sure it's okay. It get up, sticks its tongue out, and runs away for easier people, or entities, to be a nuisance to." ;
            : print "You can go all four directions now." ;
            : set_integer var="newbies_cutscene" value="2";
            : press_any_key ;
            : update_graphic ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_push_best) {
            : match "push _;_ best" {
               : set_integer var="tempint" "6" ;
               : set_false "first_half" ;
               : match "push _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   oopster_stupor : location "{loc_oopster_stupor}" header="{header_oopster_stupor}" graphic="r_oopster_stupor" {
      on_command {
         : if (point_hard_maze && !has_visited "foldin_gate") {
            : match "n _" {
               : if (!point_written_specs) {
                  : print "Whoah! Walking into a hard maze like that without any sort of map is just too intimidating." ;
                  : done ;
               } : else_if (!point_power_torch) {
                  : print "The written specs show there's no way to walk through. You'll need some sort of tool to bust down a wall." ;
                  : done ;
               } : else_if (!point_cool_plan) {
                  : print "You think you could make it through, but ... what if you have to walk back through the maze? That'd be really exhausting. Your sense of efficiency (at least you call it that instead of laziness. Heck, I do) leaves you wanting an easy way back before you make a huge time and energy commitment." ;
                  : done ;
               } : else {
                  : mask {
                     : print "The written specs show the way through, minus where you need to burn through a wall with the torch. And the cool plan will help you get back. Armed with all this, you start in on the hard maze. All goes smoothly until ..." ;
                     : press_any_key ;
                  }
               }
               : print "You walk into the maze. The written specs accurately show the passage. But then ... a noise. Horror of horrors, it's ..." ;
               : press_any_key ;
               : goto "sappage_passage" ;
               : redescribe ;
            }
         }
         : match "hard maze" {
            : if (point_hard_maze) {
               : print "You already cleared the marred haze!" ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (17) content -> ("true") } ;
            : print "The mists seem to re-form into ... something potentially worse! A hard maze! But at least you will be able to see your way through it. It seems pretty big, though, so you'll probably need some aid." ;
            : set_true "point_hard_maze" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_hard_maze) {
            : match "hard _;_ maze" {
               : set_integer var="tempint" "17" ;
               : set_false "first_half" ;
               : match "hard _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   outer_tower : location "{loc_outer_tower}" header="{header_outer_tower}" graphic="r_outer_tower" {
      on_command {
         : match "_ tower" {
            : print {( "You step back and appreciate what an impressive tower it is. " + (key_used ? "You have free passage through it now." : "Perhaps the keyhole provides a clue how to get through.") )}
            : done ;
         }
         : if (porch_in_tower) {
            : match "power torch" {
               : if (point_power_torch) {
                  : print "You already found the torch!" ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (22) content -> ("true") } ;
               : print "You wonder briefly if you are looking for a really strong flashlight, but no. You discover a power torch. It seems to have one more burst left." ;
               : set_true "point_power_torch" ;
               : pocket "power_torch" ;
               : gosub "add_point" ;
               : done ;
            }
         }
         : if (!ever_keyhole) {
            : match "_ hole;_ keyhole" {
               : print "When you look at the keyhole, it moves around a bit. A voice from inside booms \"Few can figure how to open the {puz_point_dodging_lock_u}!\"" ;
               : set_true "ever_keyhole" ;
               : done ;
            }
         } : else_if (!key_used) {
            : match "_ hole;_ keyhole;_ dodging;_ lock" {
               : print {( point_lodging_doc ? "The lock is stable now." : "The lock is still dodging. In order to open it, you'll want to stop it moving around." )} ;
               : done ;
            }
         }
         : if (porch_in_tower) {
            : if (!point_power_torch) {
               : match "power _;_ torch" {
                  : set_integer var="tempint" "22" ;
                  : set_false "first_half" ;
                  : match "power _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
         : if (ever_keyhole && !key_used) {
            : match "lodging doc;lodging dock" {
               : if (point_lodging_doc) {
                  : print "You already made the lock stable." ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (14) content -> ("true") } ;
               : print "You aren't sure if the lock responded to \"doc\" or \"dock.\" It does, however, stop. \"You can come in if you have the key, I guess,\" says a voice.\n\"What? Don't know which key you want? Yonder, futz fonder, yutz!\"" ;
               : set_true "point_lodging_doc" ;
               : gosub "add_point" ;
               : done ;
            }
            : if (!point_lodging_doc) {
               : match "lodging _;_ doc;_ dock" {
                  : set_integer var="tempint" "14" ;
                  : set_false "first_half" ;
                  : match "lodging _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
      }
      on_describe {
          : if (key_duplicated && !key_used) {
             : print "You hope the key works. It'd better. You'd hate to have to back and forth to the trove. All those trips, and no detour to bound rocks to find a round box." ;
             : print "There's always that nervous moment. Then, CLICK!" ;
             : set_true "key_used" ;
          }
      }
   }
   rocky_caves : location "{loc_rocky_caves}" header="{header_rocky_caves}" graphic="r_rocky_caves" {
      on_command {
         : match "u _" {
            : if (tutorial_0_in_tutorial && !point_steel_wrench) {
               : print "You have something to retrieve before going back to the demo meadow." ;
               : done ;
            }
         }
         : match "_ sunshine;_ shun;_ sign;_ sun;_ shine" {
            : print "It's a drawing of a sun with a red X over it. It's just there for local flavor." ;
            : if (!sunshine_xed) {
               : print "{one_time}when a room or thing or person is a spoonerism of itself, like the Demo Meadow, it's there for local flavor or humor. Authors try to balance having Extra Stuff to Look At with not distracting you too much, and I tried to establish this convention in {this_game} I hope it works." ;
               : set_true "sunshine_xed" ;
            }
            : done ;
         }
         : match "smell _" {
            : if (point_steel_wrench) {
               : print "You're kind of used to the smell. Whether it got a bit less once you found the wrench, or your mood improved so it didn't bug you, you don't know. But it's not worth reflecting too deeply on. There's probably not anything else in the stench." ;
            } : else_if (!smell_rocky_caves) {
               : print "You smell something. Something bad. A {puz_point_real_stench}." ;
               : set_true "smell_rocky_caves" ;
               : set_true "tutorial_13_smell" ;
               : increment "tutorial_score" ;
               : update_graphic ;
            } : else {
               : print "Still that {puz_point_real_stench}." ;
            }
            : done ;
         }
         : if (smell_rocky_caves) {
            : match "_ stench" {
               : print {( point_steel_wrench ? "You don't want to deal with the stench. You got something from it. Probably best to just leave." : "There must be something worth fighting through the stench for. But what?" )} ;
               : done ;
            }
            : if (!point_steel_wrench) {
               : match "steel wrench" {
                  : if (point_steel_wrench) {
                     : print "You already got the steel wrench!" ;
                     : done ;
                  }
                  : collection_modify { collection = "tried_combo_core" index -> (1) content -> ("true") } ;
                  : print "The stench is more bearable now you know what you're looking for. But you've still had quite enough of it -- you had to go into its heart -- once you acquire said wrench." ;
                  : set_true "point_steel_wrench" ;
                  : set_true "tutorial_14_steel_wrench" ;
                  : increment "tutorial_score" ;
                  : gosub "add_point" ;
                  : pocket "wrench" ;
                  : done ;
               }
               : match "steel _;_ wrench" {
                  : set_integer var="tempint" "1" ;
                  : set_false "first_half" ;
                  : match "steel _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
      }
      on_pre_describe {
         : if (!tutorial_12_down) {
            : set_true "tutorial_12_down" ;
            : increment "tutorial_score" ;
         }
      }
   }
   sappage_passage : location "{loc_sappage_passage}" header="{header_sappage_passage}" graphic="r_sappage_passage" {
         on_command {
            : match "_ fist;_ rumble;_rumbling" {
               : print "IT'S RUMBLIN' STRAIGHT FOR YA! It looks sturdy and steady, but maybe you can throw a hail mary here." ;
               : done ;
         }
         : match "fumbling wrist" {
            : if (point_fumbling_wrist) {
               : print "Already done! But you should never get here." ;
               : done ;
            }
            : print "You decide to ask the fist what could be attached to it. Surely it can't propel itself all alone, can it? Perhaps this wouldn't work elsewhere, but the sappage passage--well, it doesn't just affect you. It's particularly harsh on beings who act, act, act and don't think. And you've certainly been doing some thinking this game!" ;
            : print "The fist crash-lands, sputters into the air a few times, then finally punches the ground weakly and rolls off to the side." ;
            : print "You go back to reading your map. You're worried your brain will be sapped. But actually, something boring like working through a maze is just what you need. Because it sapped your sense of anger and \"why do I have to do this\" feelings. You find where to use the power torch and make it through quickly.\nThe cool plan mentions a way to make the maze go tumbling down. The crash echoes longer than you thought. Maybe it caused disruptions elsewhere! It will be easier to check, eventually, with the maze gone. Boy, the exit was actually really close to the entrance without all the walls in the way." ;
            : press_any_key ;
            : collection_modify { collection = "tried_combo_core" index -> (26) content -> ("true") } ;
            : set_true "point_fumbling_wrist" ;
            : gosub "add_point" ;
            : goto "foldin_gate" ;
            : redescribe ;
            : done ;
         }
         : if (!point_fumbling_wrist) {
            : match "fumbling _;_ wrist" {
               : set_integer var="tempint" "26" ;
               : set_false "first_half" ;
               : match "rumbling _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   streaky_cove : location "{loc_streaky_cove}" header="{header_streaky_cove}" graphic="r_streaky_cove" {
      on_command {
         : match "creaky stove" {
            : if (point_creaky_stove) {
               : print {( point_bake_tons ? "The stove is blown to bits. You can't get it back." : "You already revealed the stove!" )} ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (9) content -> ("true") } ;
            : print "Ah! That's what's along the unusually plain wall on the right-hand side. A creaky stove! You see an outline, and as you tap at the wall, it crumbles a bit. Yet that area still looks out of place." ;
            : set_true "point_creaky_stove" ;
            : gosub "add_point" ;
            : update_graphic ;
            : done ;
         }
         : if (!point_creaky_stove) {
            : match "creaky _;_ stove" {
               : set_integer var="tempint" "9" ;
               : set_false "first_half" ;
               : match "creaky _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : if (point_key_trove) {
            : match "_ trove;_ keys;_ key" {
               : if (!point_lodging_doc) {
                  : print {( "So many keys with so many labels. " + (has_visited "outer_tower" ? "You wouldn't know which would fit the outer tower!" : "You haven't found anything that needs unlocking yet, so you won't waste time searching." ) )};
               } : else_if (!key_found) {
                  : print "You remember the phrase from the dodging lock. YONDER, FUTZ FONDER, YUTZ. It takes a while to search through the keys, but fortunately they're sorted more or less alphabetically, so that saves time. Unfortunately, the key you pick is rusty, and you can't find another. It will fall apart if you try to open the lock." ;
                  : set_true "key_found" ;
                  : pocket "trove_key" ;
               } : else_if (key_duplicated) {
                  : print {( "You have no need to search for another key, now you " + (key_used ? "used it" : "have a stronger replacement") + "." )} ;
               } : else {
                  : print "You look at your flimsy key and search for another stronger one in the trove, but nothing turns up. Bummer. But you have the key's shape. Perhaps somewhere else you can make a sturdier key." ;
               }
               : done ;
            }
         }
         : if (point_creaky_stove && !point_bake_tons) {
            : match "_ stove" {
               : print "The stove has all sorts of settings to cook stuff. You've been around microwave ovens a lot, but you haven't totally lost touch with old-school cooking. You muse on *what* a stove could cook, and what *sort* of cooking you'd need to do." ;
               : print "The stove also looks, well, old. A stress-test might destroy it. Maybe there's something inside or under. This is a cove, after all." ;
               : done ;
            }
         }
         : if (point_creaky_stove && is_carried "buns") {
            : match "bake tons" {
               : if (point_bake_tons) {
                  : print "Even if the stove weren't destroyed, you've had enough baking for one adventure, " ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (10) content -> ("true") } ;
               : if (!point_grow_dupes) {
                  : print "You tear off one bun and put it in the oven. But, alas, it doesn't grow back fast enough. You need a way to help it grow back faster." ;
                  : set_true "think_bake_tons" ;
                  : done ;
               }
               : print "The buns, charged with the dough groups' magic, fizzle as they heat up and explode! Fortunately, only the less picturesque part of the streaky cove blew up. Behind the streaky cove, you notice a different sort of cove: a {puz_point_tree_cove}!" ;
               : set_true "point_bake_tons" ;
               : set_false "think_bake_tons" ;
               : gosub "add_point" ;
               : update_graphic ;
               : destroy "buns" ;
               : done ;
            }
         }
         : if (point_bake_tons) {
            : match "key trove" {
               : if (point_key_trove) {
                  : print "You already found the key trove. You just need to figure what to do with it." ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (11) content -> ("true") } ;
               : print "There are a lot of trees, but you eventually uncover a key trove." ;
               : set_true "point_key_trove" ;
               : gosub "add_point" ;
               : done ;
            }
         }
         : if (point_bake_tons && !point_key_trove) {
            : match "key _;_ trove" {
               : set_integer var="tempint" "11" ;
               : set_false "first_half" ;
               : match "key _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   taller_altar : location "{loc_taller_altar}" header="{header_taller_altar}" graphic="r_taller_altar" {
      on_command {
         : match "cool plan" {
            : if (point_cool_plan) {
               : print "The pool clan is gone. You already got the cool plan." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (25) content -> ("true") } ;
            : print "They seem quite glad you managed to give your friend a tip how to flee and start a new life. They appreciate the instructions to visit her. In return they share a cool plan for making it easier to return once you've gone a ways north of the tenser center. Whew! You sort of feared what was out there." ;
            : set_true "point_cool_plan" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_cool_plan) {
            : match "cool _;_ plan" {
               : set_integer var="tempint" "25" ;
               : set_false "first_half" ;
               : match "cool _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : match "penny mounds" {
            : if (point_penny_mounds) {
               : print "You already reduced the many pounds!" ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (18) content -> ("true") } ;
            : print "A few of the pounds crumble away to something less dense. Something in small enough bits you can carry it. So you do. The rest ... well, they're still there, but you know you have no use for them." ;
            : set_true "point_penny_mounds" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_penny_mounds) {
            : match "penny _;_ mounds" {
               : set_integer var="tempint" "18" ;
               : set_false "first_half" ;
               : match "penny _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   tenser_center : location "{loc_tenser_center}" header="{header_tenser_center}" graphic="r_tenser_center" {
      on_command {
         : match "minister south" {
            : if (point_minister_south) {
               : print "The sinister mouth will not return. No need to disturb the clergy." ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (16) content -> ("true") } ;
            : print "Well, you came from the south, and so maybe you can call some good guys south to help you. Some who know how to deal with evil monsters. You're in luck! A mistin'-er minister sprays the sinister mouth with Spring-'Way-Wing-Spray. You thank the minister profusely, but they say it's no big deal. The mouth wasn't evil, or at any rate very adept at evil. It just sort of hoped it was." ;
            : set_true "point_minister_south" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_minister_south) {
            : match "minister _;_ south" {
               : set_integer var="tempint" "16" ;
               : set_false "first_half" ;
               : match "minister _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
      on_describe {
         : if (!center_sign_fell && has_visited "foldin_gate") {
            : print "Oh, wow! That U R HERE sign fell over since last you passed by. Maybe the maze collapsing caused other changes worth checking out." ;
            : set_true "center_sign_fell" ;
         }
      }
   }
   tool_stall : location "{loc_tool_stall}" header="{header_tool_stall}" graphic="r_tool_stall" {
      on_command {
         : match "_ eerie;_ loner" {
            : print {( point_leery_owner ? "You're glad the loner's gone. No need to deal with them any more." : "The eerie loner's I H8 PPL tshirt suggests you may want to just ask them to refer you to someone who is more willing, or less unwilling, to help you." )} ;
            : done ;
         }
         : match "_ right;_ sign" {
            : print {( point_tight_rules ? "You figured what the sign was really for." : "It's weird. The sign doesn't just feel like bragging. It feels like ... if you know what to ask for, you can get it. An off the menu item so to speak. But if you don't, you don't deserve it. Yet." )} ;
            : done ;
         }
         : match "_ tools" {
            : print {( "The tools to the left of the sign make a bewildering array. " + (point_tight_rules ? "Fortunately, the leery owner helped you realize you were already carrying the right tool." : "You are intimidated. You have no guidelines to use them, and some, such as the Ho-Slam-'Er-Slow Hammer, seem much more violent than you'd want to have to use. You have no clue which is most right, or least wrong, for you." ) )} ;
            : done ;
         }
         : match "n _" {
            : if (tutorial_0_in_tutorial) {
               : if (!think_leery_owner) {
                  : print "For the purposes of this tutorial, you need to figure whom to ask the {puz_point_eerie_loner} for before going back {dir_n}." ;
                  : done ;
               }
               : if (point_steel_wrench && !point_leery_owner) {
                  : print "For the purposes of this tutorial, you need to remember whom to ask the {puz_point_eerie_loner} for before going back {dir_n}." ;
                  : done ;
               }
            }
         }
         : if (point_leery_owner) {
            : match "tight rules" {
               : if (point_tight_rules) {
                  : print "You already mastered the tight rules needed to use the right tools." ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (4) content -> ("true") } ;
               : print "You say you're willing to use the tools, whatever they are, properly and take the time to be taught. The leery owner is pleased with this, or at least less displeased than you expected." ;
               : print "They ask what you're looking for. You say you're not sure. You have one you're clueless about, the trowel ..." ;
               : print "The leery owner whistles. \"I can't give any big guidelines, but I'll tell you what I know about artifacts like that." ;
               : print "It takes a while. Once you're done, the eerie loner pops back in to complain about how terrible things are outside." ;
               : print "\"Boy,\" says the owner. \"Usually the loner just grouses quietly about the state of the world these days. But if they actually spoke up, things must be bad. Better go check." ;
               : print "Or, if you want first, I can show you a path back somewhere that may ... help you a bit. Or not. It's off to the south.\"" ;
               : set_true "point_tight_rules" ;
               : gosub "add_point" ;
               : destroy "wrench" ;
               : done ;
            }
            : if (!point_tight_rules) {
               : match "tight _;_ rules" {
                  : set_integer var="tempint" "4" ;
                  : set_false "first_half" ;
                  : match "tight _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
         : match "leery owner" {
            : if (point_leery_owner) {
               : print "You already summoned the owner!" ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (3) content -> ("true") } ;
            : if (!point_steel_wrench) {
               : print "The {puz_point_eerie_loner} grumbles \"Can't disturb the owner unless you have something for them.\"" ;
               : if (tutorial_0_in_tutorial && !tutorial_8_leery_owner_1) {
                  : print "{one_time}currently tutorial progress is listed in the upper right, but when you get the right command before you're ready, +1 or +2 will appear in the upper right after your score, to remind you you've gotten close somewhere. Also, {vd_think} will save such commands. You can try it now, but it's not critical for the tutorial." ;
               }
               : if (!tutorial_8_leery_owner_1) {
                  : set_true "tutorial_8_leery_owner_1" ;
                  : increment "tutorial_score" ;
               }
               : set_true "think_leery_owner" ;
               : done ;
            }
            : print "The eerie loner grumbles. You show the steel wrench.\n\"All right, I'll get 'em.\" The loner leaves, their job done for the day. The leery owner comes out.\n\"Looking for the {puz_point_right_tools}, eh? Well, we don't just sell them to anyone who wants them. There are safety precautions and such.\" What could those precautions be?" ;
            : set_true "point_leery_owner" ;
            : set_false "think_leery_owner" ;
            : set_true "tutorial_17_leery_owner_2" ;
            : increment "tutorial_score" ;
            : update_graphic ;
            : gosub "add_point" ;
            : if (tutorial_0_in_tutorial) {
               : print "Congratulations! You finished the tutorial. You may also note that your score is now listed in the upper right. You're one-seventh of the way to the City. Best of luck!" ;
               : set_false "tutorial_0_in_tutorial" ;
            }
            : done ;
         }
         : if (!point_leery_owner) {
            : match "leery _;_ owner" {
               : set_integer var="tempint" "3" ;
               : set_false "first_half" ;
               : match "leery _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
      on_pre_describe {
         : if (!tutorial_7_south_first) {
            : set_true "tutorial_7_south_first" ;
            : increment "tutorial_score" ;
         }
         : if (point_steel_wrench && !tutorial_16_south_twice) {
            : set_true "tutorial_16_south_twice" ;
            : increment "tutorial_score" ;
         }
      }
   }
   yankin_canyon : location "{loc_yankin_canyon}" header="{header_yankin_canyon}" graphic="r_yankin_canyon" {
      on_command {
         : if (point_chop_drain) {
            : match "chop drain" {
               : print "You don't need to chop anything else up." ;
               : done ;
            }
         }
         : match "listen _" {
            : print {( point_chop_drain ? "No whirring now." : "There's a whirring from the hole." )} ;
            : done ;
         }
         : match "_ hole" {
            : print {( point_chop_drain ? "Now you know the hole can shred metal, you REALLY don't want to mess with it." : "You watch the hole a bit. Leaves and tumbleweeds and such get torn apart as they are sucked in, with some finer particles being thrown back up after." )} ;
            : done ;
         }
      }
   }
}

# Defines things in the world (scenery cannot be carried)
objects {
   best_notes : object "the best notes from the nest boats" ;
   buns : object "the BUNS you managed/needed to TAKE" at="cache_shack" conspicuous="false" ;
   chain : object "the platinum CHAIN that snapped onto you that you want to get rid of. Oh, what's the word?" ;
   hold_card : object "the cold hard hold card from the hard kelp" ;
   slab : object "the slender fab fender slab that was inside the platinum chain" conspicuous="false" ;
   power_torch : object "the power torch you found on the tower porch. It has enough for one charge." ;
   seek_key : object "the reconstructed key from the dolmen" ;
   sold_guide : object "the sold guide you bought with the penny mounds" ;
   trove_key : object "a rusty key (crusty! Eee!) from the trove" ;
   trowel : object "the trudge-now'll-nudge trowel you started with" ;
   wax : object "the formed wax from the warmed fax" ;
   widget : object "the {i_widget} you found on your person" ;
   wrench : object "the wrench from the rocky caves" ;
}

zones {
   start_zone : zone {
      locations = [ rocky_caves, app_mall, tool_stall, demo_meadow ]
   }
   middle_zone : zone {
      locations = [ chattin_em_plain, streaky_cove, cache_shack, newbies_boonies, backin_cabin, yankin_canyon, moldin_dolmen, collation_location ]
   }
   end_zone : zone {
      locations = [ outer_tower, ailer_lair, tenser_center, jeerin_region, gnawing_awning, oopster_stupor, taller_altar, foldin_gate ]
   }
}
connections {

   from, direction, to = [

      demo_meadow, down, rocky_caves
      demo_meadow, south, tool_stall

      demo_meadow, north, outer_tower
      demo_meadow, east, backin_cabin
      demo_meadow, west, newbies_boonies

      backin_cabin, north, collation_location
      backin_cabin, east, yankin_canyon
      backin_cabin, south, streaky_cove

      newbies_boonies, west, cache_shack
      newbies_boonies, north, moldin_dolmen
      newbies_boonies, south, chattin_em_plain

      outer_tower, north, tenser_center

      tenser_center, east, jeerin_region
      tenser_center, west, ailer_lair
      tenser_center, north, oopster_stupor

      ailer_lair, north, gnawing_awning
      jeerin_region, north, taller_altar

      oopster_stupor, north, foldin_gate

      tool_stall, south, app_mall

   ]

}

