         : overlay "s_ailer_lair_blabber" x="160" y="18" ;
         : overlay "s_ailer_lair_blabber" x="180" y="18" ;
         : overlay "s_ailer_lair_blabber" x="200" y="18" ;
         : overlay "s_ailer_lair_blabber" x="220" y="18" ;
      }
   }
   : if (is_at "backin_cabin") {
      : if (point_pull_file) {
