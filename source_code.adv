subroutines {

   note_score_upper_right : subroutine {
      : if (!noted_upper_right) {
         : print "{one_time}you can toggle score notifications with {optt_notify} {yn}. The score is always tracked in the upper right." ;
         : set_true "noted_upper_right" ;
      }
   }
   add_bonus : subroutine {
      : if (opt_score_notify) {
         : print "<You just found a bonus point!<#ff0>>" ;
         : if (bonus_score == 0) {
            : print "{one_time}{this_game} contains several bonus points that are uncued on the first playthrough. {vd_sco} will let you know how many you've found, and {vd_bon} will list where you found them." ;
         }
      }
      : increment "bonus_score" ;
      : update_graphic ;
   }

   add_point : subroutine {
      : if (opt_score_notify) {
         : print "<Your score has just gone up by a point!<#ff0>>" ;
      }
      : gosub "note_score_upper_right" ;
      : increment "score" ;
      : update_graphic ;
   }

   say_half : subroutine {
      : match "* -;- *" {
         : print "Feels right, but what to pair that word with?" ;
         : done ;
      }
      : cycle key = "one_right" predictable_order = "true" skip_interval = "0" max_loops = "1" {
         : print "One of those words felt right, but the other didn't. You must be halfway there{for_bonus}.{already_got_check}" ;
         : print "Again, you feel like you got halfway there{for_bonus}.{already_got_check}" ;
         on_exhausted {
            : print "One word right, one word wrong{for_bonus}.{already_got_check}" ;
         }
      }
      : if (first_half) {
         : if (half_bonus) {
            : collection_modify { collection = "got_first_bonus" index -> (tempint) content -> ("true") ; }
         } : else {
            : collection_modify { collection = "got_first_core" index -> (tempint) content -> ("true") ; }
         }
      } : else {
         : if (half_bonus) {
            : collection_modify { collection = "got_second_bonus" index -> (tempint) content -> ("true") ; }
         } : else {
            : collection_modify { collection = "got_second_core" index -> (tempint) content -> ("true") ; }
         }
      }
      : set_false "already_got_command" ;
      : if (!half_bonus) {
         : done ;
      }
   }
   say_half_b : subroutine {
      : if (!have_won) {
         : print "{custom_unknown_verb_error}" ;
         : if (!bonus_obfuscated_note_yet) {
            : print "{one_time}well, not exactly. You've discovered half of the command for a bonus point. But the first time through, {qt} won't be hinting them, so as not to distract you from the main quest. If you continue after the win-and-restart, you'll get a nudge, since it's assumed you know the main way through." ;
            : set_true "bonus_obfuscated_note_yet" ;
         }
         : done ;
      }
      : set_true "half_bonus" ;
      : decrement "tempint" ;
      : gosub "say_half" ;
      : if (!bonus_half_note) {
         : print "{one_time}since you've been through once, I will assume you know all the core points and are hunting for bonus points. This wasn't available the first time through, to avoid distracting you from the main game." ;
         : set_true "bonus_half_note" ;
      }
      : set_false "half_bonus" ;
      : done ;
   }

   check_diagnostics : subroutine {
      : match "i _" {
         : if (tutorial_0_in_tutorial && !tutorial_3_x_me) {
            : print "We'll want to take inventory eventually in this tutorial, but there are even more basic things first." ;
            : done ;
         }
         : mask {
            : if (tutorial_3_x_me && !tutorial_4_inventory) {
               : set_true "tutorial_4_inventory" ;
               : increment "tutorial_score" ;
            }
         }
         : if (carried() == 0) {
            : print "" ;
         }
      }

      : match "_ map" {
         : if (!map_first_warn) {
            : set_true "map_first_warn" ;
            : print "{one_time}you can't do anything with the map other than look at it, so just {vd_map} is adequate." ;
         }
         : gosub "map_stub" ;
      }

      : match "map _" {
         : gosub "map_stub" ;
      }

      : match "score _" {
         : print {( "You've currently scored {score} of {max_score} total core points." + (think_available ? "You have also figured {number_as_word} point-scoring command" + ( commands_figured > 1 ? "s" : "" ) + " before you had the necessary support. Type {vd_think} for details." : "" ) )};
         : print "You have scored {bonus_score} of {max_bonus_score} bonus points." ;
         : if (tutorial_0_in_tutorial) {
            : print "Also, you've gotten through {tutorial_score} of the {tutorial_score} tutorial steps." ;
         }
         : gosub "note_score_upper_right" ;
      }

      : match "think _" {
         : if (tutorial_0_in_tutorial && !tutorial_4_inventory) {
            : print "{vd_think} is part of the tutorial, but it will occur later on." ;
            : done ;
         }
         : if (score == 0) {
            : print "WHAT YOU KNOW SO FAR:" ;
            : print "* you started here in the Demo Meadow" ;
            : print "* you said Fie Moan My Phone, which seemed unnatural" ;
            : print "* you were given the trudge-now'll-nudge trowel at the start" ;
            : print "* you were told of the ancient Kind Gritty Grind City, where hard work and deep thought were rewarded" ;
            : if (xme_yet) {
               : print "* you have a {i_widget}" ;
            }
            : print "Now, how do these clues add up to you getting your first point?" ;
            : if (!tutorial_5_think) {
               : increment "tutorial_score" ;
               : set_true "tutorial_5_think" ;
            }
            : done ;
         }
         : if (commands_figured > 0) {
            : print {( "Here " + (commands_figured > 1 ? "are {number_as_word} things that seemed like they" : "is something that seemed like it") + " should work, but you didn't have the resources yet:" )} ;
         }
         : if (think_leery_owner) {
            : print "You called for the {tht_leery_owner} in the tool stall but didn't have anything to trade." ;
            : set_true "skip_tutorial_cue" ;
         }
         : if (think_bake_tons) {
            : print "You tried to {tht_bake_tons} {here_streaky_cove} but the buns weren't ready to grow yet." ;
         }
         : if (think_chop_drain) {
            : print "You tried to put the chain into a chop drain when one wasn't nearby." ;
         }
         : if (think_sold_guide) {
            : print "You tried to buy a sold guide {here_gnawing_awning} but had no collateral." ;
         }
         : if (think_written_specs) {
            : print "You tried to help prepare {tht_written_specs} without any documents that might help {here_jeerin_region}." ;
         }
         : if (think_great_book) {
            : print "You tried to check out the {tht_great_book} without any ID or voucher {here_foldin_gate}." ;
         }
         : if (think_grow_dupes) {
            : print "You tried to grow dupes {here_collation_location} but didn't have any additional materials to help." ;
         }
         : gosub "diagnostic_think_core_half" ;
         : gosub "diagnostic_think_bonus_half" ;
         : if (print_core_nag_after) {
            : print "{one_time}You have figured each half of a point-scoring command, but you haven't typed them both together. That still might not work if you haven't prepared by solving other puzzles, but if that's the case, {vd_think} will remind you with context until it does." ;
            : set_true "solved_both_parts_core_nag" ;
            : set_false "print_core_nag_after" ;
         }
         : if (print_bonus_nag_after) {
            : print "{one_time}You have figured each half of a bonus point scoring command, but you haven't typed them both together. {vd_think} will remind you of this try until it works, though game state changes may make, or have made, this undoable until you replay." ;
            : set_true "solved_both_parts_bonus_nag" ;
            : set_false "print_bonus_nag_after" ;
         }
         : if (!think_any && !think_core_yet && !think_bonus_yet) {
            : print "You haven't had any good ideas you weren't able to execute yet." ;
            : done ;
         }
      }
   }

   check_meta : subroutine {
      : match "about _" {
         : print "{this_game} was written for {l_talp_2026}, another annual edition of {l_talp}." ;
         : print "It is a wordplay game in the spirit of {l_qt}, my {l_talp_2025} entry, and it reuses a lot of the code. However, this year I'm trying to get in at least somewhat with the theme of archaeology, even if my knowledge of that field is rudimentary. Well, it does have a hidden city near the end, and you dig and explore." ;
         : print "{this_game} uses a stripped-down parser for standard commands, but it requires you to discover two-word commands to win." ;
         : if (score == 0) {
            : print "Figuring the mechanic isn't meant to be too tricky, but I don't want to spoil it unsolicited. {vm_think} and, more explicitly, {vm_hint} can clue you into what is going on." ;
         }
         : if (!tutorial_1_about) {
            : increment "tutorial_score" ;
            : set_true "tutorial_1_about" ;
         }
         : done ;
      }

      : match "credits _;credit _;creds _;cred _" {
         : print "All thanks are in alphabetical order." ;
         : print "Thanks to {l_tester_wc}, {l_tester_gg}, and {l_tester_ag} for testing. Linking to their itch.io profiles is the very least I can do!" ;
         : print "GENERAL THANKS:" ;
         : print "Chris Ainsley for Adventuron and administering TALP, Garry Francis for continuing to administer TALP, and all the TALP and Adventuron authors who came before me who set a high standard I've hopefully come close to." ;
         : print "The Adventuron discord (specific technical questions) and Intfiction.org board (general support,) which overlap with the people listed above." ;
         : done ;
      }

      : match "diag _;diags _;diagnostic _;diagnostics _" {
         : print "{vd_hint} gives hints based on your location and current accomplishments." ;
         : print "{vd_i_three} takes inventory. In other words, you can see what you are carrying. While most clues in {this_game} should be in the room and description, the inventory and examining the items in it may provide additional clues." ;
         : print "{vd_score} is the most popular diagnostic command. It tells you your core score, which you can also see in the upper right. It also tracks bonus points." ;
         : print "{vd_think} describes your partial successes and, before you get your first point, clues of odd things that may help you realize what you need to do to get that first point." ;
         : done ;
      }

      : match "help _" {
         : print {( "<HELP<#f80>> is a bit ambiguous. It's not clear how much help you may want. {vd_think} will track what you know, while {vd_hint} will help with an immediate specific puzzle, if one is available. " + (xme_yet ? "The widget will give a number if there's something to do in the area." : "{xme} will reveal an item on your person which will tell if you have anything left in the area.") )} ;
         : done ;
      }

      : match "hint _;hints _" {
         : gosub "hint_function" ;
         : done ;
      }

      : match "history _;version _;versions _" {
         : print "So far there has been only one release, for {l_talp_2026}." ;
         : done ;
      }

      : match "meta _" {
         : print "{vm_about} gives general information." ;
         : print "{vm_credits} credits people and entities who helped make {this_game} or fix various flaws." ;
         : print "{vm_diag} lists diagnostic verbs." ;
         : if (have_won || graphics_unwon_warn) {
            : print "{vm_gr} gives graphical notes for the current location." ;
         }
         : print "{vm_history} lists version history and major changes that necessitated each version." ;
         : print "{vm_meta}, this command, lists meta-commands, or commands that list other commands." ;
         : print "{vm_options} lists options." ;
         : print "{vm_verbs} describes verbs the parser uses." ;
         : print "Native commands unique to Adventuron include {vs_tss}, which start and stop a transcript, which help the programmer find bugs, technical or narrative. {vs_quit} and {vs_restart} are common across text adventure systems. <SAVE<#f80>> and <RESTORE<#f80>> work as well." ;
         : done ;
      }

      : match "options _" {
         : set_boolean var="opt_on_off" {( opt_color_coding )} ;
         : print "{optt_ch}: turns color coded hinting on or off. Currently it is {txt_on_off}." ;
         : set_boolean var="opt_on_off" {( opt_score_notify )} ;
         : print "{optt_notify}: turns score notification on or off. Currently it is {txt_on_off}." ;
         : if (!can_reveal_block_opt) {
            : print "There's one more option, but knowing it could spoil the game mechanic before you want to. So you'll need to type {vm_options} again to see it." ;
         } : else {
            : set_boolean var="opt_on_off" {( opt_block_done )} ;
            : print {( "{optt_block}: blocks off places with nothing left to do. Currently it is set to " + (opt_block_done ? optt_block_on : optt_block_off) + "." )} ;
         }
         : if (!on_off_note) {
            : print "{one_time}: while ON and OFF would be more logical after an option, Adventuron reserves ON for internal use. Also, {this_game} does not toggle an option if you type it alone, so {yn} is needed." ;
            : set_true "on_off_note" ;
         }
         : set_true "option_asked_once" ;
         : done ;
      }

      : match "verbs _;verb _" {
         : print "{this_game} uses a reduced parser, though all point-scoring commands require you to guess a phrase." ;
         : print "Many commands are noun-based, so you don't have to guess the verb for relatively common actions, e.g. PUSH THING and USE THING are the same." ;
         : print "You can use the basic directions {dir_n}, {dir_s}, {dir_e}, {dir_w}, {dir_u} and {dir_d}, abbreviated to a single letter e,g, <N<#f80>>/<S<#f80>>/<E<#f80>>/<W<#f80>>/<U<#f80>>/<D<#f80>>." ;
         : print "You will also want to use the senses, including {v_listen}, {v_smell} and {v_feel}." ;
         : print "You can <X<#f80>> something to <EXAMINE<#f80>> it. Sometimes this is necessary to uncover something else." ;
         : print "<L<#f80>> (for look) refreshes the screen." ;
         : print "For the most part, <TAKE<#f80>> and <DROP<#f80>> aren't used, as the game automatically picks up what you need and destroys it when done. But they may be part of a puzzle." ;
         : print "Meta-verbs (actions or requests outside of the game world) are listed in {vm_meta}, {vm_diag}(NOSTIC), and {vm_options}. Intuitive abbreviations for these often work but aren't fully listed." ;
         : if (tutorial_1_about && !tutorial_2_verbs) {
            : increment "tutorial_score" ;
            : set_true "tutorial_2_verbs" ;
         }
         : done ;
      }

   }

   check_options : subroutine {
      : match "ch _" {
         : gosub "options_colorhint" ;
      }
      : match "notify _" {
         : gosub "options_notify" ;
      }
      : match "all way" {
         : print {( "Blocking done areas is " + (!opt_block_done ? "already" : "now" ) + " off." )} ;
         : set_false "opt_block_done" ;
         : done ;
      }
      : match "wall eh" {
         : print {( "Blocking done areas is " + (opt_block_done ? "already" : "now" ) + " on." )} ;
         : set_true "opt_block_done" ;
         : done ;
      }
   }

   feel_real : subroutine {
      : match "feel _" {
         : print {( bonus_point_real_phase ? "You already dealt with your feelings." : feel_yet ? "You still feel those rays. Well, it could be a ray. Must be several ways to deal with them." : "Maybe it's just you, but you feel rays on your back. You're not sure what sort of rays, but you definitely feel rays." )} ;
         : set_true "feel_yet" ;
         : done ;
      }
      : if (!feel_yet) {
         : return ;
      }
      : match "feel rays" {
         : print {( bonus_point_real_phase ? "The rays still push you on, in their own way, whether or not they're imaginary." : "You still feel the rays on your back. What to think of them? Not that you have to. It might just be a pick me up." )} ;
         : done ;
      }
      : match "real fey;real phase;real faze" {
         : if (bonus_point_real_phase) {
            : print "You already contemplated how things were or weren't getting real." ;
            : done ;
         }
         : print "The rays you feel may or may not be imaginary. They may be fey, or a phase, or they may faze a bit. But the thing is -- that you even imagine feeling them is an excuse to get going so they don't zap ordrain you or whatever. Sometimes we have smart reasons to do silly things or do nothing, but here it may be a case of the reverse. Which is smart in its own way." ;
         : set_true "bonus_point_real_phase" ;
         : collection_modify { collection = "tried_combo_bonus" index -> (1) content -> ("true") } ;
         : gosub "add_bonus" ;
         : done ;
      }
      : match "real _;_ phase;_ fey;_ faze" {
         : set_integer var="tempint" "1" ;
         : set_false "first_half" ;
         : match "real _" {
            : set_true "first_half" ;
         }
         : gosub "say_half_b" ;
         : done ;
      }
   }

   graphic_stuff : subroutine {
      : set_stat target="current_location" stat="stat_graphic_notes" value="1" ;
      : if (current_location() == "ailer_lair") {
            : print "My idea for the babblers and blabbers came from the Life of Brian, with the Judean People's Front and People's Front of Judea. Other than that, I realized it would get complicated once I had put three puzzles into it, while not putting any into the Jeerin' Region." ;
      } : else_if (current_location() == "app_mall") {
         : print "Since this is a very retro-friendly competition and the theme is archaeology, I thought I'd put in some artifacts I enjoyed. In this case, an Apple IIj, Commodore 512 (couldn't fit the number in,) and TRS999." ;
      } : else_if (current_location() == "backin_cabin") {
         : print "My minimal Google Image research to draw things in Adventuron can sometimes be quite fun. Here I looked at all sorts of log cabins, and I looked up different RGBs for different shades of brown. I've done cabins and hills before but never cabins in hills. I slowly but surely try new things in each Adventuron game." ;
      } : else_if (current_location() == "cache_shack") {
         : print "I originally intended this to be the shack you now see in the chattin 'em plain. I tried to simulate shelves but there was a worry they might give the optical illusion of bulging out instead of going away, which one tester pointed out. I can't say I have a full solution to that." ;
      } : else_if (current_location() == "chattin_em_plain") {
         : print "This was originally meant for the newbies' boonies, but for whatever reason, I was watching the introduction of the movie Hoosiers for one more idea to stuff in them. It reminded me of car trips from towns near West Lafayette, Indiana, where I was born. There were many details I wanted to put into them. But I didn't want to waste the original picture, so I put it here. The result is, this isn't as much of a flat plain as is perfectly optimal, but I hope it's more interesting." ;
      } : else_if (current_location() == "collation_location") {
         : print "The smiling and frowning gingerbreads weren't hard to do, and the way overlays work in Adventuron, you can just define it in several places. So this was fun. Though I did flip the smiling/frowning gingerbreads in my first build to testers. Oops." ;
      } : else_if (current_location() == "demo_meadow") {
         : print "Why yes I cut and pasted the butterflies and filled different colors in each of them and flipped some horizontally. I had to make sure they had space for both the stool and the towers. A lot of my Adventuron graphics are like that. I make heavy use of rotations and mirrorings. Often I need to use a hex editor to change the palette, as I just forget MSPaint has a palette editor! Maybe I could/should move up to GIMP for palette switches, but with MSPaint's sparer interface, I enjoy the lack of distractions. And, why yes, I do indeed use the Windows 95/XP MSPaint." ;
      } : else_if (current_location() == "foldin_gate") {
         : print "It was tough to make the gate folding! I figured out the final room early on, and I also wanted to make an angled brick wall, which wasn't bad with Python's PIL/pillow. I've used it before. But sometimes it doesn't work well with lower resolution images, and you have to blow it up before shrinking it." ;
      } : else_if (current_location() == "gnawing_awning") {
         : print "My first few drawings were of a hexagonal gazebo, which was cute, and I may use it later, but it didn't work logically." ;
      } : else_if (current_location() == "jeerin_region") {
         : print "I don't know if I've done an east/west to north/south path before. I've done crossroads. But I like the slightly different perspective here. The shirts were fun to make, too. I wanted to do something with several different shirts making a message, but I couldn't decide what. \"U R AN\" is left ambiguous on purpose, like someone who says \"You know what your problem is?\" and you don't want to hear it but you say \"What?\" and they try for ominous silence and eye-rolling. Also, the IQ we can't see is 170." ;
      } : else_if (current_location() == "moldin_dolmen") {
         : print "This was a bit of a struggle as dolmens generally have height. I wanted a ring of stones but that seemed to make the rest of the area bare. I also originally had the fax coming out from a wall, but when I moved to a wide-open space, I had to change that. The paper looks white but it's actually xf0f0f0 because I needed most of the overlay graphic to be white for transparency. Well, I could've changed the transparency color, but that'd be more difficult." ;
      } : else_if (current_location() == "newbies_boonies") {
         : print "The chattin 'em plain has this place's original graphic. I pulled three things from the movie Hoosiers: the stoplights on a wire, the grain silos, and the old-timey gas station. Of course there's bush, since there's a bush pest. I'm pleased with how this went. Cutting and pasting the silos over the road was one high point technically, and I enjoyed placing the stoplights just right once I had the shape." ;
      } : else_if (current_location() == "oopster_stupor") {
         : print "I actually just had a door with part of a maze planned here, but I'd wondered for a while, it's not a stupor with the haze gone. What could it be? So I got the idea for birds, which are tough at this low resolution, and I wanted a silly intimidating message. Brevity is necessary with this image size." ;
      } : else_if (current_location() == "outer_tower") {
         : print "I didn't have time to have the lock do a full dance, but I enjoyed making the tower locked then unlocked. I thought of the grass-is-greener joke mainly because I like to differentiate between sub-areas of an image, and shades of green are the easiest way to do it. Green and brown work too." ; 
      } : else_if (current_location() == "rocky_caves") {
         : print "The stink lines were fun to make, if trivial. It's not bad to make caves in MSPaint. You just draw a jagged line slightly above the bottom, then draw a few dark holes, then draw lines and cracks in the walls." ;
      } : else_if (current_location() == "sappage_passage") {
         : print "I fit this room in last-minute and wanted to give some sort of mazy perspective, so I wanted to go with diagonal corridors. I also transcribed the flying fist from a vector image of a fist. I made the thumb brown while placing it." ;
      } : else_if (current_location() == "streaky_cove") {
         : print "This was a lot of fun to make. The stove was a transparent graphic, copied from Google searches of old wood stoves. The tree with or without the keys " ;
      } : else_if (current_location() == "taller_altar") {
         : print "This was an interesting one. I wanted to do a small fake-out with the pool clan, as if your mind wandered to people wearing swimsuits, shame on you! This is a family game. The weight, of course, is from my days enjoying Road Runner cartoons. Though I did feel bad Wile E. Coyote never won once. He deserved it, for all his hard work." ;
      } : else_if (current_location() == "tenser_center") {
         : print "This is one of those liminal locations where I felt I didn't need too much, since it links through to others. I wanted a sign behind the sinister mouth." ;
      } : else_if (current_location() == "tool_stall") {
         : print "The tools were fun to draw. Near release I realized I'd never put the owner into the graphic. Then they were too big to fit behind the counter, so I slipped in the longer tools on the left. Which took a while, but it made the place more cheery. I'm also pleased with the brevity of the t-shirt messages. I hope I can find more for my next game." ;
      } : else_if (current_location() == "yankin_canyon") {
      } : else {
         : print "I don't have any author narrative for this location, but I should." ;
      }
   }

   map_stub : subroutine {
      : match "map _" {
         : if (!bonus_point_map_all) {
            : print "You haven't gained access to the internal game map command yet. It's not critical to win, though." ;
            : done ;
         }
         : if (is_at "sappage_passage") {
            : print "You're in the maze now, so you don't need a game map." ;
            : done ;
         }
         : set_true "drawing_map" ;
         : clear_screen ;
         : update_graphic "m_0_blank" ;
         : press_any_key ;
         : set_false "drawing_map" ;
         : if (!map_note) {
            : print "{one_time}there are no one-way paths. If you have activated the option to block completed rooms, they will be in <GREY<#888>>." ;
            : set_true "map_note" ;
         }
         : redescribe ;
         : done ;
      }
   }

   option_err_stub : subroutine {
      : match "_ -" {
         : print "Toggling {tempopt} without an argument ({yn}) is not supported." ;
         : done ;
      }
      : print "Toggling {tempopt} requires one of {yn} as an argument." ;
      : done ;
   }

   options_colorhint : subroutine {
      : set_boolean var="opt_on_off" {( opt_color_coding )} ;
      : match "ch yes" {
         : print "Now {optt_ch} is activated." ;
         : set_true "opt_color_coding" ;
         : done ;
      }
      : match "ch no" {
         : print "Now {optt_ch} is deactivated." ;
         : set_false "opt_color_coding" ;
         : done ;
      }
      : set_string var="tempopt" text="{optt_ch}" ;
      : gosub "option_err_stub" ;
   }

   options_notify : subroutine {
      : set_boolean var="opt_on_off" {( opt_score_notify )} ;
      : match "notify yes" {
         : print "Score notify is now on.";
         : set_true "opt_score_notify";
         : done ;
      }
      : match "notify no" {
         : print "Score notify is now off.";
         : set_false "opt_score_notify";
         : done ;
      }
      : set_string var="tempopt" text="{optt_notify}" ;
      : gosub "option_err_stub" ;
   }

   #########################################room specific

   dolmen_key_form: subroutine {
      : if (key_duplicated) {
         : return ;
      }
      : if (point_formed_wax && key_found && point_chop_drain) {
         : print "Now you have the old key, some stronger metal, and wax to make impressions, you could almost make a key. The moldin' dolmen might be able to help. You offer the three items to it ... and out comes a shiny new key! A key so \"Seek, oh!\"\nYou look around, half expecting to be awarded a point for this. An unseen voice behind the dolmen whispers that the key will unlock an area that will get you many more points, and gosh darn it, that's even better.\nYou whisper \"Um, con, come ON!\" Finding the key took several commands! But the voice has a point about, um, not getting a point." ;
         : destroy "trove_key" ;
         : destroy "wax" ;
         : destroy "slab" ;
         : pocket "seek_key" ;
         : set_true "key_duplicated" ;
      } : else_if (key_found) {
         : print {( "The rusty key seems to pull you towards the dolmen, but when you get too close, the dolmen pushes you away " + (point_chop_drain || point_formed_wax ? "slightly. You might need something else." : "pretty forcefully. You probably need more for it to help you.") )} ;
      }
   }

   awning_hint_check : subroutine {
      : if (ambiguous_awning_hints) {
         : print "{one_time}there's more than one thing you can focus on here and now, so I've picked the puzzle(s) in arbitrary order." ;
         : set_true "hint_awning_note" ;
         : return ;
      }
   }

   #########################################hint and tutorial

   diagnostic_think_core_half : subroutine {
      : set_integer var="counter" "0" ;
      : set_false "think_core_yet" ;
      : while (counter < max_score) {
         : if ((collection_get{ collection -> ("tried_combo_core") index -> ( counter )} == "false")) {
            : if (part_core_score > 0) {
               : if (!think_core_yet) {
                  : print "{think_here_also} is a summary of correct bonus command half-guesses:" ;
                  : set_true "think_core_yet" ;
                  : set_true "think_text_yet" ;
               }
               : print {( (part_core_score != 2 ? (collection_get{ collection -> ("think_first_core") index -> (counter) }) : "{noguess_c_1}") + " " + (part_core_score >= 2 ? (collection_get{ collection -> ("think_second_core") index -> (counter) }) : "{noguess}") + " " + (collection_get{ collection -> ("situations_core") index -> (counter) }) )} ;
               : if (!solved_both_parts_core_nag && part_core_score == 3) {
                  : set_true "print_core_nag_after" ;
               }
            }
         }
         : increment "counter" ;
      }
   }

   diagnostic_think_bonus_half : subroutine {
      : set_integer var="counter" "0" ;
      : set_false "think_bonus_yet" ;
      : set_true "in_bonus_half" ;
      : while (counter < max_bonus_score) {
         : if ((collection_get{ collection -> ("bonus_status") index -> ( counter )} == "0")) {
            : if (part_bonus_score > 0) {
               : if (!think_bonus_yet) {
                  : print "{think_here_also} is a summary of correct bonus command half-guesses:" ;
                  : set_true "think_text_yet" ;
                  : set_true "think_bonus_yet" ;
               }
               : print {( (part_bonus_score != 2 ? (collection_get{ collection -> ("think_first_bonus") index -> (counter) }) : "{noguess}") + " " + (part_bonus_score >= 2 ? (collection_get{ collection -> ("think_second_bonus") index -> (counter) }) : "{noguess}") + " " + (collection_get{ collection -> ("situations_bonus") index -> (counter) }) )} ;
               : if (!solved_both_parts_bonus_nag && part_bonus_score == 3) {
                  : set_true "print_bonus_nag_after" ;
               }
            }
         }
         : increment "counter" ;
      }
      : set_false "in_bonus_half" ;
   }

   #########################################hint and widget and tutorial

   hint_function : subroutine {
      : set_true "skip_tutorial_cue" ;
      : if (tutorial_0_in_tutorial && !tutorial_5_think) {
         : print "There are several things you can do here. Get to step 4 of the tutorial, then ask for hints again." ;
         : set_true "hint_zero_warn" ;
         : return ;
      }
      : if (score == 0 && !xme_yet) {
         : print "Before I give hints, I'd like you to try {xme}, a standard action to start text adventures. It will give a clue." ;
         : return ;
      }
      : if (!hinted_yet) {
         : print "{one_time}{this_game} makes a reasonable guess of the next puzzle you can solve in the current room. If nothing turns up, you may wish to go elsewhere." ;
         : set_true "hinted_yet" ;
      }
      : gosub "awning_hint_check" ;
      : gosub "widget_adjust" ;
      : if (score > 5) {
         : if (widget_num == -1) {
            : print "There is nothing to do here." ;
            : return ;
         } : else_if (widget_num == 1) {
            : print "There will be something to do later." ;
            : if (!hints_clarified_yet) {
               : print "{one_time}while {vd_hint} won't tell you where to go in this case, there should always be another room with hints where you can work at things and check back later." ;
               : set_true "hints_clarified_yet" ;
            }
            : return ;
         } : else_if (widget_num == 0) {
            : print "You are done here." ;
            : return ;
         }
      }
      : if (is_at "ailer_lair") {
         : if (!point_best_notes) {
            : cycle key = "hint_23_best_notes" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_nest_boats} are what you need to look at." ;
               : print "The babblers and blabbers want to give you a gift before you leave. One that isn't lame. Maybe there's something on the {puz_point_nest_boats}." ;
               : print "<BEST NOTES<#f0f>>." ;
            }
            : return ;
         }
         : if (has_visited "foldin_gate" && !point_help_card) {
            : cycle key = "hint_27_help_card" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_kelp_hard} has just gotten washed up." ;
               : print "It may get stuff lost in it." ;
               : print "A <HELP CARD<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "app_mall") {
         : print "Nothing critical is needed here, but there are two bonus points." ;
         : return ;
      } : else_if (is_at "backin_cabin") {
         : if (!point_pull_file) {
            : cycle key = "hint_07_pull_file" predictable_order = "true" skip_interval = "0" {
               : print "The full pile is in your way. It has something you might want, but what?" ;
               : print "You can reduce the clutter a bit. It helps to focus on something you need." ;
               : print "You could <PULL FILE<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "cache_shack") {
         : if (!buns_taken) {
            : print "You just need to <TAKE BUNS<#f0f>> here." ;
            : return ;
         }
      } : else_if (is_at "chattin_em_plain") {
         : if (!point_platinum_chain) {
            : cycle key = "hint_12_platinum_chain" predictable_order = "true" skip_interval = "0" {
               : print "Half the chatter says there's an item you don't want to pick up, and half says you do." ;
               : print "But what could the item be?" ;
               : print "It is a <PLATINUM CHAIN<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "collation_location") {
         : if (!point_grow_dupes) {
            : cycle key = "hint_08_grow_dupes" predictable_order = "true" skip_interval = "0" {
               : print "Now you have the buns, you have material that can help the dough groups repopulate." ;
               : print "In the collation location, you make copies of things." ;
               : print "You can <GROW DUPES<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "demo_meadow") {
         : if (!point_tool_stall) {
            : cycle key = "hint_02_tool_stall" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_stool_tall} is out of place in a meadow and oddly worded for a reason." ;
               : print "You may notice something about some location names and expressions." ;
               : print "Demo meadow. Fie Moan My Phone, if you examined yourself. The item is a {i_widget}." ;
               : print "Spoonerisms are the mechanic." ;
               : print "Flip the sounds at the start of the words to get a..." ;
               : print "<TOOL STALL<#f0f>>." ;
            }
            : return ;
         }
         : if (!listen_demo_meadow) {
            : print "{v_listen} for what to do next." ;
            : return ;
         }
         : if (!point_rocky_caves) {
            : cycle key = "hint_00_rocky_caves" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_cocky_raves_l} sure find it funny you can't find a way out." ;
               : print "But of course the {puz_point_cocky_raves_l} are hiding something you may be able to figure out." ;
               : print "You will hear <COCKY RAVES<#f0f>> are nearby." ;
            }
            : return ;
         }
         : if (placed_flaming_towers && !point_taming_flowers) {
            : cycle key = "hint_05_taming_flowers" predictable_order = "true" skip_interval = "0" {
               : print "The flaming towers are certainly a menace." ;
               : print "How could you find something nicer that makes them less of a menace?" ;
               : print "Find some <TAMING FLOWERS<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "foldin_gate") {
         : if (!point_great_book) {
            : cycle key = "hint_28_great_book" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_gate_brook} holds wisdom and secrets and all that sort of thing." ;
               : print "You have an item that can help you reserve such a book." ;
               : print "The cold hard hold card." ;
               : print "You need to ask for the <GREAT BOOK<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "gnawing_awning") {
         : if (!point_sail_tide) {
            : cycle key = "hint_19_sail_tide" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_tail_side} is helping adjust wind patterns, or something." ;
               : print "What can it help, to make things more comfortable for people to pass by?" ;
               : print "You need to start the <SAIL TIDE<#f0f>>." ;
            }
            : return ;
         } : else_if (!point_sold_guide) {
            : cycle key = "hint_20_sold_guide" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_gold_side} hides something valuable." ;
               : print "Something you should have the money to pay for." ;
               : print "You need to claim a <SOLD GUIDE<#f0f>>. You'll buy it automatically." ;
            }
            : return ;
         } : else_if (!point_sick_bride) {
            : cycle key = "hint_21_sick_bride" predictable_order = "true" skip_interval = "0" {
               : print "Something or someone is bricked up behind the {puz_point_brick_side}." ;
               : print "Who would want to run?" ;
               : print "You will find a <SICK BRIDE<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "jeerin_region") {
         : if (!point_written_specs) {
            : cycle key = "hint_24_written_specs" predictable_order = "true" skip_interval = "0" {
               : print "The best notes help here." ;
               : print "The {puz_point_spittin_wrecks} know a lot, but giving general ordinary help is beneath them." ;
               : print "Ask for <WRITTEN SPECS<#f0f>>. You'll use the best notes automatically." ;
            }
            : return ;
         }
      } : else_if (is_at "moldin_dolmen") {
         : if (!point_formed_wax) {
            : cycle key = "hint_15_formed_wax" predictable_order = "true" skip_interval = "0" {
               : print "You keep seeing a {puz_point_warmed_fax} appear from the wall, then vanish." ;
               : print "Maybe you could catch one and change it into something else quickly." ;
               : print "You need to grab or create some <FORMED WAX<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "newbies_boonies") {
         : if (!point_push_best) {
            : cycle key = "hint_06_newbies_boonies" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_bush_pest} wants a fight, but it's surprisingly good at getting in your way." ;
               : print "What sort of move could you pull on it to get by?" ;
               : print "You could <PUSH BEST<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "oopster_stupor") {
         : if (!point_hard_maze) {
            : cycle key = "hint_17_hard_maze" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_marred_haze} blocks you. It can become something slightly more solvable." ;
               : print "Not fun to solve, mind, but solvable." ;
               : print "You could discover a <HARD MAZE<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "outer_tower") {
         : if (!point_lodging_doc) {
            : cycle key = "hint_14_lodging_dock" predictable_order = "true" skip_interval = "0" {
               : print "If you've examined the keyhole, you may notice it's not any old lock." ;
               : print "It's a {puz_point_dodging_lock_l}." ;
               : print "Thus, you need to request a <LODGING DOCK<#f0f>> or say <LODGING DOC<#f0f>>. It works either way." ;
            }
            : return ;
         } : else_if (!point_power_torch) {
            : cycle key = "hint_22_power_torch" predictable_order = "true" skip_interval = "0" {
               : print "Hmm, you've found where the porch is. What does that make it?" ;
               : print "A {puz_point_tower_porch}." ;
               : print "You need to look for a <POWER TORCH<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "rocky_caves") {
         : if (!smell_rocky_caves) {
            : cycle key = "hint_rocky_caves_smell" predictable_order = "true" skip_interval = "0" {
               : print "Time to use a different sense. It's damp and dark here. You can't really see and don't want to taste, but what other sense can you use?" ;
               : print "You can SMELL." ;
            }
            : return ;
         }
         : if (!point_steel_wrench) {
            : cycle key = "hint_01_steel_wrench" predictable_order = "true" skip_interval = "0" {
               : print "That {puz_point_real_stench} may prevent less hardy adventurers from finding something, but maybe if you looked for something specific, you'd find it." ;
               : print {( point_tool_stall ? "The tool stall you unveiled needs an item." : "The {puz_point_stool_tall} back in the meadow leads somewhere that could give you a clue." )} ;
               : print "Hidden behind the {puz_point_real_stench} is a <STEEL WRENCH<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "sappage_passage") {
         : cycle key = "hint_26_fumbling_wrist" predictable_order = "true" skip_interval = "0" {
            : print "The {puz_point_rumbling_fist} is a tough customer!" ;
            : print "The {puz_point_rumbling_fist} seems quite stable and sturdy, but is it that way on its own? Or with something?" ;
            : print "In any case, linking the {puz_point_rumbling_fist} to something less solid might mess it up." ;
            : print "A <FUMBLING WRIST<#f0f>>." ;
         }
         : return ;
      } : else_if (is_at "streaky_cove") {
         : if (!point_creaky_stove) {
            : cycle key = "hint_09_creaky_stove" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_streaky_cove}'s right side is a plain grey, almost too grey." ;
               : print "Something useful is hidden in the grey. A helpful appliance." ;
               : print "It is a <CREAKY STOVE<#f0f>>." ;
            }
            : return ;
         } : else_if (!point_bake_tons) {
            : cycle key = "hint_10_bake_tons" predictable_order = "true" skip_interval = "0" {
               : print "So you have a stove. Do you have anything you could cook or heat up?" ;
               : print "The buns. If you take inventory, you notice something." ;
               : print "You had to <TAKE BUNS<#f0f>>." ;
               : print "You thus need to <BAKE TONS<#f0f>>." ;
            }
            : return ;
         } : else_if (!point_key_trove) {
            : cycle key = "hint_11_key_trove" predictable_order = "true" skip_interval = "0" {
               : print "Something is hidden behind the {puz_point_tree_cove}." ;
               : print "Perhaps something of value." ;
               : print "There is a <KEY TROVE<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "taller_altar") {
         : if (!point_penny_mounds) {
            : cycle key = "hint_18_penny_mounds" predictable_order = "true" skip_interval = "0" {
               : print "There are {puz_point_many_pounds}, of two types, around the taller altar. Animal and big cartoon weights." ;
               : print "Neither seem terribly spiritual. They don't belong here. Perhaps they can be replaced?" ;
               : print "What you get isn't terribly spiritual, but it is less damaging to the soul or body, and it's enough for what you need." ;
               : print "<PENNY MOUNDS<#f0f>>." ;
            }
         } : else_if (!point_cool_plan) {
            : cycle key = "hint_25_cool_plan" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_pool_clan} has something to offer you." ;
               : print "Nothing concrete, just some help." ;
               : print "They could construct a <COOL PLAN<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "tenser_center") {
         : if (!point_hard_maze) {
            : cycle key = "hint_16_minister_south" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_sinister_mouth} may not be fully evil, but you may need something powerful to dispel it." ;
               : print "Perhaps you can call on someone to come a certain direction." ;
               : print "You could call out <MINISTER SOUTH<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "tool_stall") {
         : if (!point_steel_wrench && !tutorial_0_in_tutorial) {
            : print "You need to do something elsewhere first to make progress here." ;
            : return ;
         }
         : if (!point_leery_owner) {
            : cycle key = "hint_03_leery_owner" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_eerie_loner} isn't the person you need to speak to, but they can summon the person who is." ;
               : print "The {puz_point_eerie_loner} isn't big on positivity, either." ;
               : print "Who is the manager? Something that rhymes with loner, someone in charge." ;
               : print "You need to talk to the OWNER of this establishment." ;
               : print "But the {puz_point_eerie_loner} is suspicious of you." ;
               : print "LEERY, in other words." ;
               : print "Ask for the {tht_leery_owner}." ;
            }
            : return ;
         }
         : if (!point_tight_rules) {
            : cycle key = "hint_04_tight_rules" predictable_order = "true" skip_interval = "0" {
               : print "The owner has the {puz_point_right_tools}, but they're not exactly stuff you can give away to anyone on the street." ;
               : print "You need advice and guidance." ;
               : print "Pretty clear advice and guidance." ;
               : print "Ask for <TIGHT RULES<#f0f>>." ;
            }
            : return ;
         }
      } : else_if (is_at "yankin_canyon") {
         : if (!point_chop_drain) {
            : cycle key = "hint_13_chop_drain" predictable_order = "true" skip_interval = "0" {
               : print "This is a tricky one, meant to identify what is yankin' things down." ;
               : print "Look in your inventory. There's something cursed, something you want to get rid of." ;
               : print "Have you tried to <DROP<#f0f>> it?" ;
               : print "It doesn't work. You need the right thing to destroy it, or its essence." ;
               : print "You need to call the <CHOP DRAIN<#f0f>>." ;
            }
            : return ;
         }
      }
      : cycle key="hint_catchall" predictable_order = "true" skip_interval = "0" max_loops = "1" {
         : print "*** This is a catchall \"I can't do anything right now\" statement. It shouldn't pop up, but if it does, it probably means I missed a case where you can do something here, but you'll have to do other things first. Sorry about this, and please let me know where and how it happened if you can, so I can fix it!" ;
         : print "Another catchall bug. I'll be shortening this announcement in the future so as not to distract you. Sorry about this!" ;

         on_exhausted {
            : print "*** Hint catchall re-notification." ;
         }
      }
      : return ;
   }

   # I hate having this function, but if I don't have it, the dynamic_integer makes Adventuron do bad things. I think it's Adventuron and not me.
   widget_adjust : subroutine {
      : if (is_at "start_zone") {
         : set_integer var="widget_num" {( widget_num_start )} ;
      } : else_if (is_at "middle_zone") {
         : set_integer var="widget_num" {( widget_num_middle )} ;
      } : else_if (is_at "end_zone") {
         : set_integer var="widget_num" {( widget_num_end )} ;
      }
   }

   widget_function : subroutine {
      : gosub "widget_adjust" ;
      : set_integer var="tempint" {( widget_num )} ;
      : set_false "widget_blurry" ;
      : if (point_penny_mounds && !point_sold_guide && awning_sides_done < 2) {
         : print {( "Weird! It's 44 plus a fraction. Like, " + (awning_sides_done == 0 ? "two-thirds" : "one-half") + "." )} ;
         : return ;
      }
      : if (tempint == -1 ) {
         : print "Some weird random negative number. Nothing to do here, period." ;
         : return ;
      }
      : if (tempint < 0) {
         : set_integer var="tempint" {( 0 - tempint )} ;
         : set_true "widget_blurry" ;
      }
      : print "On the widget, you see the number {tempint}." ;
      : if (widget_blurry) {
         : print "The number seems a bit blurry." ;
      } : else_if (tempint == 0) {
         : print "Probably means nothing left to do here." ;
      } : else_if (tempint == 1) {
         : print "Maybe there's nothing constructive to do right now." ;
      }
      : if (!widget_nudge && tempint > 1) {
         : print "Hmm. Just a number, as you might expect from the description. No detailed instructions. Perhaps that's because it was meant to give simple information with no crazy formulas." ;
         : set_true "widget_nudge" ;
      }
      : return ;
   }

   tutorial_choice : subroutine {
      : if (have_won) {
         : return ;
      }
      : ask_bool {
         question   = {this_game} has a tutorial mode for the first few puzzles. If you wish to use it, you need to request it before the game starts. Would you like to use it?
         yes_answer = Yes, I'd like to use the tutorial. (<RECOMMENDED<#0f0>> during the competition)
         no_answer  = No, I'd rather skip the tutorial.
         var        = tutorial_0_in_tutorial
      }
      : if (tutorial_0_in_tutorial) {
         : print "Tutorial mode is now on. You can switch it off, but once you do, you can't switch it on again." ;
      } : else {
         : print "Tutorial mode is disabled. If you wish to try it, you will need to restart it." ;
      }
      : press_any_key ;
      : clear_screen ;
   }

   colorclue_choice : subroutine {
      : if (have_won) {
         : return ;
      }
      : ask_bool {
         question   = {this_game} also puts critical words in <PURPLE<#f0f>> to help you know what to work with. The option can be changed in-game with {optt_ch} (on/off are reserved by Adventuron.)
         yes_answer = Yes, I'd like to use color-coded hinting. (<RECOMMENDED<#0f0>>)
         no_answer  = No, I'd prefer not to use color-coded hinting.
         var        = opt_color_coding
      }
      : print {( "Color-coded hinting is " + (opt_color_coding ? "now available." : "disabled.") + " We're ready to start the game, now!" )} ;
      : press_any_key ;
      : clear_screen ;
   }

   teststubs : subroutine {
      : match "hinttrack both" {
         : set_true "track_digits" ;
         : set_true "track_hints" ;
         : done ;
      }
      : match "hinttrack digits" {
         : set_true "track_digits" ;
         : set_false "track_hints" ;
         : done ;
      }
      : match "hinttrack hints" {
         : set_false "track_digits" ;
         : set_true "track_hints" ;
         : done ;
      }
      : match "hinttrack neither" {
         : set_false "track_digits" ;
         : set_false "track_hints" ;
         : done ;
      }
      : match "hinttrack _" {
         : print "Must HINTTRACK digits, hints, neither, or both." ;
         : done ;
      }
      : if (score == 0) {
         : match "testjump flaming" {
            : set_true "point_rocky_caves" ;
            : set_true "point_steel_wrench" ;
            : set_true "point_tool_stall" ;
            : set_true "point_leery_owner" ;
            : set_true "point_tight_rules" ;
            : set_true "point_taming_flowers" ;

            : set_true "listen_demo_meadow" ;
            : set_true "smell_rocky_caves" ;
            : set_true "placed_flaming_towers" ;
            : goto "demo_meadow" ;
            : set_integer var="score" "6" ;
            : done ;
         }
         : match "testjump outer" {
            : set_true "point_rocky_caves" ;
            : set_true "point_steel_wrench" ;
            : set_true "point_tool_stall" ;
            : set_true "point_leery_owner" ;
            : set_true "point_tight_rules" ;
            : set_true "point_taming_flowers" ;

            : set_true "point_push_best" ;
            : set_true "point_pull_file" ;
            : set_true "point_grow_dupes" ;
            : set_true "point_bake_tons" ;
            : set_true "point_creaky_stove" ;
            : set_true "point_key_trove" ;
            : set_true "point_platinum_chain" ;
            : set_true "point_chop_drain" ;
            : set_true "point_lodging_doc" ;
            : set_true "point_formed_wax" ;

            : set_true "listen_demo_meadow" ;
            : set_true "smell_rocky_caves" ;
            : set_true "placed_flaming_towers" ;

            : set_true "buns_taken" ;
            : set_true "key_found" ;
            : set_true "key_duplicated" ;
            : set_true "key_used" ;
            : set_true "ever_keyhole" ;
            : set_integer var="score" "15" ;

            : goto "outer_tower" ;
            : done ;
         }
      }
      : match "testjump _" {
         : print "Score must be 0 and you must TESTJUMP FLAMING or TESTJUMP OUTER." ;
      }
   }

}

themes {
   my_theme : theme {
      status_bar {
         : header_text ;
         : dynamic_text "my_score" ;
      }
      theme_settings {
         parser_delay  = 0
      }
      colors {
         status_bar_pen   = 15
         status_bar_paper = #222
      }
      system_messages {

         i_cant_do_that = That's a valid command, but not right here and now.
         not_present = You can't see ${entity} here.
         ask_new_game                                   = Would you like to restart {this_game}?
         ask_quit                                       = A voice behind the fourth wall pleads \"I quit? QUIET!\"\nDo you wish to quit {this_game}?
         invalid_choice                                 = {yn_or_12_or_14}
         post_quit = I hope you enjoyed the experience. Pressing {key_enter} will restart {this_game}.
         unknown_verb                                   = {custom_unknown_verb_error}
         you_cant_go_that_direction                     = {exits_err}
         you_see_nothing_special = {nospecial_custom}
         you_see_nothing_special_2 = {nospecial_custom}
      }
   }
}

## Print the objective when the game starts

on_startup {
   : print "{this_game}: a {l_talp_2026} entry with a focus on wordplay.";
   : if (have_won) {
      : print "Thanks for replaying, but this is a reminder to look at the other {l_talp_26} entries, too! The only reason to replay is to figure out bonus points." ;
      : press_any_key ;
      : clear_screen ;
   } : else {
      : gosub "tutorial_choice" ;
      : gosub "colorclue_choice" ;
   }
   : print "You have heard tell of the Kind Gritty Grind City. But you have no clue how to get there." ;
   : print "One day, when you're at the hardware store buying insulation, you happen on a weird item called the trudge-now'll-nudge trowel. You feel compelled to buy it." ;
   : print "It just sits there for a year. Then one day when you consider sending stuff to goodwill, you put it in your back. You take a bike to the flea market. But you never make it. Instead you wind up in a ..." ;
   : pocket "trowel" ;
   : press_any_key ;
}

## Execute this every time a player moves or redescribes a location

on_describe {
}

## Test VERB NOUN that the player types and executes conditional actions

on_command {
   : if (is_carried("best_notes")) {
      : match "_ best;_ notes" {
         : print "You understand them in a general sense, but the important details are well beyond you. You could use some help, here." ;
         : done ;
      }
   }
   : if (is_carried("trove_key")) {
      : match "_ rusty" {
         : print "It's not strong enough to open a lock without breaking off. You'll have to find a way to make a sturdier copy." ;
         : done ;
      }
   }
   : match "gr _" {
      : if (!have_won && !graphics_unwon_warn) {
         : print "{one_time}author's notes on graphics may spoil some puzzles the first time through. If that's okay, or you've won in a previous session, type {vm_graphics} again." ;
         : set_true "graphics_unwon_warn" ;
         : done ;
      }
      : gosub "graphic_stuff" ;
   }
   : match "undo _;rewind _" {
      : print "You need to use ctrl-shift-left to undo a move. Ctrl-shift-right can redo it, if you change your mind." ;
      : done ;
   }
   : if (is_carried "wrench") {
      : match "_ wrench" {
         : print "You're not very handy with tools, so you may need help with how to use it and where. It looks really sturdy, though." ;
      }
   }
   : match "xyzzy _" {
      : print "A low voice booms \"Vexing howls? Hexing?! VOWELS!\"";
      : done ;
   }
   : match "sw _;se _;nw _;ne _" {
      : print "{this_game} doesn't use diagonal directions." ;
      : done ;
   }
   : if (is_carried "hold_card") {
      : match "_ card;_ cold;_ hard;_ hold" {
         : print "*This entitles the bearer to have priority in checking out popular or useful literature*" ;
         : done ;
      }
   }

   : if (is_carried "trove_key") {
      : match "unlock _;open _" {
         : print {( "You don't trust the rusty key to open or unlock anything." + (is_at "outer_tower" ? " But you wouldn't be surprised if a stronger copy opened the tower here." : "") )} ;
         : done ;
      }
   }
   : if (point_sold_guide) {
      : match "_ guide;_ sold" {
         : print {( point_power_torch ? "The sold guide has instructions on how to use the power torch when you're ready, without excessive need for complicated parser commands." : "The sold guide reminds you that you need to find a torch, though it doesn't say where." )} ;
         : done ;
      }
      : match "porch *;_ porch" {
         : if (porch_in_tower) {
            : print "You already found the porch. No need for further searches." ;
            : done ;
         }
         : if (is_at "outer_tower") {
            : print "You didn't look much at the tower as you went past, but with a bit of exploration you notice, yes, indeed, it does have a porch! What could be the use of a porch on a tower? What could it hold?" ;
            : set_true "porch_in_tower" ;
         } : else {
            : print "No porch here. Maybe somewhere else." ;
         }
         : done ;
      }
   }

   : if (is_carried "chain") {
      : match "chop drain" {
         : if (point_chop_drain) {
            : print "The chain should be off-stage. You shouldn't have it again." ;
            : done ;
         }
         : if (!is_at("yankin_canyon")) {
            : print "That would destroy the chain, but you see nothing that resembles, or could hold, a chop drain." ;
            : set_true "think_chop_drain" ;
            : done ;
         }
         : collection_modify { collection = "tried_combo_core" index -> (13) content -> ("true") } ;
         : print "You take a guess that the hole here is a CHOP DRAIN. You fling the platinum chain towards it. Or try to. You struggle to pull it off, then suddenly it flies into the hole. A high-pitched noise ... and then, out pops, back, a small slab of metal. It feels like it could ward off evil. A slender fab fender-slab, if you will." ;
         : pocket "slab" ;
         : destroy "chain" ;
         : set_true "point_chop_drain" ;
         : set_false "think_chop_drain" ;
         : gosub "add_point" ;
         : done ;
      }
      : if (!point_chop_drain) {
         : match "chop _;_ drain" { # again a bug might tell us where to drop the chain even if we haven't found it ??
            : set_integer var="tempint" "13" ;
            : set_false "first_half" ;
            : match "chop _" {
               : set_true "first_half" ;
            }
            : gosub "say_half" ;
            : done ;
         }
      }
   }
   : if (is_carried "buns") {
      : match "x buns" {
         : print {( point_grow_dupes ? "Still very raw and doughy, but livelier and brighter than when you first got them." : "They're rather raw and doughy. When a small bit breaks off from it, it regenerates." )} ;
         : done ;
      }
      : match "_ buns" {
         : print "All you can do, now you decided to TAKE the buns, is examine them. Well, you'll be able to do something else with them, but indirectly, with another phrase." ;
         : done ;
      }
      : if ((!point_creaky_stove || !is_at "streaky_cove")) {
         : match "bake tons" {
            : collection_modify { collection = "tried_combo_core" index -> (10) content -> ("true") } ;
            : print "Good idea, but you have nothing to help you cook here. You file the thought away for later." ;
            : set_true "think_bake_tons" ;
            : done ;
         }
         : match "bake _;_ tons" { # obscure bug here, 1/2 guess will be spoiled that stove is in cove if we BAKE TONS outside, whether or not stove is there ??
            : set_integer var="tempint" "10" ;
            : set_false "first_half" ;
            : match "bake _" {
               : set_true "first_half" ;
            }
            : gosub "say_half" ;
            : done ;
         }
      }
   }
   : gosub "check_diagnostics" ;
   : gosub "check_meta" ;
   : gosub "check_options" ;

   : match "dig below" {
      : if (bonus_point_dig_below) {
         : print "You already looked forward to what you needed to do." ;
         : done ;
      }
      : collection_modify { collection = "tried_combo_bonus" index -> (0) content -> ("true") } ;
      : print "Narrative text." ;
      : set_true "bonus_point_dig_below" ;
      : gosub "add_bonus" ;
      : done ;
   }
   : if (!bonus_point_dig_below) {
      : match "dig _;_ below" {
         : set_integer var="tempint" "0" ;
         : set_false "first_half" ;
         : match "dig _" {
            : set_true "first_half" ;
         }
         : gosub "say_half_b" ;
         : done ;
      }
   }

   : if (xme_yet) {
      : match "_ widget;_ digit;_ dialed;_ wild" {
         : gosub "widget_function" ;
         : if (widget_noun_note) {
            : print "{one_time}All you can do is look at the widget, so every verb, silly or normal, does the same thing." ;
            : set_true "widget_noun_note" ;
         }
         : done ;
      }
   }

   : match "x me;x myself;x self" {
      : if (tutorial_0_in_tutorial && !tutorial_2_verbs) {
         : print {( "{xme} is good to do very early on, but for the purposes of the tutorial, there are a couple general information commands first. Try " + ( tutorial_1_about ? "{vm_verbs}" : "{vm_about}" ) + "." )} ;
         : set_true "skip_tutorial_cue" ;
         : done ;
      }
      : if (!xme_yet) {
         : print "You search around your body and notice your phone is gone." ;
         : print "\"Fie! Moan! My phone!\" you cry out. Weird, you're not used to talking like that." ;
         : print "You clutch at various places on your body, and you're surprised to find something very odd indeed turn up." ;
         : print "It's a {i_widget}." ;
      } : else {
         : print "You find nothing else on your person. You still can't locate your phone, but who knows, it may turn up some day. Perhaps when you least expect it." ;
      }
      : if (!tutorial_3_x_me && tutorial_2_verbs) {
         : set_true "tutorial_3_x_me" ;
         : increment "tutorial_score" ;
         : print "{one_time}you often need to examine some objects to reveal traits to use those objects properly. Though often in {this_game} you don't even need to use<X<#f80>>. Any verb with the noun is sufficient." ;
      }
      : set_true "xme_yet" ;
      : done ;
   }

   : match "listen _" {
      : print "You hear nothing unusual." ;
      : done ;
   }

   : match "smell _" {
      : print "Nothing smells unusual." ;
      : done ;
   }

   # the 4 below here are point scoring events that need general rejects
   : if (is_carried "chain") {
      : match "drop chain" {
         : print {( "You fling the chain on the ground, but it " + (is_at "yankin_canyon" ? "hurls you away from the hole and " : "") + "snakes back onto your wrist. You need stronger measures. Help from someone, or something, else." )} ;
         : done ;
      }
   }

   : match "drop _" {
      : set_boolean var="already_flag" {( point_chop_drain )} ;
      : print "{standard_puzzle_check}" ;
   }

   : match "take _" {
      : set_boolean var="already_flag" {( buns_taken )} ;
      : print "{standard_puzzle_check}" ;
   }

   : match "pull _" {
      : set_boolean var="already_flag" {( point_pull_file )} ;
      : print "{standard_puzzle_check}" ;
   }

   : match "push _" {
      : set_boolean var="already_flag" {( point_push_best )} ;
      : print "{standard_puzzle_check}" ;
   }

   : gosub "teststubs" ;

   : match "bake _;best _;cool _;clock _;chop _;creaky _;formed _;golden _;great _;hard _;key _;leery _;lodging _;minister _;penny _;platinum _;power _;rocky _;rumble _;rumbling _;sail _;sick _;sold _;steel _;taming _;tool _;tight _;written _" { #obfuscation of non solutions, regular points
      : print "{custom_unknown_verb_error}" ;
      : done ;
   }

   # bonus point obfuscations -- note MAP is taken care of elsewhere

   : match "dig _" { # also an obfuscation of a bonus point
      : print "The archaeology theme suggests digging, but it'll mostly be done implicitly. Mostly." ;
      : done ;
   }

   : match "clock _;golden _" { #obfuscation of non solutions, bonus points
      : print "{custom_unknown_verb_error}" ;
      : done ;
   }

}

on_tick {
   : if (!showed_first_note) {
      : print {( "{one_time}{vm_about} will give general game information. {vm_verbs} will describe {this_game}'s stripped-down parser." + (tutorial_0_in_tutorial ? " In fact, typing {vm_about} is the first step of the tutorial." : "" ) )} ;
      : set_true "showed_first_note" ;
      : done ;
   }
   : match "use _" {
      : cycle key = "use_notes" predictable_order = "true" skip_interval = "0" max_loops = "1" {
         : print "While there's stuff you need to use, the USE verb isn't specific enough, at least for {this_game}. Some other parser games allow and encourage it for weird items, so the player doesn't have to fight the parser, but here, the right command is needed for an item's use. Also, if you're seeing this message, it should mean whatever you tried to use isn't critical, as this game's parser often focuses on nouns." ;
         : print "You tried to {v_use} something that likely didn't need to be used, period." ;
      }
   }
   : match "i _" {
      : if (!tutorial_3_x_me && carried() == 0) {
         : print "You aren't holding anything, but you haven't really searched yourself with {xme}." ;
      } : else_if (carried() == 0) {
         : print {( "You " + (carried() == 0 ? "only" : "also" ) + " have the {i_widget}." )} ;
      }
   }
   : if (tutorial_0_in_tutorial) {
      : if (skip_tutorial_cue) {
         : set_false "skip_tutorial_cue" ;
         : done ;
      }
      : if (!tutorial_1_about) {
         : print "{note_cue_tutorial}First, you should type {vm_about} to see general information about {this_game}." ;
      } : else_if (!tutorial_2_verbs) {
         : print "{note_cue_tutorial}Now you've typed {vm_about}, you should type {vm_verbs} next to see basic commands for {this_game}." ;
      } : else_if (!tutorial_3_x_me) {
         : print "{note_cue_tutorial}Now you've seen basic info, you should examine yourself with {xme}." ;
      } : else_if (!tutorial_4_inventory) {
         : print "{note_cue_tutorial}Now you've examined yourself, you should type {vd_i_three} to verify the new item is in your inventory." ;
      } : else_if (!tutorial_5_think) {
         : print "{note_cue_tutorial}Now you've taken inventory, you should type {vd_think} next to recap odd things you've seen." ;
      } : else_if (!tutorial_6_tool_stall) {
         : cycle key = "tutorial_6" predictable_order = "true" skip_interval = "0" max_loops = "1" {
            : print "{note_cue_tutorial}Now you've taken inventory, you should figure what to do with the {puz_point_stool_tall}." ;
            : print "{note_cue_tutorial}What to do with the stool is a lateral thinking puzzle, so use {vd_hint} if you want to see the solution." ;
            : print "{note_cue_tutorial}Things in your inventory should give you a clue, as should the starting location name." ;
            : print "{note_cue_tutorial}The phrase you need is very similar to {puz_point_stool_tall}." ;
         }
      } : else_if (!tutorial_7_south_first) {
         : print "{note_cue_tutorial}Now you've removed the stool, you should go {dir_s} to check what's there." ;
      } : else_if (!tutorial_8_leery_owner_1) {
         : print "{note_cue_tutorial}Now you've made it to the tool stall, you may want to ask the {puz_point_eerie_loner} for someone specific. But who(m)? Using {vd_hint} is perfectly valid here, especially for non-native English speakers." ;
      } : else_if (!tutorial_9_north) {
         : print "{note_cue_tutorial}Now you know what you need, you should go back {dir_n}." ;
      } : else_if (!tutorial_10_listen) {
         : print "{note_cue_tutorial}Text adventures often have you use your senses for clues. Now you're back in the meadow, {v_listen_hear}." ;
      } : else_if (!tutorial_11_rocky_caves) {
         : print "{note_cue_tutorial}Now you've heard the {puz_point_cocky_raves_l}, you need to figure what they're cluing. You can use {vd_hint} if you want, but this is intended to be easier than the other puzzles." ;
      } : else_if (!tutorial_12_down) {
         : print "{note_cue_tutorial}Now you've found the rocky caves, you should go {dir_d} to explore them." ;
      } : else_if (!tutorial_13_smell) {
         : print "{note_cue_tutorial}You need to use one of your senses. There are five." ;
      } : else_if (!tutorial_14_steel_wrench) {
         : print "{note_cue_tutorial}You need to figure out what the {puz_point_real_stench} might be hiding." ;
      } : else_if (!tutorial_15_up) {
         : print "{note_cue_tutorial}You're done in the caves. Now you've got the steel wrench, you should retreat {dir_u}." ;
      } : else_if (!tutorial_16_south_twice) {
         : print "{note_cue_tutorial}The steel wrench might be useful in the tool stall to the {dir_s}." ;
      } : else_if (!tutorial_17_leery_owner_2) {
         : print "{note_cue_tutorial}Now you have something appropriate for the tool stall, you should ask to summon the person in charge. If you forget who that is, {vd_think}." ;
      } : else {
         : print "Oh no! You should be done with the tutorial. That's a small bug I'd like to know about." ;
         : set_false "tutorial_0_in_tutorial" ;
      }
   }

   # debug stuff here
   : if (track_digits) {
      : gosub "widget_function" ;
   }
   : if (track_hints) {
      : gosub "hint_function" ;
   }
}

on_render {
   : if (drawing_map) {
      : if (has_visited("rocky_caves")) {
         : overlay "m_0_visited" x="41" y="127" ;
         : overlay "m_rocky_caves" x="41" y="127" ;
