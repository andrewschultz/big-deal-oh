      }
      : if (is_at "outer_tower") {
         : overlay "m_you_are_here" x="81" y="64" ;
      }
      : if (has_visited("collation_location")) {
         : overlay "m_0_visited" x="121" y="64" ;
         : overlay "m_collation_location" x="121" y="64" ;
      }
      : if (is_at "collation_location") {
         : overlay "m_you_are_here" x="121" y="64" ;
      }
      : if (has_visited("ailer_lair")) {
