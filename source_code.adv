   num_to_word : list {
      items = [
         "zero",
         "one",
         "two",
         "three",
         "four",
         "five",
         "six",
         "seven"
      ]
   };

   tried_combo_core : list {
      items = [
         "false",
         "false",
         "false",
         "false",
         "false",
         "false"
      ]
   }

   situations_core : list {
      items = [
         "{here_demo_meadow}",
         "{here_rocky_caves}",
         "{here_demo_meadow}",
         "{here_tool_stall}",
         "{here_tool_stall}",
         "{here_demo_meadow}"
      ]
   }

   got_first_core : list {
      items = [
         "false",
         "false",
         "false",
         "false",
         "false",
         "false"
      ]
   }

   think_first_core : list {
      items = [
         "<ROCKY<#f80>>",
         "<STEEL<#f80>>",
         "<TOOL<#f80>>",
         "<LEERY<#f80>>",
         "<TIGHT<#f80>>",
         "<TAMING<#f80>>"
      ]
   }

   got_second_core : list {
      items = [
         "false",
