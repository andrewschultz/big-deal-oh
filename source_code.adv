         : if (point_rocky_caves) {
            : overlay "m_1_diag" x="73" y="98" ;
         }
         : if (point_tool_stall) {
            : overlay "m_1_vertical" x="96" y="98" ;
         }
         : if (point_taming_flowers) {
            : overlay "m_1_vertical" x="96" y="77" ;
            : overlay "m_1_horizontal" x="113" y="91" ;
            : overlay "m_1_horizontal" x="73" y="91" ;
         }
      }
      : if (is_at "demo_meadow") {
         : overlay "m_you_are_here" x="81" y="85" ;
