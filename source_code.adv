         "false",
         "false",
         "false",
         "false",
         "false",
         "false",
         "false",
         "false",
         "false",
         "false",
         "false",
         "false",
         "false"
      ]
   }

   tried_combo_bonus : list {
      items = [
         "false",
         "false",
         "false",
         "false"
      ]
   }

   situations_bonus : list {
      items = [
         "anywhere",
         "{here_app_mall}",
         "{here_app_mall}",
         "{here_foldin_gate}"
      ]
   }

   got_first_bonus : list {
      items = [
         "false",
         "false",
         "false",
         "false"
      ]
   }

   think_first_bonus : list {
      items = [
         "<DIG<#f80>>",
         "<MAP<#f80>>",
         "<CLOCK<#f80>>",
         "<GOLDEN<#f80>>"
      ]
   }

   got_second_bonus : list {
      items = [
         "false",
         "false",
         "false",
         "false"
      ]
   }

   think_second_bonus : list {
      items = [
         "<BELOW<#f80>>",
         "<ALL<#f80>>",
         "<JERK<#f80>>",
         "<FATE<#f80>>"
      ]
   }

   bonus_status : list {
      items = [
         0,
         0,
         0,
         0,
         0,
         0
      ]
   };

}

booleans {
   # game state (noncritical)
   xme_yet : boolean "false" ;
   showed_first_note : boolean "false" ;
   noted_upper_right : boolean "false" ;
   have_won : boolean "false" scope="survivor" ;
   in_number_choice : boolean "false" ;
   hint_zero_warn : boolean "false" ;
   hinted_yet : boolean "false" ;
   sunshine_xed : boolean "false" ;
   on_off_note : boolean "false" ;
   drawing_map : boolean "false" ;
   map_note : boolean "false" ;

   # game state (critical)
   listen_demo_meadow : boolean "false" ;
   smell_rocky_caves : boolean "false" ;
   placed_flaming_towers : boolean "false" ;
   buns_taken : boolean "false" ;

   key_found : boolean "false" ;
   key_duplicated : boolean "false" ;
   key_used : boolean "false" ;

   # game state (tutorials)
   skip_tutorial_cue : boolean "false" ; # not a tutorial but skip every-turn note when it is implied
   tutorial_0_in_tutorial : boolean "false" ;
   tutorial_1_about : boolean "false" ;
   tutorial_2_verbs : boolean "false" ;
   tutorial_3_x_me : boolean "false" ;
   tutorial_4_inventory : boolean "false" ;
   tutorial_5_think : boolean "false" ;
   tutorial_6_tool_stall : boolean "false" ;
   tutorial_7_south_first : boolean "false" ;
   tutorial_8_leery_owner_1 : boolean "false" ;
   tutorial_9_north : boolean "false" ;
   tutorial_10_listen : boolean "false" ;
   tutorial_11_rocky_caves : boolean "false" ;
   tutorial_12_southwest : boolean "false" ;
   tutorial_13_smell : boolean "false" ;
   tutorial_14_steel_wrench : boolean "false" ;
   tutorial_15_northeast : boolean "false" ;
   tutorial_16_south_twice : boolean "false" ;
   tutorial_17_leery_owner_2 : boolean "false" ;
   tutorial_done : boolean "false" ;

   # game state (point scoring) (alphabetical, with number in half-guess array)
   point_bake_tons       : boolean "false" ; # 9
   point_best_notes      : boolean "false" ; # 23
   point_chop_drain      : boolean "false" ; # 13
   point_cool_plan       : boolean "false" ; # 25
   point_creaky_stove    : boolean "false" ; # 10
   point_formed_wax      : boolean "false" ; # 15
   point_great_book      : boolean "false" ; # 26
   point_grow_dupes      : boolean "false" ; # 8
   point_hard_maze       : boolean "false" ; # 17
   point_help_card       : boolean "false" ; # 27
   point_key_trove       : boolean "false" ; # 11
   point_leery_owner     : boolean "false" ; # 3
   point_lodging_doc     : boolean "false" ; # 14
   point_minister_south  : boolean "false" ; # 16
   point_platinum_chain  : boolean "false" ; # 12
   point_pull_file       : boolean "false" ; # 7
   point_push_best       : boolean "false" ; # 6
   point_rocky_caves     : boolean "false" ; # 0
   point_penny_mounds    : boolean "false" ; # 18
   point_power_torch     : boolean "false" ; # 22
   point_sail_tide       : boolean "false" ; # 21
   point_sick_bride      : boolean "false" ; # 20
   point_sold_guide      : boolean "false" ; # 19
   point_steel_wrench    : boolean "false" ; # 1
   point_taming_flowers  : boolean "false" ; # 5
   point_tight_rules     : boolean "false" ; # 4
   point_tool_stall      : boolean "false" ; # 2
   point_written_specs   : boolean "false" ; # 24

   # bonus point(s) (alphabetize)
   bonus_point_clock_jerk : boolean "false" scope="survivor" ;
   bonus_point_dig_below : boolean "false" scope="survivor" ;
   bonus_point_golden_fate : boolean "false" scope="survivor" ;
   bonus_point_map_all : boolean "false" scope="survivor" ;

   # think variables
   think_bake_tons   : boolean "false" ;
   think_chop_drain  : boolean "false" ;
   think_grow_dupes  : boolean "false" ;
   think_leery_owner : boolean "false" ;

   # dynamic booleans for ease of coding
   known_leery_owner : dynamic_boolean {( think_leery_owner || point_leery_owner )} ;
   cocky_raves_present : dynamic_boolean {( listen_demo_meadow && !point_rocky_caves )} ;
   flaming_towers_present : dynamic_boolean {( placed_flaming_towers && !point_taming_flowers )} ;

   # think-relevant booleans
   already_got_command : boolean "false" ;
   think_any : dynamic_boolean {( think_leery_owner || think_grow_dupes || think_bake_tons || think_chop_drain )} ;
   first_half : boolean "false" ;
   half_bonus : boolean "false" ;
   bonus_obfuscated_note_yet : boolean "false" ;
   bonus_half_note : boolean "false" ;
   think_core_yet : boolean "false" ;
   think_bonus_yet : boolean "false" ;
   think_text_yet : boolean "false" ;
   print_bonus_nag_after : boolean "false" scope="survivor" ;
   print_core_nag_after : boolean "false" ;
   solved_both_parts_core_nag : boolean "false" ;
   solved_both_parts_bonus_nag : boolean "false" ;

   in_bonus_half : boolean "false" ;
   unneeded_half : dynamic_boolean {( tempint == 0 && !in_bonus_half )} ;

   # option(s)
   option_asked_once : boolean "false" scope="survivor" ;
   opt_block_done : boolean "false" scope="survivor" ;
   opt_color_coding : boolean "false" scope="survivor" ;
   opt_score_notify : boolean "true" scope="survivor" ;
   can_reveal_block_opt : dynamic_boolean {( score > 0 || option_asked_once || have_won )} ;

   # blocker dynamic booleans
   doneblock_rocky_caves : dynamic_boolean {( point_steel_wrench && opt_block_done )} ;

   widget_blurry : boolean "false" ;
   show_overlay : boolean "true" ;

   # auxiliary variables
   opt_on_off : boolean "false" ;
   already_flag : boolean "true" ;
}

vocabulary {

   : verb / aliases = [ch, colorhint] ;
   : verb / aliases = [opt, opts, option, options] ;

}

locations {
   ailer_lair : location "{loc_ailer_lair}" header="{header_ailer_lair}" graphic="r_0_blank" {
      on_command {
         : if (has_visited "foldin_gate") {
            : match "help card" {
               : if (point_help_card) {
                  : print "You already found the help card!" ;
                  : done ;
               }
               : print "The kelp is tough to pick through, which is discouraging, but then you remember if it's tough to pick through, it can catch a lot of stuff. And you find a help card! Actually, it's more a cold hard hold card, like for a library or something." ;
               : set_true "point_help_card" ;
               : pocket "hold_card" ;
               : gosub "add_point" ;
               : done ;
            }
         }
         : if (!point_help_card) {
            : match "help _;_ card" {
               : set_integer var="tempint" "26" ;
               : set_false "first_half" ;
               : match "help _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : if (point_sail_tide && !point_best_notes) {
            : match "best notes" {
               : print "Yes! That is what you need. The ailers are happy with this and leave you with the notes. They go off to complain elsewhere, abnout more first-worldly problems." ;
               : set_true "point_best_notes" ;
               : gosub "add_point" ;
               : done ;
            }
         }
         : if (point_sail_tide && !point_best_notes) {
            : match "best _;_ notes" {
               : set_integer var="tempint" "23" ;
               : set_false "first_half" ;
               : match "best _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   app_mall : location "{loc_app_mall}" header="{header_app_mall}" graphic="r_0_blank" {
      on_command {
         : match "map all" {
            : if (bonus_point_map_all) {
               : print "You already gained map-all capabilities!" ;
               : done ;
            }
            : print "The jock clerk nods. \"Yup, good, practical, simple. I think it'll serve you well. From now on, just say MAP whenever you want to map something.\"" ;
            : set_true "bonus_point_map_all" ;
            : gosub "add_bonus" ;
            : done ;
         }
         : if (!bonus_point_map_all) {
            : match "map _;_ all" {
               : set_integer var="tempint" "1" ;
               : set_false "first_half" ;
               : match "map _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half_b" ;
               : done ;
            }
         }
         : match "clock jerk" {
            : if (bonus_point_clock_jerk) {
               : print "You already alerted the clerk to the riff-raff. They will know what to do if said riff-raff return." ;
               : done ;
            }
            : print "You suggest a plan of action to the clerk, to get rid of the marginally audible kvetching. They wonder if it is too drastic. No, no, it is just right." ;
            : print "You locate the source of the kvetching about how apps sold here are too simplistic and dumb people shouldn't have luxuries that make their lives simple. The jock clerk looks determined before pulling out ..." ;
            : press_any_key ;
            : print "A stopwatch. All jocks have that, to test speed or endurance or whatever. The kvetcher still goes on. Tick, tick, goes the stopwatch. After five minutes the kvetcher asks if the clerk has anything better to do. The clerk asks back: pal, you've been complaining for more than five minutes. Oh no! That's different! They are spreading wisdom to the masses! You know, the ones who don't deserve efficiency!" ;
            : print "The jock clerk has little to say. The ticking of the stopwatch finally makes the kvetcher snap. \"ANYTHING to get away from that noise.\" And they do run away. The jock clerk thanks you for your help, embarrassed they didn't think of that themselves. But they'll know for next time." ;
            : set_true "bonus_point_clock_jerk" ;
            : gosub "add_bonus" ;
            : done ;
         }
         : if (!bonus_point_clock_jerk) {
            : match "clock _;_ jerk" {
               : set_integer var="tempint" "2" ;
               : set_false "first_half" ;
               : match "clock _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   backin_cabin : location "{loc_backin_cabin}" header="{header_backin_cabin}" graphic="r_backin_cabin" {
      on_command {
         : match "pull file" {
            : if (point_pull_file) {
               : print "You already pulled the file and made the cabin neater to make a path through!" ;
            }
            : print "Now you know what you're looking for in the full pile, or you're pretty sure you do, you can at least sort out the junk. Then you find a file. It describes where the secret passages in the cabin are. It's not pretty, but you dump some of the piles into the secret pasasages, as there's enough space in them, and things look a little cleaner. Those passages lead north, south and east." ;
            : set_true "point_pull_file" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_pull_file) {
            : match "pull _;_ file" {
               : set_integer var="tempint" "7" ;
               : set_false "first_half" ;
               : match "pull _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   cache_shack : location "{loc_cache_shack}" header="{header_cache_shack}" graphic="r_cache_shack" {
      on_command {
         : if (!buns_taken) {
            : match "take buns" {
               : print "Why, yes, it is that simple. You take the buns!" ;
               : set_true "buns_taken" ;
               : update_graphic ;
               : pocket "buns" ;
               : done ;
            }
         }
      }
      on_describe {
         : if (!buns_taken) {
            : print "There are BUNS just sitting around. They're packaged up and all. Shouldn't be hard to get them." ;
         }
      }
   }
   chattin_em_plain : location "{loc_chattin_em_plain}" header="{header_chattin_em_plain}" graphic="r_chattin_em_plain" {
      on_command {
         : match "platinum chain" {
            : if (point_platinum_chain) {
               : print "You already attracted the platinum chain to yourself." ;
               : done ;
            }
            : print "Well, you pushed your luck ... a platinum chain slithers from the ground onto your wrist. It feels heavy. You try to shake it off, but it stays. You grab it and throw it to the ground, but it leaps back up onto your wrist. You're obviously going to need help taking it off." ;
            : set_true "point_platinum_chain" ;
            : pocket "chain" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_platinum_chain) {
            : match "platinum _;_ chain" {
               : set_integer var="tempint" "12" ;
               : set_false "first_half" ;
               : match "platinum _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   collation_location : location "{loc_collation_location}" header="{header_cl}" graphic="r_collation_location" {
      on_command {
         : match "grow dupes" {
            : if (point_grow_dupes) {
               : print "You've duplicated enough!" ;
               : done ;
            }
            : if (!buns_taken) {
               : print "That seems right, but you have no raw materials with which to help the dough groups regenerate!" ;
               : set_true "think_grow_dupes" ;
               : done ;
            }
            : print "The buns you took manage to crumble off just enough. The dough groups, renewed, grow and -- somehow, when you're not looking -- reproduce. They thank you, assuring you the buns will now have self-regenerative properties of their own." ;
            : set_true "point_grow_dupes" ;
            : set_false "think_grow_dupes" ;
            : gosub "add_point" ;
            : update_graphic ;
            : done ;
         }
         : if (!point_grow_dupes) {
            : match "grow _;_ dupes" {
               : set_integer var="tempint" "8" ;
               : set_false "first_half" ;
               : match "grow _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   demo_meadow : location "{loc_demo_meadow}" header="{header_demo_meadow}" graphic="r_demo_meadow" {
      on_command {
         : match "s _" {
            : if (tutorial_0_in_tutorial && tutorial_9_north && !point_steel_wrench) {
               : print "You don't need to go back to the tool stall yet. You don't have what you need at the moment." ;
               : done ;
            }
         }
         : match "d _" {
            : if (tutorial_0_in_tutorial && point_steel_wrench) {
               : print "You don't need to go back to the rocky caves for the tutorial. You got what you needed." ;
               : done ;
            }
         }
         : if (!point_tool_stall) {
            : match "_ stool;_ tall" {
               : print "You're not sure why you think of the {puz_point_stool_tall} that way instead of a tall stool. It's a bit weird, here. You can't exactly take it, and it doesn't lead anywhere, either. " ;
               : done ;
            }
            : match "tool stall" {
               : if (tutorial_0_in_tutorial && !tutorial_5_think) {
                  : print "That's how to score the first point, but we're in the tutorial right now, so there are other things to do." ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (2) content -> ("true") } ;
               : print "The {puz_point_stool_tall} shakes and falls over and rolls around more than you thought possible. As it does, its legs point to a passage you haven't seen before, to the {dir_s}." ;
               : set_true "point_tool_stall" ;
               : set_true "tutorial_6_tool_stall" ;
               : gosub "add_point" ;
               : update_graphic ;
               : done ;
            }
            : match "tool _;_ stall" {
               : set_integer var="tempint" "2" ;
               : set_false "first_half" ;
               : match "tool _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : if (flaming_towers_present) {
            : match "taming flowers" {
               : if (point_taming_flowers) {
                  : print "You already picked some taming flowers!" ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (5) content -> ("true") } ;
               : print "You look for taming flowers. You figure weapons won't work. What sort of flowers would tame fire? Why, cold ones. You find ones that look really frosty, and what do you know? They feel frosty, too!\nYou walk up to each tower, and the flowers stand up surprisingly well to the heat. The towers dissolve in heaps of ash. You can go {dir_n} and {dir_e} and {dir_w} now." ;
               : set_true "point_taming_flowers" ;
               : gosub "add_point" ;
               : update_graphic ;
               : done ;
            }
            : if (!point_taming_flowers) {
               : match "taming _;_ flowers" {
                  : set_integer var="tempint" "5" ;
                  : set_false "first_half" ;
                  : match "taming _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
         : if (listen_demo_meadow) {
            : match "rocky caves" {
               : collection_modify { collection = "tried_combo_core" index -> (0) content -> ("true") } ;
               : if (point_rocky_caves) {
                  : print "You already know where the rocky caves are." ;
               }
               : print "The cockiness seems to recede as you look around with a purpose. Then you find it. A passage {dir_d} to rocky caves!" ;
               : set_true "point_rocky_caves" ;
               : set_true "tutorial_11_rocky_caves" ;
               : gosub "add_point" ;
               : done ;
            }
            : if (!point_rocky_caves) {
               : match "rocky _;_ caves" {
                  : set_integer var="tempint" "0" ;
                  : set_false "first_half" ;
                  : match "rocky _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
         : match "listen _" {
            : if (point_rocky_caves) {
               : print "Quieter, with the cocky raves gone." ;
               : done ;
            } : else_if (!listen_demo_meadow) {
               : if (tutorial_0_in_tutorial && !tutorial_9_north) {
                  : print "You'll want to do that later in the tutorial, but not yet." ;
                  : done ;
               }
               : print {( "What's that? {puz_point_cocky_raves}! Saying you won't find any" + (point_tool_stall ? " other" : "" ) + " way out of the meadow." )} ;
               : set_true "listen_demo_meadow" ;
               : set_true "tutorial_10_listen" ;
               : update_graphic ;
            } : else {
               : print "{puz_point_cocky_raves} continue to mock your inability to go anywhere interesting." ;
            }
         }
      }
      on_describe {
         : if (point_steel_wrench) {
            : set_true "tutorial_15_northeast" ;
         } : else_if (think_leery_owner) {
            : set_true "tutorial_9_north" ;
         }
         : if (flaming_towers_present) {
            : print "Those flaming towers are still flaming, exposing passage {dir_n}, {dir_e} and {dir_w} but not letting you by." ;
         } : else_if (point_tight_rules && !placed_flaming_towers) {
            : set_true "placed_flaming_towers" ;
            : print "It must have been a while since you went through the tight rules. Flaming towers have now popped up to the {dir_n}, {dir_e} and {dir_w}!" ;
            : update_graphic ;
         }
      }
   }
   foldin_gate : location "{loc_foldin_gate}" header="{header_foldin_gate}" graphic="r_foldin_gate" {
      on_command {
         : match "great book" {
            : if (!point_help_card) {
               : print "You'd like that, but you realize you'd need a special card or something to check it out. You don't have one." ;
               : done ;
            }
            : print "Narrative text." ;
            : set_true "point_great_book" ;
            : gosub "add_point" ;
            : win_game ;
            : done ;
         }
         : if (!point_great_book) {
            : match "great _;_ book" {
               : set_integer var="tempint" "27" ;
               : set_false "first_half" ;
               : match "great _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : match "n _" {
            : if (!bonus_point_golden_fate) {
               : print "You'll need to open the gate first. What could be behind it?" ;
            } : else {
               : cycle key = "thru_gate" predictable_order = "true" skip_interval = "0" max_loops = "1" {
                  : print "The trowel jiggles and seems to pull you away." ;
                  : print "You enter and achieve riches beyond your wildest dreams. But your life gets boring that way." ;
               }
            }
			: done ;
         }
         : match "golden fate" {
            : if (bonus_point_golden_fate) {
               : print "You already opened the foldin' gate!" ;
               : done ;
            }
            : print "The foldin' gate opens to reveal a golden fate behind it! What could be better than gold? Lots of it?" ;
            : set_true "bonus_point_golden_fate" ;
            : gosub "add_bonus" ;
            : done ;
         }
         : if (!bonus_point_golden_fate) {
            : match "golden _;_ fate" {
               : set_integer var="tempint" "3" ;
               : set_false "first_half" ;
               : match "golden _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half_b" ;
               : done ;
            }
         }
      }
   }
   gnawing_awning : location "{loc_gnawing_awning}" header="{header_gnawing_awning}" graphic="r_0_blank" { # ?? describe with 1 or 2 or 3 white sides
      on_command {
         : match "sail tide" {
            : if (point_sail_tide) {
               : print "You already made a sail tide from the tail side!" ;
               : done ;
            }
            : print "The tail side creaks and somehow sets off a Rube Goldberg-esque sequence of events that results in a waterway opening and the tide rising. You see a boat sail south out of view and then hear yelling to the south." ;
            : set_true "point_sail_tide" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_sail_tide) {
            : match "sail _;_ tide" {
               : set_integer var="tempint" "21" ;
               : set_false "first_half" ;
               : match "sail _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : match "sick bride" {
            : if (point_sick_bride) {
               : print "You already discovered the sick bride. Why make her sicker?" ;
               : done ;
            }
            : print "You are sort of surprised, and not, to find a sick bride. She talks about why she can't go through with a wedding. What she found that she couldn't even have told her friends. They are probably looking for her. But it is embarrassing. You say you'll keep a look out." ;
            : set_true "point_sick_bride" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_sick_bride) {
            : match "sick _;_ bride" {
               : set_integer var="tempint" "20" ;
               : set_false "first_half" ;
               : match "sick _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   jeerin_region : location "{loc_jeerin_region}" header="{header_jeerin_region}" graphic="r_0_blank" {
   }
   moldin_dolmen : location "{loc_moldin_dolmen}" header="{header_moldin_dolmen}" graphic="r_0_blank" {
      on_command {
         : match "formed wax" {
            : if (point_formed_wax) {
               : print "You got enough formed wax." ;
               : done ;
            }
            : print "You grab a warmed fax as it comes out. Not sure what to do with it, or how to make formed wax, you crumple it in a ball and throw it at the dolmen. The dolmen throws a lump of formed wax back at you. It's not fully formed, but it's in a block that will fit nicely into your pocket while still being able to take impressions of whatever you need to make impressions of.\nYou're so busy fumbling in your pocket you don't notice the fax machine has slowed down and eventually stopped." ;
            : pocket "wax" ;
            : gosub "dolmen_key_form" ;
            : set_true "point_formed_wax" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_formed_wax) {
            : match "_ fax;_ machine" {
               : print "When you walk over by the machine, it spits out a fax every couple minutes. Each fax is warmed but quickly cools off and disintegrates. What on earth could you do with a warmed fax?" ;
               : done ;
            }
            : match "formed _;_ wax" {
               : set_integer var="tempint" "15" ;
               : set_false "first_half" ;
               : match "formed _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
      on_describe {
         : gosub "dolmen_key_form" ;
      }
   }
   newbies_boonies : location "{loc_newbies_boonies}" header="{header_newbies_boonies}" graphic="r_newbies_boonies" {
      on_command {
         : match "push best" {
            : if (point_push_best) {
               : print "You already pushed the bush pest away." ;
            }
            : set_true "point_push_best" ;
            : print "It's an interesting little rassling match. Direct pushing doesn't work, but you have an idea. You move to your right, then as the bush comes to the right, you pull a Reggie White club move on it, pushing it the direction it was already going..." ;
            : press_any_key ;
            : update_graphic ;
            : set_integer var="newbies_cutscene" value="1";
            : print "It screams, then ..." ;
            : press_any_key ;
            : update_graphic ;
            : print "Oh no! You're worried you did permanent damage to it. You walk over to make sure it's okay. It get up, sticks its tongue out, and runs away for easier people, or entities, to be a nuisance to." ;
            : print "You can go all four directions now." ;
            : set_integer var="newbies_cutscene" value="2";
            : press_any_key ;
            : update_graphic ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_push_best) {
            : match "push _;_ best" {
               : set_integer var="tempint" "6" ;
               : set_false "first_half" ;
               : match "push _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   oopster_stupor : location "{loc_oopster_stupor}" header="{header_oopster_stupor}" graphic="r_0_blank" {
      on_command {
         : match "hard maze" {
            : if (point_hard_maze) {
               : print "You already cleared the marred haze!" ;
               : done ;
            }
            : print "The mists seem to re-form into ... something potentially worse! A hard maze! But at least you will be able to see your way through it. It seems pretty big, though, so you'll probably need some aid." ;
            : set_true "point_hard_maze" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_hard_maze) {
            : match "hard _;_ maze" {
               : set_integer var="tempint" "17" ;
               : set_false "first_half" ;
               : match "hard _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   outer_tower : location "{loc_outer_tower}" header="{header_outer_tower}" graphic="r_outer_tower" {
      on_command {
         : match "lodging doc;lodging dock" {
            : if (point_lodging_doc) {
               : print "You already made the lock stable." ;
               : done ;
            }
            : print "You aren't sure if the lock responded to \"doc\" or \"dock.\" It does, however, stop. \"You can come in if you have the key, I guess,\" says a voice." ;
            : set_true "point_lodging_doc" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_lodging_doc) {
            : match "lodging _;_ doc;_ dock" {
               : set_integer var="tempint" "14" ;
               : set_false "first_half" ;
               : match "lodging _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
      on_describe {
          : if (key_duplicated && !key_used) {
             : print "?? The reconstructed key works! You can go north now." ;
          }
      }
   }
   rocky_caves : location "{loc_rocky_caves}" header="{header_rocky_caves}" graphic="r_rocky_caves" {
      on_command {
         : match "u _" {
            : if (tutorial_0_in_tutorial && !point_steel_wrench) {
               : print "You have something to retrieve before going back to the demo meadow." ;
               : done ;
            }
         }
         : match "_ sunshine;_ shun;_ sign;_ sun;_ shine" {
            : print "It's a drawing of a sun with a red X over it. It's just there for local flavor." ;
            : if (!sunshine_xed) {
               : print "{one_time}when something is a spoonerism of itself, like the Demo Meadow, it's there for local flavor or humor. Authors try to balance having Extra Stuff to Look At with not distracting you too much, and I tried to establish this convention in {this_game}. I hope it works." ;
               : set_true "sunshine_xed" ;
            }
            : done ;
         }
         : match "smell _" {
            : if (point_steel_wrench) {
               : print "No smell any more." ;
            } : else_if (!smell_rocky_caves) {
               : print "You smell something. Something bad. A {puz_point_real_stench}." ;
               : set_true "smell_rocky_caves" ;
               : set_true "tutorial_13_smell" ;
               : update_graphic ;
            } : else {
               : print "Still that real stench." ;
            }
            : done ;
         }
         : if (smell_rocky_caves) {
            : if (!point_steel_wrench) {
               : match "steel wrench" {
                  : if (point_steel_wrench) {
                     : print "You already got the steel wrench!" ;
                     : done ;
                  }
                  : collection_modify { collection = "tried_combo_core" index -> (1) content -> ("true") } ;
                  : print "The stench is more bearable now you know what you're looking for. But you've still had quite enough of it -- you had to go into its heart -- once you acquire said wrench." ;
                  : set_true "point_steel_wrench" ;
                  : set_true "tutorial_14_steel_wrench" ;
                  : gosub "add_point" ;
                  : done ;
               }
               : match "steel _;_ wrench" {
                  : set_integer var="tempint" "1" ;
                  : set_false "first_half" ;
                  : match "steel _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
      }
      on_describe {
         : set_true "tutorial_12_southwest" ;
      }
   }
   streaky_cove : location "{loc_streaky_cove}" header="{header_streaky_cove}" graphic="r_streaky_cove" {
      on_command {
         : match "creaky stove" {
            : if (point_creaky_stove) {
               : print {( point_bake_tons ? "The stove is blown to bits. You can't get it back." : "You already revealed the stove!" )} ;
               : done ;
            }
            : print "Ah! That's what's along the unusually plain wall on the right-hand side. A creaky stove! You see an outline, and as you tap at the wall, it crumbles a bit. Yet that area still looks out of place." ;
            : set_true "point_creaky_stove" ;
            : gosub "add_point" ;
            : update_graphic ;
            : done ;
         }
         : if (!point_creaky_stove) {
            : match "creaky _;_ stove" {
               : set_integer var="tempint" "9" ;
               : set_false "first_half" ;
               : match "creaky _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
         : if (point_key_trove) {
            : match "_ trove" {
               : if (!point_lodging_doc) {
                  : print {( "So many keys with so many labels. " + (has_visited "outer_tower" ? "You wouldn't know which would fit the outer tower!" : "You haven't found anything that needs unlocking yet, so you won't waste time searching." ) )};
               } : else_if (!key_found) {
                  : print "You remember the phrase from the dodging lock. YONDER, FUTZ FONDER, YUTZ. It takes a while, but the keys are sorted more or less alphabetically, so that saves time. The key you pick is rusty. It will fall apart if you try to open the lock." ;
                  : set_true "key_found" ;
                  : pocket "trove_key" ;
               } : else_if (key_duplicated) {
                  : print {( "You have no need to search for another key, now you " + (key_used ? "used it" : "have a stronger replacement") + "." )} ;
               } : else {
                  : print "You search for another key, perhaps a stronger one, but nothing turns up. You'll have to make one." ;
               }
               : done ;
            }
         }
         : if (point_creaky_stove && is_carried "buns") {
            : match "bake tons" {
               : if (point_bake_tons) {
                  : print "You already had enough baking for one adventure, even if the stove didn't get destroyed." ;
                  : done ;
               }
               : print "The buns, charged with the dough groups' magic, fizzle as they heat up and explode! Fortunately, only the less picturesque part of the streaky cove blew up. Behind the streaky cove, you notice a different sort of cove: a {puz_point_tree_cove}!" ;
               : set_true "point_bake_tons" ;
               : set_false "think_bake_tons" ;
               : gosub "add_point" ;
               : update_graphic ;
               : destroy "buns" ;
               : done ;
            }
            : match "key trove" {
               : if (point_key_trove) {
                  : print "You already found the key trove. You just need to figure what to do with it." ;
                  : done ;
               }
               : print "There are a lot of trees, but you eventually uncover a key trove." ;
               : set_true "point_key_trove" ;
               : gosub "add_point" ;
               : done ;
            }
            : if (!point_key_trove) {
               : match "key _;_ trove" {
                  : set_integer var="tempint" "11" ;
                  : set_false "first_half" ;
                  : match "key _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
      }
   }
   taller_altar : location "{loc_taller_altar}" header="{header_taller_altar}" graphic="r_0_blank" {
   }
   tenser_center : location "{loc_tenser_center}" header="{header_tenser_center}" graphic="r_0_blank" {
      on_command {
         : match "minister south" {
            : if (point_minister_south) {
               : print "Already done!" ;
               : done ;
            }
            : print "Narrative text." ;
            : set_true "point_minister_south" ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_minister_south) {
            : match "minister _;_ south" {
               : set_integer var="tempint" "16" ;
               : set_false "first_half" ;
               : match "minister _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
   }
   tool_stall : location "{loc_tool_stall}" header="{header_tool_stall}" graphic="r_tool_stall" {
      on_command {
         : match "n _" {
            : if (tutorial_0_in_tutorial) {
               : if (!think_leery_owner) {
                  : print "For the purposes of this tutorial, you need to figure whom to ask the eerie loner for before going back {dir_n}." ;
                  : done ;
               }
               : if (point_steel_wrench && !point_leery_owner) {
                  : print "For the purposes of this tutorial, you need to figure whom to ask the eerie loner for before going back {dir_n}." ;
                  : done ;
               }
            }
         }
         : if (point_leery_owner) {
            : match "tight rules" {
               : if (point_tight_rules) {
                  : print "You already mastered the tight rules needed to use the right tools." ;
                  : done ;
               }
               : collection_modify { collection = "tried_combo_core" index -> (4) content -> ("true") } ;
               : print "You say you're willing to use the tools properly and take the time to be taught. The leery owner is pleased with this, or at least less displeased than you expected." ;
               : print "But it takes a while. Once you're done, the eerie loner pops back in to complain about how terrible things are outside." ;
               : print "\"Boy,\" says the owner. \"Usually the loner just generally grouses quietly. But if they actually spoke up, things must be bad. Better go check." ;
               : print "Or, if you want, I can show you a path back somewhere that may ... help you a bit. Or not. Off to the south, now.\"" ;
               : set_true "point_tight_rules" ;
               : gosub "add_point" ;
               : done ;
            }
            : if (!point_tight_rules) {
               : match "tight _;_ rules" {
                  : set_integer var="tempint" "4" ;
                  : set_false "first_half" ;
                  : match "tight _" {
                     : set_true "first_half" ;
                  }
                  : gosub "say_half" ;
                  : done ;
               }
            }
         }
         : match "leery owner" {
            : if (point_leery_owner) {
               : print "You already summoned the owner!" ;
               : done ;
            }
            : collection_modify { collection = "tried_combo_core" index -> (3) content -> ("true") } ;
            : if (!point_steel_wrench) {
               : print "The eerie loner grumbles \"Can't disturb the owner unless you have something for them.\"" ;
               : set_true "think_leery_owner" ;
               : set_true "tutorial_8_leery_owner_1" ;
               : done ;
            }
            : print "The eerie loner grumbles. You show the steel wrench.\n\"All right, I'll get 'em.\" The loner leaves, their job done for the day. The leery owner comes out." ;
            : set_true "point_leery_owner" ;
            : set_false "think_leery_owner" ;
            : set_true "tutorial_17_leery_owner_2" ;
            : if (tutorial_0_in_tutorial) {
               : print "Congratulations! You finished the tutorial." ;
               : set_false "tutorial_0_in_tutorial" ;
            }
            : update_graphic ;
            : gosub "add_point" ;
            : done ;
         }
         : if (!point_leery_owner) {
            : match "leery _;_ owner" {
               : set_integer var="tempint" "3" ;
               : set_false "first_half" ;
               : match "leery _" {
                  : set_true "first_half" ;
               }
               : gosub "say_half" ;
               : done ;
            }
         }
      }
      on_describe {
         : set_true "tutorial_7_south_first" ;
         : if (point_steel_wrench) {
            : set_true "tutorial_16_south_twice" ;
         }
      }
   }
   yankin_canyon : location "{loc_yankin_canyon}" header="{header_yankin_canyon}" graphic="r_0_blank" {
      on_command {
         : match "listen _" {
            : print {( point_chop_drain ? "No whirring now." : "There's a whirring from the hole." )} ;
            : done ;
         }
         : match "_ hole" {
            : print {( point_chop_drain ? "Now you know the hole can shred metal, you don't want to mess with it." : "You watch the hole a bit. Leaves and tumbleweeds and such get torn apart as they are sucked in." )} ;
            : done ;
         }
      }
   }
}

# Defines things in the world (scenery cannot be carried)
objects {
   buns : object "the BUNS you managed/needed to TAKE" at="cache_shack" conspicuous="false" ;
   chain : object "the platinum chain that snapped onto you that you want to get rid of" ;
   slab : object "the slender fab fender slab that was inside the platinum chain" conspicuous="false" ;
   seek_key : object "the reconstructed key from the dolmen" ;
   trove_key : object "a flimsy key from the trove" ;
   wax : object "the formed wax from the warmed fax" ;
}

connections {

   from, direction, to = [

      demo_meadow, down, rocky_caves
      demo_meadow, south, tool_stall

      demo_meadow, north, outer_tower
      demo_meadow, east, backin_cabin
      demo_meadow, west, newbies_boonies

      backin_cabin, north, collation_location
      backin_cabin, east, yankin_canyon
      backin_cabin, south, streaky_cove

      newbies_boonies, west, cache_shack
      newbies_boonies, north, moldin_dolmen
      newbies_boonies, south, chattin_em_plain

      outer_tower, north, tenser_center

      tenser_center, east, taller_altar
      tenser_center, west, gnawing_awning
      tenser_center, north, oopster_stupor

      gnawing_awning, north, ailer_lair
      taller_altar, north, jeerin_region

      oopster_stupor, north, foldin_gate

      tool_stall, south, app_mall

   ]

}

barriers {

   #blockers will all be defined by map location (x,y) from bottom left. (6,4) is the upper right map edge.

   block_10_rockycaves : block {
      location = rocky_caves
      block_when_not = point_rocky_caves
      message = Maybe something's below, but you need to look for something concrete.
   }

   block_20_app_mall : block {
      location = app_mall
      block_when_not = point_tight_rules
      message = There is something south, but you'll need management's trust first.
   }

   block_11_chattin_em_plain : block {
      location = chattin_em_plain
      block_when_not = point_push_best
      message = The bush pest slides over to block passage south.
   }

   block_21_meadow_toolstall : block {
      location = tool_stall
      block_when_not = point_tool_stall
      message = Maybe something's south, but you need to look for something concrete.
   }

   block_31_streaky_cove : block {
      location = streaky_cove
      block_when_not = point_pull_file
      message = Perhaps there is a passage south behind the backin' cabin. How to clear it out?
   }

   block_02_cache_shack : block {
      location = cache_shack
      block_when_not = point_push_best
      message = The bush pest slides over to block passage west.
   }

   block_12_0_newbies_boonies : block {
      location = newbies_boonies
      block_when_not = point_tight_rules
      message = Maybe something's west, but you need to look for something concrete.
   }

   block_12_newbies_boonies : block {
      location = newbies_boonies
      block_when_not = point_taming_flowers
      message = You need to neutralize the flaming towers first.
   }

   # no block_22 since that's the demo meadow where we start

   block_32_0_backin_cabin : block {
      location = backin_cabin
      block_when_not = point_tight_rules
      message = Maybe something's east, but you need to look for something concrete.
   }

   block_32_backin_cabin : block {
      location = backin_cabin
      block_when_not = point_taming_flowers
      message = You need to neutralize the flaming towers first.
   }

   block_42_yankin_canyon : block {
      location = yankin_canyon
      block_when_not = point_pull_file
      message = Perhaps there is a passage east behind the backin' cabin. How to clear it out?
   }

   block_13_moldin_dolmen : block {
      location = moldin_dolmen
      block_when_not = point_push_best
      message = The bush pest slides over to block passage north.
   }

   block_23_0_outer_tower : block {
      location = outer_tower
      block_when_not = point_tight_rules
      message = Maybe something's north, but you need to look for something concrete.
   }

   block_23_outer_tower : block {
      location = outer_tower
      block_when_not = point_taming_flowers
      message = You need to neutralize the flaming towers first.
   }

   block_33_collation_location : block {
      location = collation_location
      block_when_not = point_pull_file
      message = Perhaps there is a passage north behind the backin' cabin. How to clear it out?
   }

   block_14_ailer_lair : block {
      location = ailer_lair
      block_when_not = point_minister_south
      message = The sinister mouth blocks your passage west.
   }

   block_24_tenser_center : block {
      location = tenser_center
      block_when_not = key_used
      message = You haven't unlocked the tower yet.
   }

   block_34_jeerin_region : block {
      location = jeerin_region
      block_when_not = point_minister_south
      message = The sinister mouth blocks your passage east.
   }

   block_25_oopster_stupor : block {
      location = oopster_stupor
      block_when_not = point_minister_south
      message = The sinister mouth blocks your passage north.
   }

   ###########################block_done

   block_done_meadow_rocky_caves : block {
      location = rocky_caves
      block_when = doneblock_rocky_caves
      message = You are done in the rocky caves.
   }

}

subroutines {

   note_score_upper_right : subroutine {
      : if (!noted_upper_right) {
         : print "{one_time}you can toggle score notifications with {optt_notify} {yn}. The score is always tracked in the upper right." ;
         : set_true "noted_upper_right" ;
      }
   }
   add_bonus : subroutine {
      : if (opt_score_notify) {
         : print "<You just found a bonus point!<#ff0>>" ;
         : if (bonus_score == 0) {
            : print "{one_time}{this_game} contains several bonus points that are uncued on the first playthrough. {vd_sco} will let you know how many you've found, and {vd_bon} will list where you found them." ;
         }
      }
      : increment "bonus_score" ;
      : update_graphic ;
   }

   add_point : subroutine {
      : if (opt_score_notify) {
         : print "<Your score has just gone up by a point!<#ff0>>" ;
      }
      : gosub "note_score_upper_right" ;
      : increment "score" ;
      : update_graphic ;
   }

   say_half : subroutine {
      : match "* -;- *" {
         : print "Feels right, but what to pair that word with?" ;
         : done ;
      }
      : cycle key = "one_right" predictable_order = "true" skip_interval = "0" max_loops = "1" {
         : print "One of those words felt right, but the other didn't. You must be halfway there{for_bonus}.{already_got_check}" ;
         : print "Again, you feel like you got halfway there{for_bonus}.{already_got_check}" ;
         on_exhausted {
            : print "One word right, one word wrong{for_bonus}.{already_got_check}" ;
         }
      }
      : if (first_half) {
         : if (half_bonus) {
            : collection_modify { collection = "got_first_bonus" index -> (tempint) content -> ("true") ; }
         } : else {
            : collection_modify { collection = "got_first_core" index -> (tempint) content -> ("true") ; }
         }
      } : else {
         : if (half_bonus) {
            : collection_modify { collection = "got_second_bonus" index -> (tempint) content -> ("true") ; }
         } : else {
            : collection_modify { collection = "got_second_core" index -> (tempint) content -> ("true") ; }
         }
      }
      : set_false "already_got_command" ;
      : if (!half_bonus) {
         : done ;
      }
   }
   say_half_b : subroutine {
      : if (!have_won) {
         : print "{custom_unknown_verb_error}" ;
         : if (!bonus_obfuscated_note_yet) {
            : print "{one_time}well, not exactly. You've discovered half of a bonus point. But the first time through, {qt} won't be hinting them, so as not to distract you from the main quest. If you continue after the win-and-restart, you'll get a nudge, since it's assumed you know the main way through." ;
            : set_true "bonus_obfuscated_note_yet" ;
         }
         : done ;
      }
      : set_true "half_bonus" ;
      : decrement "tempint" ;
      : gosub "say_half" ;
      : if (!bonus_half_note) {
         : print "{one_time}since you've been through once, I will assume you know all the core points and are hunting for bonus points. This wasn't available the first time through, to avoid distracting you from the main game." ;
         : set_true "bonus_half_note" ;
      }
      : set_false "half_bonus" ;
      : done ;
   }

   check_diagnostics : subroutine {
      : match "i _" {
         : if (tutorial_0_in_tutorial && !tutorial_3_x_me) {
            : print "We'll want to take inventory eventually in this tutorial, but there are even more basic things first." ;
            : done ;
         }
         : mask {
            : set_true "tutorial_4_inventory" ;
         }
         : if (carried() == 0) {
            : print "" ;
         }
      }

      : match "map _" {
         : if (!bonus_point_map_all) {
            : print "You haven't gained access to the internal game map command yet. It's not critical to win, though." ;
            : done ;
         }
         : set_true "drawing_map" ;
         : clear_screen ;
         : update_graphic "m_0_blank" ;
         : press_any_key ;
         : set_false "drawing_map" ;
         : if (!map_note) {
            : print "{one_time}there are no one-way paths. If you have activated the option to block completed rooms, they will be in <GREY<#888>>." ;
            : set_true "map_note" ;
         }
         : update_graphic ;
         : done ;
      }

      : match "score _" {
         : print "You've currently scored {score} of {max_score} total core points. You have scored {bonus_score} of {max_bonus_score} bonus points." ;
         : gosub "note_score_upper_right" ;
      }

      : match "think _" {
         : if (tutorial_0_in_tutorial)
         {
            : if (!tutorial_4_inventory) {
               : print "{vd_think} is part of the tutorial, but it will occur later on." ;
               : done ;
            }
            : set_true "tutorial_5_think" ;
         }
         : if (think_leery_owner) {
            : print "You called for the {tht_leery_owner} in the tool stall but didn't have anything to trade." ;
         }
         : if (think_bake_tons) {
            : print "You tried to {tht_bake_tons} {here_streaky_cove} but the buns weren't ready to grow yet.." ;
         }
         : if (think_bake_tons) {
            : print "You tried to put the chain into a chop drain when one wasn't nearby." ;
         }
         : if (think_grow_dupes) {
            : print "You tried to grow dupes {here_collation_location} but didn't have any additional materials to help." ;
         }
         : gosub "diagnostic_think_core_half" ;
         : gosub "diagnostic_think_bonus_half" ;
         : if (print_core_nag_after) {
            : print "{one_time}You have figured each half of a point-scoring command, but you haven't typed them both together. That still might not work if you haven't prepared by solving other puzzles, but if that's the case, {vd_think} will remind you with context until it does." ;
            : set_true "solved_both_parts_core_nag" ;
            : set_false "print_core_nag_after" ;
         }
         : if (print_bonus_nag_after) {
            : print "{one_time}You have figured each half of a bonus point scoring command, but you haven't typed them both together. {vd_think} will remind you of this try until it works, though game state changes may make, or have made, this undoable until you replay." ;
            : set_true "solved_both_parts_bonus_nag" ;
            : set_false "print_bonus_nag_after" ;
         }
         : if (!think_any && !think_core_yet && !think_bonus_yet) {
            : print "You haven't had any good ideas you weren't able to execute yet." ;
            : done ;
         }
      }
   }

   check_meta : subroutine {
      : match "about _" {
         : print "{this_game} was written for {l_talp_2026}, another annual edition of {l_talp}." ;
         : print "It is in the spirit of {l_qt} and reuses a lot of the code. However, this year I'm trying to get in with the theme of Archaeology, even if my knowledge of that field is rudimentary." ;
         : set_true "tutorial_1_about" ;
         : done ;
      }

      : match "credits _;credit _;creds _;cred _" {
         : print "Nothing yet. But obviously this will grow, and I need to fix this, and if you're testing now, you'll be in here!" ;
         : done ;
      }

      : match "help _;hint _;hints _" {
         : gosub "hint_function" ;
         : done ;
      }

      : match "history _;version _;versions _" {
         : print "So far there has been only one release, for {l_talp_2026}." ;
         : done ;
      }

      : match "meta _" {
         : print "{vm_about} gives general information." ;
         : print "{vm_credits} credits people and entities who helped make {this_game} or fix various flaws." ;
         : print "{vm_diag} lists diagnostic verbs." ;
         : print "{vm_diag} lists version history and major changes that necessitated each version." ;
         : print "{vm_meta}, this command, lists meta-commands, or commands that list other commands." ;
         : print "{vm_options} lists options." ;
         : print "{vm_verbs} describes verbs the parser uses." ;
         : print "Native commands unique to Adventuron include {vs_tss}, which start and stop a transcript, which help the programmer find bugs, technical or narrative. {vs_quit} and {vs_restart} are common across text adventure systems. SAVE and RESTORE work as well." ;
         : done ;
      }

      : match "options _" {
         : set_boolean var="opt_on_off" {( opt_color_coding )} ;
         : print "{optt_ch}: turns color coded hinting on or off. Currently it is {txt_on_off}." ;
         : set_boolean var="opt_on_off" {( opt_score_notify )} ;
         : print "{optt_notify}: turns score notification on or off. Currently it is {txt_on_off}." ;
         : if (!can_reveal_block_opt) {
            : print "There's one more option, but knowing it could spoil the game mechanic before you want to. So you'll need to type {vm_options} again to see it." ;
         } : else {
            : set_boolean var="opt_on_off" {( opt_block_done )} ;
            : print {( "{optt_block}: blocks off places with nothing left to do. Currently it is set to " + (opt_block_done ? optt_block_on : optt_block_off) + "." )} ;
         }
         : if (!on_off_note) {
            : print "{one_time}: {yn} toggles options. ON and OFF would be more logical, but Adventuron reserves ON for internal use. {this_game} also does not toggle an option if you type it alone." ;
            : set_true "on_off_note" ;
         }
         : set_true "option_asked_once" ;
         : done ;
      }

      : match "verbs _;verb _" {
         : print "{this_game} uses a reduced parser, though you need to guess certain commands to score points." ;
         : print "Many commands are noun-based, so you don't have to guess the verb for relatively common actions, e.g. PUSH THING and USE THING are the same." ;
         : print "Many commands are noun-based, so you don't have to guess the verb for relatively common actions, e.g. PUSH THING and USE THING are the same." ;
         : print "You can use the basic directions {dir_n}, {dir_s}, {dir_e}, {dir_w}, {dir_u} and {dir_d}, abbreviated to a single letter e,g, <N<#f80>>/<S<#f80>>/<E<#f80>>/<W<#f80>>/<U<#f80>>/<D<#f80>>." ;
         : print "You will also want to use the senses, including {v_listen}, {v_smell} and {v_feel}." ;
         : print "You can <X<#f80>> something to examine it, though for most scenery in this game, you can use a noun, and any verb works." ;
         : print "<L<#f80>> for look refreshes the screen." ;
         : print "For the most part, <TAKE<#f80>> and <DROP<#f80>> aren't used, as the game automatically picks up what you need and destroys it when done. But they may be part of a puzzle." ; #?? establish whem
         : print "Verbs outside of the game world are listed in {vm_meta}, {vm_diag}(NOSTIC), and {vm_options}. Intuitive abbreviations often work." ;
         : set_true "tutorial_2_verbs" ;
         : done ;
      }

   }

   check_options : subroutine {
      : match "ch _" {
         : gosub "options_colorhint" ;
      }
      : match "notify _" {
         : gosub "options_notify" ;
      }
      : match "all way" {
         : print {( "Blocking done areas is " + (!opt_block_done ? "already" : "now" ) + " off." )} ;
         : set_false "opt_block_done" ;
         : done ;
      }
      : match "wall eh" {
         : print {( "Blocking done areas is " + (opt_block_done ? "already" : "now" ) + " on." )} ;
         : set_true "opt_block_done" ;
         : done ;
      }
   }

   option_err_stub : subroutine {
      : match "_ -" {
         : print "Toggling {tempopt} without an argument ({yn}) is not supported." ;
         : done ;
      }
      : print "Toggling {tempopt} requires one of {yn} as an argument." ;
      : done ;
   }

   options_colorhint : subroutine {
      : set_boolean var="opt_on_off" {( opt_color_coding )} ;
      : match "ch yes" {
         : print "Now {cch} is activated." ;
         : set_true "opt_color_coding" ;
         : done ;
      }
      : match "ch no" {
         : print "Now {cch} is deactivated." ;
         : set_false "opt_color_coding" ;
         : done ;
      }
      : set_string var="tempopt" text="{optt_ch}" ;
      : gosub "option_err_stub" ;
   }

   options_notify : subroutine {
      : set_boolean var="opt_on_off" {( opt_score_notify )} ;
      : match "notify yes" {
         : print "Score notify is now on.";
         : set_true "opt_score_notify";
         : done ;
      }
      : match "notify no" {
         : print "Score notify is now off.";
         : set_false "opt_score_notify";
         : done ;
      }
      : set_string var="tempopt" text="{optt_notify}" ;
      : gosub "option_err_stub" ;
   }

   #########################################room specific

   dolmen_key_form: subroutine {
      : if (point_formed_wax && key_found && point_chop_drain && !key_duplicated) {
         : print "Now you have the old key, some stronger metal, and wax to make impressions, you could almost make a key. The moldin' dolmen might be able to help. You offer the three items to it ... and out comes a shiny new key! A key so \"Seek, oh!\"" ;
         : destroy "trove_key" ;
         : pocket "seek_key" ;
      }
   }
   #########################################hint and tutorial

   diagnostic_think_core_half : subroutine {
      : set_integer var="counter" "0" ;
      : set_false "think_core_yet" ;
      : while (counter < max_score) {
         : if ((collection_get{ collection -> ("tried_combo_core") index -> ( counter )} == "false")) {
            : if (part_core_score > 0) {
               : if (!think_core_yet) {
                  : print "{think_here_also} is a summary of correct bonus command half-guesses:" ;
                  : set_true "think_core_yet" ;
                  : set_true "think_text_yet" ;
               }
               : print {( (part_core_score != 2 ? (collection_get{ collection -> ("think_first_core") index -> (counter) }) : "{noguess_c_1}") + " " + (part_core_score >= 2 ? (collection_get{ collection -> ("think_second_core") index -> (counter) }) : "{noguess}") + " " + (collection_get{ collection -> ("situations_core") index -> (counter) }) )} ;
               : if (!solved_both_parts_core_nag && part_core_score == 3) {
                  : set_true "print_core_nag_after" ;
               }
            }
         }
         : increment "counter" ;
      }
   }

   diagnostic_think_bonus_half : subroutine {
      : set_integer var="counter" "0" ;
      : set_false "think_bonus_yet" ;
      : set_true "in_bonus_half" ;
      : while (counter < max_bonus_score) {
         : if ((collection_get{ collection -> ("bonus_status") index -> ( counter )} == "0")) {
            : if (part_bonus_score > 0) {
               : if (!think_bonus_yet) {
                  : print "{think_here_also} is a summary of correct bonus command half-guesses:" ;
                  : set_true "think_text_yet" ;
                  : set_true "think_bonus_yet" ;
               }
               : print {( (part_bonus_score != 2 ? (collection_get{ collection -> ("think_first_bonus") index -> (counter) }) : "{noguess}") + " " + (part_bonus_score >= 2 ? (collection_get{ collection -> ("think_second_bonus") index -> (counter) }) : "{noguess}") + " " + (collection_get{ collection -> ("situations_bonus") index -> (counter) }) )} ;
               : if (!solved_both_parts_bonus_nag && part_bonus_score == 3) {
                  : set_true "print_bonus_nag_after" ;
               }
            }
         }
         : increment "counter" ;
      }
      : set_false "in_bonus_half" ;
   }

   #########################################hint and tutorial

   hint_function : subroutine {
      : if (!hinted_yet) {
         : print "{one_time}{this_game} makes a reasonable guess of the next puzzle you can solve in the current room. If nothing turns up, you may wish to go elsewhere." ;
         : set_true "hinted_yet" ;
      }
      : set_true "skip_tutorial_cue" ;
      : if (tutorial_0_in_tutorial && !tutorial_5_think) {
         : print "There are several things you can do here. Get to step 4 of the tutorial, then ask for hints again." ;
         : set_true "hint_zero_warn" ;
         : done ;
      }
      : if (score == 0 && !xme_yet) {
         : print "Before I give hints, I'd like you to try {xme}, a standard action to start text adventures. It will give a clue." ;
         : done ;
      }
      : if (is_at "demo_meadow") {
         : if (!point_tool_stall) {
            : cycle key = "hint_tool_stall" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_tool_stall} is out of place in a meadow and oddly worded for a reason." ;
               : print "You may notice something about some location names and expressions." ;
               : print "Demo meadow. Fie Moan My Phone, if you examined yourself. The item is a {i_widget}." ;
               : print "Spoonerisms are the mechanic." ;
               : print "Flip the sounds at the start of the words to get a..." ;
               : print "TOOL STALL." ;
            }
            : done ;
         }
         : if (!listen_demo_meadow) {
            : print "{v_listen} for what to do next." ;
            : done ;
         }
         : if (!point_rocky_caves) {
            : cycle key = "hint_rocky_caves" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_cocky_raves} sure find it funny you can't find a way out." ;
               : print "But of course the {puz_point_cocky_raves} are hiding something you may be able to figure out." ;
               : print "COCKY RAVES are nearby." ;
            }
            : done ;
         }
      } : else_if (is_at "tool_stall") {
         : if (!point_steel_wrench) {
            : print "You need to do something elsewhere first to make progress here." ;
            : done ;
         }
         : if (!point_leery_owner) {
            : cycle key = "hint_leery_owner" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_eerie_loner} isn't the person you need to speak to, but they can summon the person who is." ;
               : print "The {puz_point_eerie_loner} isn't big on positivity, either." ;
               : print "Who is the manager? Something that rhymes with loner, someone in charge." ;
               : print "You need to talk to the OWNER of this establishment." ;
               : print "But the eerie loner is suspicious of you." ;
               : print "LEERY, in other words." ;
               : print "Ask for the {tht_leery_owner}." ;
            }
            : done ;
         }
         : if (!point_tight_rules) {
            : cycle key = "hint_tight_rules" predictable_order = "true" skip_interval = "0" {
               : print "The {puz_point_eerie_loner} isn't the person you need to speak to, but they can summon the person who is." ;
               : print "The {puz_point_eerie_loner} isn't big on positivity, either." ;
               : print "Who is the manager? Something that rhymes with loner, someone in charge." ;
               : print "You need to talk to the OWNER of this establishment." ;
               : print "But the eerie loner is suspicious of you." ;
               : print "LEERY, in other words." ;
               : print "Ask for the LEERY OWNER." ;
            }
            : done ;
         }
      } : else_if (is_at "rocky_caves") {
         : if (!smell_rocky_caves) {
            : cycle key = "hint_rocky_caves_smell" predictable_order = "true" skip_interval = "0" {
               : print "Time to use a different sense. It's damp and dark here. You can't really see and don't want to taste, but what other sense can you use?" ;
               : print "You can SMELL." ;
               : done ;
            }
         }
         : if (!point_steel_wrench) {
            : cycle key = "hint_steel_wrench" predictable_order = "true" skip_interval = "0" {
               : print "That real stench may prevent less hardy adventurers from finding something, but maybe if you looked for something specific, you'd find it." ;
               : print {( point_tool_stall ? "The tool stall you unveiled needs an item." : "The stool (tall) back in the meadow leads somewhere that could give you a clue." )} ;
               : done ;
            }
         }
      }
      : print "I can't point to anything here and now.";
      : done ;
   }

   tutorial_choice : subroutine {
      : if (have_won) {
         : return ;
      }
      : ask_bool {
         question   = {this_game} has a tutorial mode for the first few puzzles. If you wish to use it, you need to request it before the game starts. Would you like to use it?
         yes_answer = Yes, I'd like to use the tutorial.
         no_answer  = No, I'd rather skip the tutorial.
         var        = tutorial_0_in_tutorial
      }
      : if (tutorial_0_in_tutorial) {
         : print "Tutorial mode is now on. You can switch it off, but once you do, you can't switch it on again." ;
      } : else {
         : print "Tutorial mode is disabled. If you wish to try it, you will need to restart it." ;
      }
      : press_any_key ;
      : clear_screen ;
   }

   colorclue_choice : subroutine {
      : if (have_won) {
         : return ;
      }
      : ask_bool {
         question   = {this_game} also puts critical words in <PURPLE<#f0f>> to help you know what to work with. The option can be changed in-game with CH YES/NO (on/off are reserved by Adventuron.)
         yes_answer = Yes, I'd like to use color-coded hinting.
         no_answer  = No, I'd prefer not to use color-coded hinting.
         var        = opt_color_coding
      }
      : print {( "Color-coded hinting is " + (opt_color_coding ? "now available." : "disabled.") + " We're ready to start the game, now!" )} ;
      : press_any_key ;
      : clear_screen ;
   }

}

themes {
   my_theme : theme {
      status_bar {
         : header_text ;
         : dynamic_text "my_score" ;
      }
      theme_settings {
         parser_delay  = 0
      }
      colors {
         status_bar_pen   = 15
         status_bar_paper = #222
      }
      system_messages {

         i_cant_do_that = That's a valid command, but not right here and now.
         not_present = You can't see ${entity} here.
         ask_new_game                                   = Would you like to restart {this_game}?
         ask_quit                                       = A voice behind the fourth wall pleads \"I quit? QUIET!\"\nDo you wish to quit {this_game}?
         invalid_choice                                 = {yn_or_12_or_14}
         post_quit = I hope you enjoyed the experience. Pressing {key_enter} will restart {this_game}.
         unknown_verb                                   = {custom_unknown_verb_error}
         you_cant_go_that_direction                     = {exits_err}
         you_see_nothing_special = {nospecial_custom}
         you_see_nothing_special_2 = {nospecial_custom}
      }
   }
}

## Print the objective when the game starts

on_startup {
   : print "{this_game}: a {l_talp_2026} entry.";
   : if (have_won) {
      : print "Thanks for replaying, but this is a reminder to look at the other {l_talp_26} entries, too!" ;
      : press_any_key ;
      : clear_screen ;
   } : else {
      : gosub "tutorial_choice" ;
      : gosub "colorclue_choice" ;
   }
}

## Execute this every time a player moves or redescribes a location

on_describe {
}

## Test VERB NOUN that the player types and executes conditional actions

on_command {
   : match "xyzzy _" {
      : print "A low voice booms \"Vexing howls? Hexing?! VOWELS!\"";
      : done ;
   }
   : if (is_carried "chain") {
      : match "chop drain" {
         : if (point_chop_drain) {
            : print "The chain should be off-stage. You shouldn't have it again." ;
            : done ;
         }
         : if (!is_at("yankin_canyon")) {
            : print "That would destroy the chain, but you see nothing that resembles, or could hold, a chop drain." ;
            : set_true "think_chop_drain" ;
            : done ;
         }
         : print "You take a guess that the hole here is a CHOP DRAIN. You fling the platinum chain towards it. Or try to. You struggle to pull it off, then suddenly it flies into the hole. A high-pitched noise ... and then, out pops, back, a small slab of metal. It feels like it could ward off evil. A slender fab fender-slab, if you will." ;
         : pocket "slab" ;
         : destroy "chain" ;
         : set_true "point_chop_drain" ;
         : set_false "think_chop_drain" ;
         : gosub "add_point" ;
         : done ;
      }
      : if (!point_chop_drain) {
         : match "chop _;_ drain" { # again a bug might tell us where to drop the chain even if we haven't found it ??
            : set_integer var="tempint" "13" ;
            : set_false "first_half" ;
            : match "chop _" {
               : set_true "first_half" ;
            }
            : gosub "say_half" ;
            : done ;
         }
      }
   }
   : if (is_carried "buns") {
      : match "x buns" {
         : print {( point_grow_dupes ? "Livelier and brighter than when you first got it." : "Flaky and dry. But weird, when something crumbles from it, it regenerates." )} ;
         : done ;
      }
      : match "_ buns" {
         : print "All you can do is examine the buns. Well, with the parser and with buns as a noun." ;
         : done ;
      }
      : if ((!point_creaky_stove || !is_at "streaky_cove")) {
         : match "bake tons" {
            : print "You have nothing to help you cook here." ;
            : done ;
         }
         : match "bake _;_ tons" { # obscure bug here, 1/2 guess will be spoiled that stove is in cove if we BAKE TONS outside, whether or not stove is there ??
            : set_integer var="tempint" "10" ;
            : set_false "first_half" ;
            : match "bake _" {
               : set_true "first_half" ;
            }
            : gosub "say_half" ;
            : done ;
         }
      }
   }
   : gosub "check_diagnostics" ;
   : gosub "check_meta" ;
   : gosub "check_options" ;

   : match "dig below" {
      : if (bonus_point_dig_below) {
         : print "You already looked forward to what you needed to do." ;
      }
      : collection_modify { collection = "tried_combo_bonus" index -> (0) content -> ("true") } ;
      : print "Narrative text." ;
      : set_true "bonus_point_dig_below" ;
      : gosub "add_bonus" ;
      : done ;
   }
   : if (!bonus_point_dig_below) {
      : match "dig _;_ below" {
         : set_integer var="tempint" "0" ;
         : set_false "first_half" ;
         : match "dig _" {
            : set_true "first_half" ;
         }
         : gosub "say_half_b" ;
         : done ;
      }
   }

   : if (xme_yet) {
      : match "_ widget;_ digit;_ dialed;_ wild" {
         : set_integer var="tempint" {( widget_num )} ;
         : set_false "widget_blurry" ;
         : if (tempint == -1 ) {
            : print "Some weird random negative number. Nothing to do here, period." ;
            : done ;
         }
         : if (tempint < 0) {
            : set_integer var="tempint" {( 0 - tempint )} ;
            : set_true "widget_blurry" ;
         }
         : print "On the widget, you see the number {tempint}." ;
         : if (widget_blurry) {
            : print "The number seems a bit blurry." ;
         } : else_if (tempint == 0) {
            : print "Probably means nothing left to do here." ;
         } : else_if (tempint == 1) {
            : print "Maybe there's nothing constructive to do right now." ;
         }
         : done ;
      }
   }

   : match "x me;x myself;x self" {
      : if (tutorial_0_in_tutorial && !tutorial_2_verbs) {
         : print {( "{xme} is good to do very early on, but for the purposes of the tutorial, there are a couple general information commands first. Try " + ( tutorial_1_about ? "{vm_verbs}" : "{vm_about}" ) + "." )} ;
         : set_true "skip_tutorial_cue" ;
         : done ;
      }
      : if (!xme_yet) {
         : print "You search around your body and notice your phone is gone." ;
         : print "\"Fie! Moan! My phone!\" you cry out. Weird, you're not used to talking like that." ;
         : print "You clutch at various places on your body, and you're surprised to find something very odd indeed turn up." ;
         : print "It's a {i_widget}." ;
      } : else {
         : print "You find nothing else on your person. You still can't locate your phone, but who knows, it may turn up some day. Perhaps when you least expect it." ;
      }
      : set_true "tutorial_3_x_me" ;
      : set_true "xme_yet" ;
      : done ;
   }

   : match "listen _" {
      : print "You hear nothing unusual." ;
      : done ;
   }

   : match "smell _" {
      : print "Nothing smells unusual." ;
      : done ;
   }

   # the 4 below here are point scoring events that need general rejects

   : match "drop _" {
      : set_boolean var="already_flag" {( point_chop_drain )} ;
      : print "{standard_puzzle_check}" ;
   }

   : match "take _" {
      : set_boolean var="already_flag" {( buns_taken )} ;
      : print "{standard_puzzle_check}" ;
   }

   : match "pull _" {
      : set_boolean var="already_flag" {( point_pull_file )} ;
      : print "{standard_puzzle_check}" ;
   }

   : match "push _" {
      : set_boolean var="already_flag" {( point_push_best )} ;
      : print "{standard_puzzle_check}" ;
   }

   : match "leery _;rocky _;steel _;taming _;tool _;tight _" { #obfuscation of non solutions, regular points
      : print "{custom_unknown_verb_error}" ;
      : done ;
   }

   # bonus point obfuscations -- note MAP is taken care of elsewhere

   : match "dig _" { # also an obfuscation of a bonus point
      : print "The archaeology theme suggests digging, but it'll mostly be done implicitly. Mostly." ;
      : done ;
   }

   : match "clock _" { #obfuscation of non solutions, bonus points
      : print "{custom_unknown_verb_error}" ;
      : done ;
   }

}

on_tick {
   : if (!showed_first_note) {
      : print {( "{one_time}{vm_about} will give general game information. {vm_verbs} will describe {this_game}'s stripped-down parser." + (tutorial_0_in_tutorial ? " In fact, typing {vm_about} is the first step of the tutorial." : "" ) )} ;
      : set_true "showed_first_note" ;
      : done ;
   }
   : match "i _" {
      : if (!tutorial_3_x_me && carried() == 0) {
         : print "You aren't holding anything, but you haven't really searched yourself with {xme}." ;
      } : else_if (carried() == 0) {
         : print {( "You " + (carried() == 0 ? "only" : "also" ) + " have the {i_widget}." )} ;
      }
   }
   : if (tutorial_0_in_tutorial) {
      : if (skip_tutorial_cue) {
         : set_false "skip_tutorial_cue" ;
         : done ;
      }
      : if (!tutorial_1_about) {
         : print "{note_cue_tutorial}First, you should type {vm_about} to see general information about {this_game}." ;
      } : else_if (!tutorial_2_verbs) {
         : print "{note_cue_tutorial}Now you've typed {vm_about}, You should type {vm_verbs} next to see basic commands for {this_game}." ;
      } : else_if (!tutorial_3_x_me) {
         : print "{note_cue_tutorial}Now you've seen basic info, you should examine yourself with {xme}." ;
      } : else_if (!tutorial_4_inventory) {
         : print "{note_cue_tutorial}Now you've examined yourself, you should type {vd_i_three} to verify the new item is in your inventory." ;
      } : else_if (!tutorial_5_think) {
         : print "{note_cue_tutorial}Now you've taken inventory, you should type {vd_think} next to recap odd things you've seen." ;
      } : else_if (!tutorial_6_tool_stall) {
         : print "{note_cue_tutorial}Now you've taken inventory, you should figure what to do with the {puz_point_stool_tall}." ;
      } : else_if (!tutorial_7_south_first) {
         : print "{note_cue_tutorial}Now you've removed the stool, you should go {dir_s} to check what's there." ;
      } : else_if (!tutorial_8_leery_owner_1) {
         : print "{note_cue_tutorial}Now you've made it to the tool stall, you may want to ask the eerie loner for someone." ;
      } : else_if (!tutorial_9_north) {
         : print "{note_cue_tutorial}Now you know what you need, you should go back {dir_n}." ;
      } : else_if (!tutorial_10_listen) {
         : print "{note_cue_tutorial}Now you're back in the meadow, try LISTENing." ;
      } : else_if (!tutorial_11_rocky_caves) {
         : print "{note_cue_tutorial}Now you've heard the {puz_point_cocky_raves}, you need to figure what they're cluing." ;
      } : else_if (!tutorial_12_southwest) {
         : print "{note_cue_tutorial}Now you've found the rocky caves, you should explore them to the southwest." ;
      } : else_if (!tutorial_13_smell) {
         : print "{note_cue_tutorial}You need to use one of your senses. There are five." ;
      } : else_if (!tutorial_14_steel_wrench) {
         : print "{note_cue_tutorial}You need to figure out what the real stench might be hiding." ;
      } : else_if (!tutorial_15_northeast) {
         : print "{note_cue_tutorial}Now you've got the steel wrench, you should retreat NORTHEAST." ;
      } : else_if (!tutorial_16_south_twice) {
         : print "{note_cue_tutorial}Now you've got the steel wrench, you should continue {dir_s}." ;
      } : else_if (!tutorial_17_leery_owner_2) {
         : print "{note_cue_tutorial}Now you have something appropriate for the tool stall, you should ask to summon the person in charge. If you forget who that is, {vd_think}." ;
      } : else {
         : print "Oh no! You should be done with the tutorial. That's a small bug I'd like to know about." ;
         : set_false "tutorial_0_in_tutorial" ;
      }
   }
}

on_render {
   : if (drawing_map) {
      : if (has_visited("demo_meadow")) {
         : overlay "m_0_visited" x="81" y="85" ;
         : overlay "m_demo_meadow" x="81" y="85" ;
      }
      : if (has_visited("tool_stall")) {
         : overlay "m_0_visited" x="81" y="106" ;
         : overlay "m_tool_stall" x="81" y="106" ;
      }
      : if (has_visited("app_mall")) {
         : overlay "m_0_visited" x="81" y="127" ;
         : overlay "m_app_mall" x="81" y="127" ;
      }
      : if (has_visited("rocky_caves")) {
         : overlay "m_0_visited" x="41" y="127" ;
         : overlay "m_rocky_caves" x="41" y="127" ;
      }
      : if (has_visited("newbies_boonies")) {
         : overlay "m_0_visited" x="41" y="85" ;
         : overlay "m_newbies_boonies" x="41" y="85" ;
      }
      : if (has_visited("backin_cabin")) {
         : overlay "m_0_visited" x="121" y="85" ;
         : overlay "m_backin_cabin" x="121" y="85" ;
      }
      : if (has_visited("moldin_dolmen")) {
         : overlay "m_0_visited" x="41" y="64" ;
         : overlay "m_moldin_dolmen" x="41" y="64" ;
      }
      : if (has_visited("collation_location")) {
         : overlay "m_0_visited" x="121" y="64" ;
         : overlay "m_collation_location" x="121" y="64" ;
      }
      : if (has_visited("chattin_em_plain")) {
         : overlay "m_0_visited" x="41" y="106" ;
         : overlay "m_chattin_em_plain" x="41" y="106" ;
      }
      : if (has_visited("streaky_cove")) {
         : overlay "m_0_visited" x="121" y="106" ;
         : overlay "m_streaky_cove" x="121" y="106" ;
      }
      : if (has_visited("cache_shack")) {
         : overlay "m_0_visited" x="1" y="85" ;
         : overlay "m_cache_shack" x="1" y="85" ;
      }
      : if (has_visited("yankin_canyon")) {
         : overlay "m_0_visited" x="161" y="85" ;
         : overlay "m_yankin_canyon" x="161" y="106" ;
      }
      : if (has_visited("outer_tower")) {
         : overlay "m_0_visited" x="81" y="64" ;
         : overlay "m_outer_tower" x="81" y="64" ;
      }
      : if (has_visited("tenser_center")) {
         : overlay "m_0_visited" x="81" y="43" ;
         : overlay "m_tenser_center" x="81" y="43" ;
      }
      : if (has_visited("gnawing_awning")) {
         : overlay "m_0_visited" x="41" y="43" ;
         : overlay "m_gnawing_awning" x="41" y="43" ;
      }
      : if (has_visited("ailer_lair")) {
         : overlay "m_0_visited" x="41" y="22" ;
         : overlay "m_ailer_lair" x="41" y="22" ;
      }
      : if (has_visited("taller_altar")) {
         : overlay "m_0_visited" x="121" y="43" ;
         : overlay "m_taller_altar" x="121" y="43" ;
      }
      : if (has_visited("jeerin_region")) {
         : overlay "m_0_visited" x="121" y="22" ;
         : overlay "m_jeerin_region" x="121" y="22" ;
      }
      : if (has_visited("oopster_stupor")) {
         : overlay "m_0_visited" x="81" y="22" ;
         : overlay "m_oopster_stupor" x="81" y="22" ;
      }
      : if (has_visited("foldin_gate")) {
         : overlay "m_0_visited" x="81" y="1" ;
         : overlay "m_foldin_gate" x="81" y="1" ;
      }
      : done ;
   }
   : if (!show_overlay) {
      : done ;
   }
   #alphabetize main scenery
   : if (is_at "cache_shack" && !buns_taken) {
      : overlay "s_cache_shack_buns" x="97" y="15" ;
   }
   : if (is_at "collation_location") {
      : if (!point_grow_dupes) {
         : overlay "s_collation_location_sad" x="33" y="0" ;
         : overlay "s_collation_location_sad" x="55" y="0" ;
         : overlay "s_collation_location_sad" x="179" y="0" ;
         : overlay "s_collation_location_sad" x="201" y="0" ;
      } : else {
         : overlay "s_collation_location_happy" x="22" y="0" ;
         : overlay "s_collation_location_happy" x="44" y="0" ;
         : overlay "s_collation_location_happy" x="66" y="0" ;
         : overlay "s_collation_location_happy" x="88" y="0" ;
         : overlay "s_collation_location_happy" x="146" y="0" ;
         : overlay "s_collation_location_happy" x="168" y="0" ;
         : overlay "s_collation_location_happy" x="190" y="0" ;
         : overlay "s_collation_location_happy" x="212" y="0" ;
      }
   }
   : if (is_at "demo_meadow" && !point_tool_stall) {
      : overlay "s_meadow_stool" x="164" y="0" ;
   }
   : if (is_at "demo_meadow" && (!point_rocky_caves && listen_demo_meadow)) {
      : overlay "s_meadow_haha" x="2" y="2" ;
   }
   : if (is_at "demo_meadow" && flaming_towers_present) {
      : overlay "s_meadow_flaming_towers" x="0" y="0" ;
      : overlay "s_meadow_flaming_towers" x="82" y="0" ;
      : overlay "s_meadow_flaming_towers" x="164" y="0" ;
   }
   : if (is_at "rocky_caves") {
      : if (smell_rocky_caves) {
         : overlay "s_rocky_stink_lines" x="40" y="3" ;
         : overlay "s_rocky_stink_lines" x="180" y="3" ;
      }
   }
   : if (is_at "newbies_boonies") {
      : if (!point_push_best) {
         : overlay "s_newbies_boonies_bush_pest" x="83" y="20" ;
      } : else_if (newbies_cutscene == 0) {
         : overlay "s_newbies_boonies_bush_fall_1" x="102" y="0" ;
      } : else_if (newbies_cutscene == 1) {
         : overlay "s_newbies_boonies_bush_fall_2" x="112" y="19" ;
      }
   }
   : if (is_at "streaky_cove") {
      : if (point_bake_tons) {
         : overlay "s_streaky_cove_tree_cove" x="160" y="0" ;
         : if (point_key_trove) {
            : overlay "s_streaky_cove_key_trove" x="160" y="0" ;
         }
      }
      : else_if (point_creaky_stove) {
         : overlay "s_streaky_cove_creaky_stove" x="190" y="0" ;
      }
   }
   : if (is_at "tool_stall") {
      : if (!point_leery_owner) {
         : overlay "s_tool_eerie_loner" x="20" y="6" ;
      } : else {
         : overlay "s_tool_right_tools" x="210" y="0" ;
      }
   }
   : if (is_at "tenser_center") {
      : if (!point_minister_south) {
         : overlay "s_tenser_center_sinister_mouth" x="0" y="0" ;
      } : else {
         : overlay "s_tenser_center_u_r_here" x="170" y="0" ;
      }
   }
}

