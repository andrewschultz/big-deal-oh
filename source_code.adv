         : overlay "m_ailer_lair" x="41" y="43" ;
         : overlay "m_1_vertical" x="56" y="35" ;
      }
      : if (is_at "ailer_lair") {
         : overlay "m_you_are_here" x="41" y="43" ;
      }
      : if (has_visited("tenser_center")) {
         : overlay "m_0_visited" x="81" y="43" ;
         : overlay "m_tenser_center" x="81" y="43" ;
         : if (point_minister_south) {
            : overlay "m_1_horizontal" x="113" y="49" ;
            : overlay "m_1_horizontal" x="73" y="49" ;
            : overlay "m_1_vertical" x="96" y="35" ;
         }
      }
      : if (is_at "tenser_center") {
         : overlay "m_you_are_here" x="81" y="43" ;
      }
      : if (has_visited("jeerin_region")) {
         : overlay "m_0_visited" x="121" y="43" ;
         : overlay "m_jeerin_region" x="121" y="43" ;
         : overlay "m_1_vertical" x="136" y="35" ;
      }
      : if (is_at "jeerin_region") {
         : overlay "m_you_are_here" x="121" y="43" ;
      }
      : if (has_visited("gnawing_awning")) {
         : overlay "m_0_visited" x="41" y="22" ;
         : overlay "m_gnawing_awning" x="41" y="22" ;
      }
      : if (is_at "gnawing_awning") {
         : overlay "m_you_are_here" x="41" y="22" ;
      }
      : if (has_visited("oopster_stupor")) {
         : overlay "m_0_visited" x="81" y="22" ;
         : overlay "m_oopster_stupor" x="81" y="22" ;
         : if (point_written_specs && point_power_torch && point_cool_plan) {
            : overlay "m_1_vertical" x="96" y="14" ;
         }
      }
      : if (is_at "oopster_stupor") {
         : overlay "m_you_are_here" x="81" y="22" ;
      }
      : if (has_visited("taller_altar")) {
         : overlay "m_0_visited" x="121" y="22" ;
         : overlay "m_taller_altar" x="121" y="22" ;
      }
      : if (is_at "taller_altar") {
         : overlay "m_you_are_here" x="121" y="22" ;
      }
      : if (has_visited("foldin_gate")) {
