start_at = "demo_meadow"
start_theme = my_theme

#cch.py makes sure of things

game_information {
   game_name                    = Big Deal, Oh!
   game_version                 = 1.0.0
   game_shortname               = BDO
   written_by                   = Andrew Schultz
   uuid                         = b3c1f8e2-5d4a-4f9b-8c3d-2a7e5f6a9b1c
   year_of_release              = 2026
   copyright_message            = Free to distribute, voluntary payments welcome
   short_synopsis               = TALP 2026 entry
}


## Defines locations in the world

strings {
   # top level
   this_game : string "<Big Deal, Oh!<#f80>>" ;
   l_qt : string "<Quirky Test<#0f0>>[http://andrewschultz.itch.io/us-too]" ;
   l_talp : string "<TALP<#0f0>>[https://itch.io/jam/talp]" ;
   l_talp_2026 : string "<TALP 2026<#0f0>>[https://itch.io/jam/talp2026]" ;

   # basics
   my_score : string "{score}/{max_score}" ;
   custom_unknown_verb_error : dynamic_string {( "Nothing special happens. You can use {vm_verbs} for a general overview of standard verbs." )} ;
   exits_err : dynamic_string {( "Can't go that way." )} ;

   # parser stuff
   nospecial_custom : string "You see no specific item like that--time limits mean I couldn't implement noncritical things. To examine a room, <LOOK<#0f0>>. Note that the parser may not recognize adjectives as synonyms, so using a noun works best." ;
   yn_or_12_or_14 : dynamic_string {( (verb_is "save" || verb_is "load") ? "Please choose from 1 to 4." : in_number_choice ? "Please choose 1 or 2." : "Please choose YES/Y or NO/N." )}

   # noting stuff
   one_time : string "<ONE-TIME NOTE: <#f0f>>" ;
   key_enter : string "the <ENTER<#f88>>/<RETURN<#f88>> key" ;
   note_cue_tutorial : string "<TUTORIAL CUE:<#f0f>> " ;

   # sense verbs
   v_listen : string "<LISTEN<#0f0>>" ;
   v_listen_hear : string "<LISTEN<#0f0>> or <HEAR<#0f0>>" ;

   # diagnostic verbs
   vd_i : string "<I<#f80>>" ;
   vd_inv : string "<INV<#f80>>" ;
   vd_i_long : string "<INVENTORY<#f80>>" ;
   vd_i_three : string "{vd_i}/{vd_inv}/{vd_i_long}" ;
   vd_score : string "<SCORE<#f80>>" ;
   vd_think : string "<THINK<#f80>>" ;

   # meta-verbs
   vm_about : string "<ABOUT<#f80>>" ;
   vm_credits : string "<CREDITS<#f80>>" ;
   vm_diag : string "<DIAG<#f80>>" ;
   vm_history : string "<HISTORY<#f80>>" ;
   vm_meta : string "<META<#f80>>" ;
   vm_options : string "<OPTIONS<#f80>>" ;
   vm_verbs : string "<VERBS<#f80>>" ;

   # top-level meta-commands
   vs_quit : string "<QUIT<#f80>>" ;
   vs_restart : string "<RESTART<#f80>>" ;
   vs_tss : string "<TSTART<#f80>> and <TSTOP<#f80>>" ;

   # standard top level stuff
   xme : string "<X ME<#0f0>>" ;

   # room(s)
   loc_demo_meadow : string "Here in the Demo Meadow {meadow_status}.\n{meadow_passages}." ;
   meadow_status : dynamic_string {( point_rocky_caves ? "it's quiet again after you got rid of the cocky raves" : listen_demo_meadow ? "you hear some {puz_point_cocky_raves_l}" : "it feels relatively quiet, and yet, not as quiet and peaceful as it should be" )} ;
   meadow_passages: dynamic_string {( point_taming_flowers ? "You've found passages north, west and east that lead away. You probably don't need to go back south or in" : (!point_rocky_caves && !point_tool_stall) ? "You haven't found anywhere to go from here yet" : !point_rocky_caves ? "You can go south to the tool stall" : !point_tool_stall ? "You can go down to the rocky caves" : "You can go south to the tool stall and down to the rocky caves" )} ;
   header_demo_meadow : string "<Demo Meadow<#ff0>>" ;

   loc_rocky_caves : dynamic_string {( point_steel_wrench ? "The rocky caves are just caves now. You're used to the smell, but you have nothing more to do here." : smell_rocky_caves ? "The {puz_point_real_stench} is almost overpowering. Could any good possibly come from it?" : "It's damp and dark in here. Yet the dampness and darkness reveal little. Perhaps another sense..." )} ;
   header_rocky_caves : string "<Rocky Caves<#ff0>>" ;

   loc_tool_stall : dynamic_string {( "You're in a tool stall. The exit is back north. Nearby you see " + (point_leery_owner ? "the owner, no longer leery" : "an {puz_point_eerie_loner}") + (point_tight_rules || !point_leery_owner ? "" : ". That sign indicates the {puz_point_right_tools} are available, but you haven't figured how to ask for them yet") + "." )} ;
   header_tool_stall : string "<Tool Stall<#ff0>>" ;

   # puzzle text
   puz_point_cocky_raves : string "<Cocky raves<#f80>>" ;
   puz_point_cocky_raves_l : string "<cocky raves<#f80>>" ;
   puz_point_eerie_loner : string "<eerie loner<#f80>>" ;
   puz_point_real_stench : string "<real stench<#f80>>" ;
   puz_point_stool_tall : string "<stool (tall)<#f80>>" ;
   puz_point_right_tools : string "<right tools<#f80>>" ;
   puz_point_flaming_towers : string "<flaming towers<#f80>>" ;

   # think text
   tht_leery_owner : string "<LEERY OWNER<#f80>>" ;
   already_got_check : dynamic_string {( already_got_command ? " Though you already got the full command, which you can revisit with {vd_think}." : "" )} ;
   for_bonus : dynamic_string {( half_bonus ? " for a bonus point" : "" )} ;

   #conditional location text
   here_demo_meadow : dynamic_string {( is_at "demo_meadow" ? "here" : "in the demo meadow" )} ;
   here_rocky_caves : dynamic_string {( is_at "rocky_caves" ? "here" : "in the rocky caves" )} ;
   here_tool_stall : dynamic_string {( is_at "tool_stall" ? "here" : "in the tool stall" )} ;

   # Interpretive
   noguess : string "<(unknown)<#888>>" ;
   noguess_c_1 : dynamic_string {( unneeded_half ? "<(unneeded)<#888>>" : "<(unknown)<#888>>" )} ;
   think_here_also : dynamic_string {( think_text_yet ? "Also, here" : "Here" )} ;
   number_as_word : dynamic_string {( collection_get { collection -> ("num_to_word") index -> ( commands_figured ) } )} ;

   # item(s)
   i_widget : string "<wild digit-dialed widget<#c8c>>" ;
}

integers {
   score : integer "0" ;
   max_score : integer "6" ;

   bonus_score : integer "0" ;
   max_bonus_score : integer "1" ;

   # hinting. Magic numbers are 1 = do later, 0 = done, -1 = nothing to do
   # note items are listed in backwards order of how we do things
   widget_num : dynamic_integer {( is_at "demo_meadow" ? widget_demo_meadow : is_at "tool_stall" ? widget_tool_stall : is_at "rocky_caves" ? widget_rocky_caves : -1 )} ;
   widget_rocky_caves : dynamic_integer {( point_steel_wrench ? 0 : smell_rocky_caves ? 56 : 1 )} ;
   widget_tool_stall : dynamic_integer {( point_tight_rules ? 0 : point_leery_owner ? 55 : point_steel_wrench ? 55 : -55 )} ;
   widget_demo_meadow : dynamic_integer {( point_taming_flowers ? 0 : placed_flaming_towers ? 67 : cocky_raves_present ? 55 : (!point_tool_stall) ? 45 : 1 )} ;

   #auxiliary
   tempint : integer "0" ;
   counter : integer "0" ;

   # for half THINK
   part_core_score : dynamic_integer {( ((collection_get{ collection -> ("got_first_core") index -> ( counter ) } == "true") ? 1 : 0) + ((collection_get{ collection -> ("got_second_core") index -> ( counter ) } == "true") ? 2 : 0) )} ; # this is a really bad hack, but I couldn't find a concise way to code things. Maybe I could use a dynamic boolean.
   part_bonus_score : dynamic_integer {( ((collection_get{ collection -> ("got_first_bonus") index -> ( counter ) } == "true") ? 1 : 0) + ((collection_get{ collection -> ("got_second_bonus") index -> ( counter ) } == "true") ? 2 : 0) )} ; # this is a really bad hack, but I couldn't find a concise way to code things. Maybe I could use a dynamic boolean.

   commands_figured : dynamic_integer {( (think_leery_owner ? 1 : 0) )} ;

}

