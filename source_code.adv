start_at = "demo_meadow"
start_theme = my_theme

#cch.py makes sure of things

game_information {
   game_name                    = Big Deal, Oh!
   game_version                 = 1.0.0
   game_shortname               = BDO
   written_by                   = Andrew Schultz
   uuid                         = b3c1f8e2-5d4a-4f9b-8c3d-2a7e5f6a9b1c
   year_of_release              = 2026
   copyright_message            = Free to distribute, voluntary payments welcome
   short_synopsis               = Wordplay game with tutorial written for TALP 2026
}

game_settings {
   rewind_enabled = true
   rollback_enabled = true
}

## Defines locations in the world

strings {
   # top level
   this_game : string "<Big Deal, Oh!<#f80>>" ;
   l_qt : string "<Quirky Test<#0f0>>[http://andrewschultz.itch.io/us-too]" ;
   l_talp : string "<TALP<#0f0>>[https://itch.io/jam/talp]" ;
   l_talp_2025 : string "<TALP 2025<#0f0>>[https://itch.io/jam/talp2025]" ;
   l_talp_2026 : string "<TALP 2026<#0f0>>[https://itch.io/jam/talp2026]" ;

   l_tester_gg : string "<Gianluca Girelli<#0f0>>[https://g0blin.itch.io/]" ;
   l_tester_ag : string "<Allyson Gray<#0f0>>[https://zophobas-morio.itch.io/]" ;
   l_tester_wc : string "<Wade Clarke<#0f0>>[https://wade-clarke.itch.io/]" ;

   # basics
   my_score : dynamic_string {( tutorial_0_in_tutorial ? "Tutorial progress: {tutorial_score}/{max_tutorial_score}" : "{score}{plus_in_header}/{max_score}" )} ;
   custom_unknown_verb_error : dynamic_string {( "Nothing special happens. You can use {vm_verbs} for a general overview of standard verbs." )} ;

   only_up : string "You can only go back up" ;
   only_west : string "You can only go back west" ;
   only_east : string "You can only go back east" ;
   only_north : string "You can only go back north" ;
   only_south : string "You can only go back south" ;
   only_north_south : string "You can go north and south, but there are no more secret passages to open" ;
   only_four : string "You can only go the four basic directions here." ;
   exits_err : dynamic_string {(
      is_at "demo_meadow" ? "{this_game} uses the four basic directions, along with up and down." :
      is_at "rocky_caves" ? "{only_up}." :
      is_at "tool_stall" ? ( point_tight_rules ? "{only_north_south}." : "You can only go north here, for now" ) :
      is_at "app_mall" ? "{only_north}." :
      is_at "chattin_em_plain" ? "{only_north}." :
      is_at "streaky_cove" ? "{only_north}." :
      is_at "cache_shack" ? "{only_east}." :
      is_at "newbies_boonies" ? ( point_push_best ? "{only_four}" : "{only_east} for now." ) :
      is_at "backin_cabin" ? "{only_four}." :
      is_at "yankin_canyon" ? "{only_west}." :
      is_at "moldin_dolmen" ? "{only_south}." :
      is_at "outer_tower" ? ( key_used ? "{only_north_south}." : "{only_south}, at least until you find a way through the tower." ) :
      is_at "collation_location" ? "{only_south}." :
      is_at "ailer_lair" ? "You can only go north or back east." :
      is_at "tenser_center" ? ( point_minister_south ? "{only_four}" : "{only_south}." ) :
      is_at "jeerin_region" ? "You can only go north or back west." :
      is_at "gnawing_awning" ? "{only_south}." :
      is_at "oopster_stupor" ? ( point_hard_maze ? "{only_north_south}." : "{only_south}." ) :
      is_at "taller_altar" ? "{only_south}." :
      is_at "foldin_gate" ? ( bonus_point_golden_fate ? "{only_north_south}." : "{only_south}." ) : "You can't go that way."
   )} ;

   # parser stuff
   nospecial_custom : string "You see no specific item like that--time limits mean I couldn't implement noncritical things. To examine a room, <LOOK<#0f0>>. Note that the parser may not recognize adjectives as synonyms, so using a noun works best." ;
   yn_or_12_or_14 : dynamic_string {( (verb_is "save" || verb_is "load") ? "Please choose from 1 to 4." : in_number_choice ? "Please choose 1 or 2." : "Please choose YES/Y or NO/N." )}
   standard_puzzle_check : dynamic_string {( "That's a standard verb often used for parsers, but " + (already_flag ? "you already found where to use it" : "you haven't found the one place to use it in this game yet") + "." )} ;

   # noting stuff
   one_time : string "<ONE-TIME NOTE: <#f0f>>" ;
   key_enter : string "the <ENTER<#f88>>/<RETURN<#f88>> key" ;
   note_cue_tutorial : string "<TUTORIAL CUE:<#f0f>> " ;

   # directions
   dir_n : string "<NORTH<#f80>>" ;
   dir_s : string "<SOUTH<#f80>>" ;
   dir_e : string "<EAST<#f80>>" ;
   dir_w : string "<WEST<#f80>>" ;
   dir_u : string "<UP<#f80>>" ;
   dir_d : string "<DOWN<#f80>>" ;

   # options
   yn : string "<YES<#f88>>/<Y<#f88>> or <NO<#f88>>/<N<#f88>>" ;
   optt_block_on : string "<WALL EH<#88f>> (on)" ;
   optt_block_off : string "<ALL WAY<#88f>> (off)" ;
   optt_block : string "{optt_block_on} and {optt_block_off}" ;
   optt_ch : string "<CH<#88f>> or <COLORHINT<#88f>>" ;
   optt_notify : string "<NOTIFY<#88f>>" ;

   # sense verbs
   v_feel : string "<FEEL<#0f0>>" ;
   v_listen : string "<LISTEN<#0f0>>" ;
   v_listen_hear : string "<LISTEN<#0f0>> or <HEAR<#0f0>>" ;
   v_smell : string "<SMELL<#0f0>>" ;

   # diagnostic verbs
   vd_hint : string "<HINT<#f80>>/<HINTS<#f80>>" ;
   vd_i : string "<I<#f80>>" ;
   vd_inv : string "<INV<#f80>>" ;
   vd_i_long : string "<INVENTORY<#f80>>" ;
   vd_i_three : string "{vd_i}/{vd_inv}/{vd_i_long}" ;
   vd_map : string "{vd_i}/{vd_inv}/{vd_i_long}" ;
   vd_score : string "<SCORE<#f80>>" ;
   vd_think : string "<THINK<#f80>>" ;

   # meta-verbs
   vm_about : string "<ABOUT<#f80>>" ;
   vm_credits : string "<CREDITS<#f80>>" ;
   vm_diag : string "<DIAG<#f80>>" ;
   vm_graphics : string "<GR<#f80>>" ;
   vm_history : string "<HISTORY<#f80>>" ;
   vm_meta : string "<META<#f80>>" ;
   vm_options : string "<OPTIONS<#f80>>" ;
   vm_verbs : string "<VERBS<#f80>>" ;

   # top-level meta-commands
   vs_quit : string "<QUIT<#f80>>" ;
   vs_restart : string "<RESTART<#f80>>" ;
   vs_tss : string "<TSTART<#f80>> and <TSTOP<#f80>>" ;

   # standard top level stuff
   xme : string "<X ME<#0f0>>" ;

   # room(s)

   loc_ailer_lair : dynamic_string {( (point_best_notes ? "It's quiet here now." : point_sail_tide ? "Some {puz_point_nest_boats} have arrived here. The babblers and blabbers look at you impatiently. They'd like to just give you a reward for rescuing them, they've changed their kvetching to how you've given them no clue what you like or need." : "You are in the ailer lair. Babblers and blabbers sit here, one side kvetching about things that might go wrong, the other side kvetching about things they think went wrong but are actually okay. You see no way to mediate this civil war on your own, but you also see no danger of being sucked into it." ) + (has_visited "foldin_gate" ? " The changing tide has brought in some {puz_point_kelp_hard}." : "") + "\nYou can go north and west." )} ;
   header_ailer_lair : string "<Ailer Lair<#ff0>>" ;

   loc_app_mall : dynamic_string {( "Here in the mall they're offering apps--well, you ask the nice jock clerk at the front desk for a code or whatever. Apparently they need to make sure you're sane enough, or something. " + (bonus_point_map_all ? "But you got the one you needed." : "Which app might be right for you?" ) + "\nA jock clerk mans the vending area.\nYou can go back north." + (!bonus_point_clock_jerk ? "\nAnd yet the atmosphere isn't quite right. You can probably leave " + (bonus_point_map_all ? "now" : "once") + " you've got what you want, but then there always seems to be more to tidy up." : "" ) )} ;
   header_app_mall : string "<App Mall<#ff0>>" ;

   loc_backin_cabin : dynamic_string {( "Here by the backin' cabin, " + (point_pull_file ? "the pile has been cleaned significantly and is nowhere near as full, and now you see three passages through the cabin. You can go in all four directions." : "you can only go back west for now. A {puz_point_full_pile} spills from the backin' cabin. Whoever put it there obviously was trying to help you, but they may have tried too hard." ) )} ;
   header_backin_cabin : string "<Backin' Cabin<#ff0>>" ;

   loc_cache_shack : string "You are in a cache shack, filled with various random stuff that seems either useless or far too heavy to lift. You can go back east." ;
   header_cache_shack : string "<Cache Shack<#ff0>>" ;

   loc_chattin_em_plain : string "You are in the {puz_point_chattin_em_plain}. The only exit is north." ;
   header_chattin_em_plain : string "<Chattin' 'Em Plain<#ff0>>" ;

   loc_collation_location : dynamic_string {( "You are in a collation location. The only exit is south. {puz_point_dough_groups_u} sit here " + (!point_grow_dupes ? "looking lonely" : "happy together") + "." )} ;
   header_cl : string "<Collation Location<#ff0>>" ;

   loc_demo_meadow : string "Here in the Demo Meadow {meadow_status}{meadow_stool}.\n{meadow_passages}." ;
   meadow_status : dynamic_string {( point_taming_flowers ? "it's peaceful again with the flaming towers subdued" : placed_flaming_towers ? "the flaming towers have interrupted the tranquility" : point_tight_rules ? "you see what the eerie loner was worried about" : point_rocky_caves ? "it's quiet again after you got rid of the cocky raves" : listen_demo_meadow ? "you hear some {puz_point_cocky_raves_l}" : "it feels relatively quiet, and yet, not as quiet and peaceful as it should be" )} ;
   meadow_stool : dynamic_string {( point_tool_stall ? "" : ". A {puz_point_stool_tall} sits inexplicably here" )} ;
   header_demo_meadow : string "<Demo Meadow<#ff0>>" ;
   meadow_passages: dynamic_string {( point_taming_flowers ? "You've found passages {dir_n}, {dir_e} and {dir_w} that lead away. You probably don't need to go back {dir_s} or in" : (!point_rocky_caves && !point_tool_stall) ? "You haven't found anywhere to go from here yet" : !point_rocky_caves ? "You can go {dir_s} to the tool stall" : !point_tool_stall ? "You can go {dir_d} to the rocky caves" : "You can go {dir_s} to the tool stall and {dir_d} to the rocky caves" )} ;

   loc_foldin_gate : dynamic_string {( "A big foldin' gate is to the north. It is " + (bonus_point_golden_fate ? "open, with goldness gleaming behind it" : "closed" ) + ". There's always passage south. Also, a {puz_point_gate_brook} runs by the gate." )} ;
   header_foldin_gate : string "<Foldin' Gate<#ff0>>" ;

   loc_gnawing_awning : string "A gnawing awning blocks passage every way except back south. It has a {puz_point_gold_side}, a {puz_point_brick_side}, and a {puz_point_tail_side}.{awning_sides}" ;
   awning_sides: dynamic_string {( point_sold_guide ? ("\nYou've currently found what to do with the gold side" + awning_gold_sub + ".") :
      point_sick_bride ? ( "\nYou've currently found what to do with the brick side" + (point_sail_tide ? " and the tail side" : "") + ".") :
	  point_sail_tide ? "\nYou've currently found what to do with the tail side." : "\nYou haven't uncovered any of the awning's mysteries yet."
   )} ;
   awning_gold_sub : dynamic_string {( !point_sick_bride ? ( point_sail_tide ? " and the tail side" : "" ) :
      ( point_sail_tide ? ", the brick side and the tail side" : " and the brick side" )
   )} ;
   header_gnawing_awning : string "<Gnawing Awning<#ff0>>" ;

   loc_jeerin_region : dynamic_string {( "Here in the jeerin' region, {puz_point_spittin_wrecks} find very clever ways to prove that everyone's beneath them. " + ( !point_written_specs ? "Yet they seem pretty smart. Perhaps they might help you" : "Maybe even you, but at least they helped you.") + (!kelp_placed ? "" : point_help_card ? " The kelp (hard) still lies here, but you already found something from it." : " The kelp (hard) has washed in from sea. Perhaps it's gotten something tangled in it.") + " You can exit north or west." )} ;
   header_jeerin_region : string "<Jeerin' Region<#ff0>>" ;

   loc_moldin_dolmen : dynamic_string {( "You are by a " + (key_duplicated ? "no longer " : "") + "glowing moldin' dolmen." + (!point_formed_wax ? " A fax machine from--well, for all you know, a wormhole to a new dimension--spits out a fax every few minutes. Weird to have it here! Perhaps you should inspect things." : "") + "\nThe only exit is south." )} ;
   header_moldin_dolmen : string "<Moldin' Dolmen<#ff0>>" ;

   loc_newbies_boonies : dynamic_string {( "Here in the newbies' boonies you can " + (point_push_best ? "go in all four directions with the {puz_point_bush_pest} gone." : "only go back south for now. There's a {puz_point_bush_pest} dancing around that seems to pop up in the latest direction you're considering going. Well, except back east." ) )} ;
   header_newbies_boonies : string "<Newbies' Boonies<#ff0>>" ;

   loc_oopster_stupor : dynamic_string {( has_visited("foldin_gate") ? "The path north is clear now you passed and destroyed the hard maze. You can go south, too." : point_hard_maze ? "The hard maze is ahead to the north, and the tenser center is back to the south." : "Oh no! There's a {puz_point_marred_haze} ahead to the north! You haven't stepped in it, but its fogginess still affects you. Whether or not oopster is a word, you're very much in a stupor and doing minor things that make you say oops. Thankfully you're still aware of passage back south." )} ;
   header_oopster_stupor : dynamic_string {( point_hard_maze ? "<Chirp Perch<#ff0>>" : "<Oopster Stupor<#ff0>>" )} ;

   loc_outer_tower : dynamic_string {( key_used ? ("The tower leads north/south now you've opened it." + (porch_in_tower && !point_power_torch ? " You also found a {puz_point_tower_porch}." : "" ) ) : "Here at the outer tower, barbed wire stretches all around. It looks like you could maybe eventually unlock the tower to go north, though, since it has a weird looking keyhole in it. It looks like you'll want to, because the grass really IS greener on the other side! Or maybe you'll need to prep by going back south first." )} ;
   header_outer_tower : string "<Outer Tower<#ff0>>" ;

   loc_rocky_caves : dynamic_string {( (point_steel_wrench ? "The rocky caves are just caves now. You're used to the smell, but you have nothing more to do here." : smell_rocky_caves ? "The {puz_point_real_stench} is almost overpowering. Could any good possibly come from it?" : "It's damp and dark in here. Yet the dampness and darkness reveal little. Perhaps another sense...") + "\nThere's a sunshine-shun sign here, probably just to reiterate the caves are too dark to explore deeply." )} ;
   header_rocky_caves : string "<Rocky Caves<#ff0>>" ;

   loc_sappage_passage : string "A {puz_point_rumbling_fist} has you pinned down. It's rumbling slowly towards you! You're so paralyzed with fear, you can't even focus on whether \"sappage\" is a real word or not, or whether it deserves to be. How to get out of this fix?" ;
   header_sappage_passage : string "<Sappage Passage<#ff0>>" ;

   loc_streaky_cove: dynamic_string {( "You are in a {puz_point_streaky_cove}. " + (point_key_trove ? "You discovered a key trove out back." : point_bake_tons ? "You discovered a {puz_point_tree_cove} once you blew up the stove." : point_creaky_stove ? "You discovered a creaky stove in the greyness of the right wall." : "The greyness of the right wall is a stark contrast to the colorful left side. What could be there?") + "\nThe only exit is north." )} ;
   header_streaky_cove: string "<Streaky Cove<#ff0>>" ;

   loc_taller_altar : dynamic_string {( "Here by the taller altar you see " + ( point_cool_plan ? "nothing much any more. You're probably done here." : !point_penny_mounds ? "{puz_point_many_pounds}, both in the animal cage sense, on the left, and huge cartoon trap sense, on the right. Surely they can be repurposed!" : "The bride's {puz_point_pool_clan}. They're waiting for you to ask for the right favor before you move on." ) + "\nThe only exit is south." )} ;
   header_taller_altar : string "<Taller Altar<#ff0>>" ;

   loc_tenser_center : dynamic_string {( (point_minister_south ? "I guess this could be the intenser incenter if you want, now that you must be close to your goal, as long as you don't mind thumbing your nose at a geometry textbook. You can exit in all four directions with the sinister mouth gone, though you probably don't need to go back south." : "You are in the tenser center. A {puz_point_sinister_mouth} blocks passage further! You can only go south right now." ) )} ;
   header_tenser_center : string "<Tenser Center<#ff0>>" ;

   loc_tool_stall : dynamic_string {( "You're in a tool stall. The exit is back {dir_n}. Nearby you see " + (point_leery_owner ? "the owner, no longer leery" : "an {puz_point_eerie_loner}") + (point_tight_rules || !point_leery_owner ? "" : ". That sign indicates the {puz_point_right_tools} are available, but you haven't figured how to ask for them yet") + "." + (point_tight_rules ? "\nThe owner also showed you a passage to the south." : "") )} ;
   header_tool_stall : string "<Tool Stall<#ff0>>" ;

   loc_yankin_canyon : string "Here in the yankin' canyon, there's a hole which occasionally, well, yanks debris into it. As it does so, there are small whirring and slicing noises. The only exit is back west." ;
   header_yankin_canyon : string "<Yankin' Canyon<#ff0>>" ;

   # puzzle text (core) (alphabetize)

   puz_point_bush_pest        : dynamic_string {( opt_color_coding ? "<bush pest<#f80>>" : "bush pest" )} ;                 # 06
   puz_point_brick_side       : dynamic_string {( opt_color_coding ? "<brick side<#f80>>" : "brick side" )} ;               # 20
   puz_point_chattin_em_plain : dynamic_string {( opt_color_coding ? "<chattin 'em plain<#f80>>" : "chattin 'em plain" )} ; # 12
   puz_point_cocky_raves_u    : dynamic_string {( opt_color_coding ? "<Cocky raves<#f80>>" : "Cocky raves" )} ;             # 00
   puz_point_cocky_raves_l    : dynamic_string {( opt_color_coding ? "<cocky raves<#f80>>" : "cocky raves" )} ;             # 00
   puz_point_dodging_lock_l   : dynamic_string {( opt_color_coding ? "<dodging lock<#f80>>" : "dodging lock" )} ;           # 14
   puz_point_dodging_lock_u   : dynamic_string {( opt_color_coding ? "<DODGING LOCK<#f80>>" : "DODGING LOCK" )} ;           # 14
   puz_point_dough_groups_l   : dynamic_string {( opt_color_coding ? "<dough groups<#f80>>" : "dough groups" )} ;           # 08
   puz_point_dough_groups_u   : dynamic_string {( opt_color_coding ? "<Dough groups<#f80>>" : "Dough groups" )} ;           # 08
   puz_point_drop_chain       : dynamic_string {( opt_color_coding ? "<drop chain<#f80>>" : "drop chain" )} ;               # 13
   puz_point_eerie_loner      : dynamic_string {( opt_color_coding ? "<eerie loner<#f80>>" : "eerie loner" )} ;             # 03
   puz_point_flaming_towers   : dynamic_string {( opt_color_coding ? "<flaming towers<#f80>>" : "flaming towers" )} ;       # 05
   puz_point_full_pile        : dynamic_string {( opt_color_coding ? "<full pile<#f80>>" : "full pile" )} ;                 # 07
   puz_point_rumbling_fist    : dynamic_string {( opt_color_coding ? "<rumbling fist<#f80>>" : "rumbling fist" )} ;         # 26
   puz_point_gate_brook       : dynamic_string {( opt_color_coding ? "<gate brook<#f80>>" : "gate brook" )} ;               # 28
   puz_point_gold_side        : dynamic_string {( opt_color_coding ? "<gold side<#f80>>" : "gold side" )} ;                 # 21
   puz_point_kelp_hard        : dynamic_string {( opt_color_coding ? "<kelp (hard)<#f80>>" : "kelp (hard)" )} ;             # 27
   puz_point_many_pounds      : dynamic_string {( opt_color_coding ? "<many pounds<#f80>>" : "many pounds" )} ;             # 18
   puz_point_marred_haze      : dynamic_string {( opt_color_coding ? "<marred haze<#f80>>" : "marred haze" )} ;             # 17
   puz_point_nest_boats       : dynamic_string {( opt_color_coding ? "<nest boats<#f80>>" : "nest boats" )} ;               # 23
   puz_point_pool_clan        : dynamic_string {( opt_color_coding ? "<pool clan<#f80>>" : "pool clan" )} ;                 # 25
   puz_point_right_tools      : dynamic_string {( opt_color_coding ? "<right tools<#f80>>" : "right tools" )} ;             # 04
   puz_point_real_stench      : dynamic_string {( opt_color_coding ? "<real stench<#f80>>" : "real stench" )} ;             # 02
   puz_point_sinister_mouth   : dynamic_string {( opt_color_coding ? "<sinister mouth<#f80>>" : "sinister mouth" )} ;       # 16
   puz_point_spittin_wrecks   : dynamic_string {( opt_color_coding ? "<spittin' wrecks<#f80>>" : "spittin' wrecks" )} ;     # 24
   puz_point_stool_tall       : dynamic_string {( opt_color_coding ? "<stool (tall)<#f80>>" : "stool (tall)" )} ;           # 01
   puz_point_streaky_cove     : dynamic_string {( opt_color_coding ? "<streaky cove<#f80>>" : "streaky cove" )} ;           # 09
   puz_point_tail_side        : dynamic_string {( opt_color_coding ? "<tail side<#f80>>" : "tail side" )} ;                 # 19
   puz_point_take_buns        : dynamic_string {( opt_color_coding ? "<TAKE BUNS<#f80>>" : "TAKE BUNS" )} ;                 # 10
   puz_point_tower_porch      : dynamic_string {( opt_color_coding ? "<tower porch<#f80>>" : "tower porch" )} ;             # 22
   puz_point_tree_cove        : dynamic_string {( opt_color_coding ? "<tree cove<#f80>>" : "tree cove" )} ;                 # 11
   puz_point_warmed_fax       : dynamic_string {( opt_color_coding ? "<warmed fax<#f80>>" : "warmed fax" )} ;               # 15

   # puzzle text (bonus) (alphabetize)
   puz_point_map_all : dynamic_string {( opt_color_coding && have_won ? "<app mall<#f80>>" : "app mall" )} ;

   # think text
   tht_leery_owner : string "<LEERY OWNER<#f80>>" ;
   already_got_check : dynamic_string {( already_got_command ? " Though you already got the full command, which you can revisit with {vd_think}." : "" )} ;
   for_bonus : dynamic_string {( half_bonus ? " for a bonus point" : "" )} ;

   #conditional location text (core) (alphabetize)
   here_ailer_lair : dynamic_string {( is_at "ailer_lair" ? "here" : "in the ailer lair" )} ;
   here_backin_cabin : dynamic_string {( is_at "backin_cabin" ? "here" : "in the backin' cabin" )} ;
   here_chattin_em_plain : dynamic_string {( is_at "chattin_em_plain" ? "here" : "in the chattin' 'em plain" )} ;
   here_collation_location : dynamic_string {( is_at "collation_location" ? "here" : "in the collation location" )} ;
   here_demo_meadow : dynamic_string {( is_at "demo_meadow" ? "here" : "in the demo meadow" )} ;
   here_foldin_gate : dynamic_string {( is_at "foldin_gate" ? "here" : "by the foldin' gate" )} ;
   here_gnawing_awning : dynamic_string {( is_at "gnawing_awning" ? "here" : "by the gnawing awning" )} ;
   here_jeerin_region : dynamic_string {( is_at "jeerin_region" ? "here" : "in the jeerin' region" )} ;
   here_moldin_dolmen : dynamic_string {( is_at "moldin_dolmen" ? "here" : "by the moldin' dolmen" )} ;
   here_newbies_boonies : dynamic_string {( is_at "newbies_boonies" ? "here" : "in the newbies' boonies" )} ;
   here_oopster_stupor : dynamic_string {( is_at "oopster_stupor" ? "here" : "in the oopster stupor" )} ;
   here_outer_tower : dynamic_string {( is_at "outer_tower" ? "here" : "in the outer tower" )} ;
   here_rocky_caves : dynamic_string {( is_at "rocky_caves" ? "here" : "in the rocky caves" )} ;
   here_taller_altar : dynamic_string {( is_at "taller_altar" ? "here" : "in the taller altar" )} ;
   here_tenser_center : dynamic_string {( is_at "tenser_center" ? "here" : "in the tenser center" )} ;
   here_tool_stall : dynamic_string {( is_at "tool_stall" ? "here" : "in the tool stall" )} ;
   here_streaky_cove : dynamic_string {( is_at "streaky_cove" ? "here" : "in the streaky cove" )} ;
   here_yankin_canyon : dynamic_string {( is_at "yankin_canyon" ? "here" : "by the yankin' canyon" )} ;

   #conditional location text (bonus) (alphabetize)
   here_app_mall : dynamic_string {( is_at "app_mall" ? "here" : "in the app mall" )} ;

   # Interpretive
   noguess : string "<(unknown)<#888>>" ;
   noguess_c_1 : dynamic_string {( unneeded_half ? "<(unneeded)<#888>>" : "<(unknown)<#888>>" )} ;
   think_here_also : dynamic_string {( think_text_yet ? "Also, here" : "Here" )} ;
   number_as_word : dynamic_string {( collection_get { collection -> ("num_to_word") index -> ( commands_figured ) } )} ;
   plus_in_header : dynamic_string {( commands_figured > 0 ? "+{commands_figured}" : "" )} ;

   # item(s)
   i_widget : string "<wild digit-dialed widget<#c8c>>" ;

   # auxiliary variable(s)
   tempopt : string "" ;
   txt_on_off : dynamic_string {( opt_on_off ? "<ON<#f0f>>" : "<OFF<#f0f>>" )} ;

}

integers {
   score : integer "0" ;
   max_score : integer "29" ;

   tutorial_score : integer "0" ;
   max_tutorial_score : integer "17" ;

   bonus_score : integer "0" scope="survivor" ;
   max_bonus_score : integer "10" ;

   # hinting. Magic numbers are 1 = do later, 0 = done, -1 = nothing to do
   # note items are listed in backwards order of how we do things
   # Adventuron didn't like too-complex dynamic_integers so I broke things up

   widget_num : integer "0" ;

   widget_num_start : dynamic_integer {( is_at "rocky_caves" ? widget_10_rocky_caves :
   is_at "tool_stall" ? widget_21_tool_stall :
   is_at "demo_meadow" ? widget_22_demo_meadow :
   -1 )} ;

   widget_num_middle : dynamic_integer {(
   is_at "chattin_em_plain" ? widget_11_chattin_em_plain :
   is_at "streaky_cove" ? widget_31_streaky_cove :
   is_at "cache_shack" ? widget_02_cache_shack :
   is_at "newbies_boonies" ? widget_12_newbies_boonies :
   is_at "demo_meadow" ? widget_22_demo_meadow :
   is_at "moldin_dolmen" ? widget_13_moldin_dolmen :
   is_at "collation_location" ? widget_33_collation_location :
   is_at "backin_cabin" ? widget_32_backin_cabin :
   is_at "yankin_canyon" ? widget_42_yankin_canyon :
   -1 )} ;

   widget_num_end : dynamic_integer {( is_at "outer_tower" ? widget_23_outer_tower :
   is_at "ailer_lair" ? widget_14_ailer_lair :
   is_at "tenser_center" ? widget_24_tenser_center :
   is_at "jeerin_region" ? widget_34_jeerin_region :
   is_at "gnawing_awning" ? widget_15_gnawing_awning :
   is_at "oopster_stupor" ? widget_25_oopster_stupor :
   is_at "taller_altar" ? widget_35_taller_altar :
   is_at "sappage_passage" ? widget_na_sappage_passage :
   is_at "foldin_gate" ? widget_26_foldin_gate :
   -1 )} ;

   widget_10_rocky_caves : dynamic_integer {( point_steel_wrench ? 0 : smell_rocky_caves ? 56 : 1 )} ;
   widget_20_app_mall : dynamic_integer {( 0 )} ;
   widget_11_chattin_em_plain : dynamic_integer {( point_platinum_chain ? 0 : 85 )} ;
   widget_21_tool_stall : dynamic_integer {( point_tight_rules ? 0 : point_leery_owner ? 55 : point_steel_wrench ? 55 : -55 )} ;
   widget_31_streaky_cove : dynamic_integer {( point_key_trove ? -1 : point_bake_tons ? 45 : point_creaky_stove ? 0 : 65 )} ;
   widget_02_cache_shack : dynamic_integer {( 0 )} ;
   widget_12_newbies_boonies : dynamic_integer {( point_push_best ? 0 : 44 )} ;
   widget_22_demo_meadow : dynamic_integer {( point_taming_flowers ? 0 : placed_flaming_towers ? 67 : cocky_raves_present ? 55 : (!point_tool_stall) ? 45 : 1 )} ;
   widget_32_backin_cabin : dynamic_integer {( point_pull_file ? 0 : 44 )} ;
   widget_42_yankin_canyon : dynamic_integer {( point_chop_drain ? 0 : 45 )} ;
   widget_13_moldin_dolmen : dynamic_integer {( point_formed_wax ? 0 : 63 )} ;
   widget_23_outer_tower : dynamic_integer {( point_power_torch ? 0 : !point_lodging_doc ? 74 : point_sold_guide ? 55 : 1 )} ;
   widget_33_collation_location : dynamic_integer {( point_grow_dupes ? -1 : 45 )} ;
   widget_14_ailer_lair : dynamic_integer {( point_help_card ? 0 : has_visited "foldin_gate" ? 44 : point_best_notes ? 1 : point_sail_tide ? 45 : 1 )} ;
   widget_24_tenser_center : dynamic_integer {( point_minister_south ? 0 : 85 )} ;
   widget_34_jeerin_region : dynamic_integer {( point_written_specs ? 0 : point_best_notes ? 75 : -75 )} ;
   widget_15_gnawing_awning : dynamic_integer {( point_sick_bride && point_sold_guide && point_sail_tide ? 0 : !point_sail_tide ? 45 : point_sick_bride || point_sold_guide ? 44 : 1 )} ;
   widget_25_oopster_stupor : dynamic_integer {( point_hard_maze ? 0 : 44 )} ;
   widget_35_taller_altar : dynamic_integer {( point_cool_plan ? 0 : point_sick_bride ? 44 : point_penny_mounds ? 1 : 56 )} ;
   widget_na_sappage_passage : integer "85" ;
   widget_26_foldin_gate : dynamic_integer {( point_help_card ? 54 : -54 )} ;

   awning_sides_done : dynamic_integer {( (point_sail_tide ? 1 : 0) + (point_sold_guide ? 1 : 0) + (point_sick_bride ? 1 : 0) )};
   awning_doable : dynamic_integer {( (3 - awning_sides_done) - (point_penny_mounds ? 1 : 0) )} ;

   #auxiliary
   tempint : integer "0" ;
   counter : integer "0" ;

   # silliness
   newbies_cutscene : integer "0" ;

   # for half THINK
   part_core_score : dynamic_integer {( ((collection_get{ collection -> ("got_first_core") index -> ( counter ) } == "true") ? 1 : 0) + ((collection_get{ collection -> ("got_second_core") index -> ( counter ) } == "true") ? 2 : 0) )} ; # this is a really bad hack, but I couldn't find a concise way to code things. Maybe I could use a dynamic boolean.
   part_bonus_score : dynamic_integer {( ((collection_get{ collection -> ("got_first_bonus") index -> ( counter ) } == "true") ? 1 : 0) + ((collection_get{ collection -> ("got_second_bonus") index -> ( counter ) } == "true") ? 2 : 0) )} ; # this is a really bad hack, but I couldn't find a concise way to code things. Maybe I could use a dynamic boolean.

   commands_figured : dynamic_integer {( (think_bake_tons ? 1 : 0) + (think_chop_drain ? 1 : 0) + (think_great_book ? 1 : 0) + (think_grow_dupes ? 1 : 0) + (think_leery_owner ? 1 : 0) + (think_sold_guide ? 1 : 0) + (think_written_specs ? 1 : 0) )} ;

}

