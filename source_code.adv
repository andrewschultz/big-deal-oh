start_at = "demo_meadow"
start_theme = my_theme

#cch.py makes sure of things

game_information {
   game_name                    = Big Deal, Oh!
   game_version                 = 1.0.0
   game_shortname               = BDO
   written_by                   = Andrew Schultz
   uuid                         = b3c1f8e2-5d4a-4f9b-8c3d-2a7e5f6a9b1c
   year_of_release              = 2026
   copyright_message            = Free to distribute, voluntary payments welcome
   short_synopsis               = TALP 2026 entry
}


## Defines locations in the world

strings {
   # top level
   this_game : string "<Big Deal, Oh!<#f80>>" ;
   l_qt : string "<Quirky Test<#0f0>>[http://andrewschultz.itch.io/us-too]" ;
   l_talp : string "<TALP<#0f0>>[https://itch.io/jam/talp]" ;
   l_talp_2026 : string "<TALP 2026<#0f0>>[https://itch.io/jam/talp2026]" ;

   # basics
   my_score : string "{score}/{max_score}" ;
   custom_unknown_verb_error : dynamic_string {( "Nothing special happens. You can use {vm_verbs} for a general overview of standard verbs." )} ;
   exits_err : dynamic_string {( "Can't go that way." )} ;

   # parser stuff
   nospecial_custom : string "You see no specific item like that--time limits mean I couldn't implement noncritical things. To examine a room, <LOOK<#0f0>>. Note that the parser may not recognize adjectives as synonyms, so using a noun works best." ;
   yn_or_12_or_14 : dynamic_string {( (verb_is "save" || verb_is "load") ? "Please choose from 1 to 4." : in_number_choice ? "Please choose 1 or 2." : "Please choose YES/Y or NO/N." )}
   standard_puzzle_check : dynamic_string {( "That's a standard verb often used for parsers, but " + (already_flag ? "you already found where to use it" : "you haven't found the one place to use it in this game yet") + "." )} ;

   # noting stuff
   one_time : string "<ONE-TIME NOTE: <#f0f>>" ;
   key_enter : string "the <ENTER<#f88>>/<RETURN<#f88>> key" ;
   note_cue_tutorial : string "<TUTORIAL CUE:<#f0f>> " ;

   # directions
   dir_n : string "<NORTH<#f80>>" ;
   dir_s : string "<SOUTH<#f80>>" ;
   dir_e : string "<EAST<#f80>>" ;
   dir_w : string "<WEST<#f80>>" ;
   dir_u : string "<UP<#f80>>" ;
   dir_d : string "<DOWN<#f80>>" ;

   # options
   yn : string "<YES<#f88>>/<Y<#f88>> or <NO<#f88>>/<N<#f88>>" ;
   optt_block_on : string "<WALL EH<#88f>> (on)" ;
   optt_block_off : string "<ALL WAY<#88f>> (off)" ;
   optt_block : string "{optt_block_on} and {optt_block_off}" ;
   optt_ch : string "<CH<#88f>> or <COLORHINT<#88f>>" ;
   optt_notify : string "<NOTIFY<#88f>>" ;

   # sense verbs
   v_feel : string "<FEEL<#0f0>>" ;
   v_listen : string "<LISTEN<#0f0>>" ;
   v_listen_hear : string "<LISTEN<#0f0>> or <HEAR<#0f0>>" ;
   v_smell : string "<SMELL<#0f0>>" ;

   # diagnostic verbs
   vd_i : string "<I<#f80>>" ;
   vd_inv : string "<INV<#f80>>" ;
   vd_i_long : string "<INVENTORY<#f80>>" ;
   vd_i_three : string "{vd_i}/{vd_inv}/{vd_i_long}" ;
   vd_score : string "<SCORE<#f80>>" ;
   vd_think : string "<THINK<#f80>>" ;

   # meta-verbs
   vm_about : string "<ABOUT<#f80>>" ;
   vm_credits : string "<CREDITS<#f80>>" ;
   vm_diag : string "<DIAG<#f80>>" ;
   vm_history : string "<HISTORY<#f80>>" ;
   vm_meta : string "<META<#f80>>" ;
   vm_options : string "<OPTIONS<#f80>>" ;
   vm_verbs : string "<VERBS<#f80>>" ;

   # top-level meta-commands
   vs_quit : string "<QUIT<#f80>>" ;
   vs_restart : string "<RESTART<#f80>>" ;
   vs_tss : string "<TSTART<#f80>> and <TSTOP<#f80>>" ;

   # standard top level stuff
   xme : string "<X ME<#0f0>>" ;

   # room(s)

   loc_ailer_lair : dynamic_string {( (point_best_notes ? "It's quiet here now." : point_sail_tide ? "Nest boats have arrived here. The babblers and blabbers look at you impatiently. They'd like to just give you a reward for rescuing them, but you've been taking a while." : "You are in the ailer lair. Babblers and blabbers sit here, one side kvetching about things that might go wrong, the other side kvetching about things they think went wrong but are actually okay. You see no way to mediate this civil war." ) + (has_visited "foldin_gate" ? " The changing tide has brought in some kelp, hard." : "") + "\nYou can go north and west." )} ;
   header_ailer_lair : string "<Ailer Lair<#ff0>>" ;

   loc_app_mall : dynamic_string {( "Here in the mall they're offering apps--well, you ask the nice jock clerk at the front desk for a code or whatever. Apparently they need to make sure you're sane enough, or something. " + (bonus_point_map_all ? "But you got the one you needed." : "Which app might be right for you?" ) + "\nA jock clerk mans the vending area.\nYou can go back north." + (!bonus_point_clock_jerk ? "\nAnd yet the atmosphere isn't quite right. You can probably leave " + (bonus_point_map_all ? "now" : "once") + " you've got what you want, but then there always seems to be more to tidy up." : "" ) )} ;
   header_app_mall : string "<App Mall<#ff0>>" ;

   loc_backin_cabin : dynamic_string {( "Here by the backin' cabin, " + (point_pull_file ? "the pile has been cleaned significantly and is nowhere near as full, and now you see three passages through the cabin. You can go in all four directions." : "you can only go back west for now. A {puz_point_full_pile} spills from the backin' cabin. Whoever put it there obviously was trying to help you, but they may have tried too hard." ) )} ;
   header_backin_cabin : string "<Backin' Cabin<#ff0>>" ;

   loc_cache_shack : string "You are in a cache shack, filled with various random stuff that seems either useless or far too heavy to lift. You can go back east." ;
   header_cache_shack : string "<Cache Shack<#ff0>>" ;

   loc_chattin_em_plain : string "You are in the Chattin 'Em Plain. The only exit is north." ;
   header_chattin_em_plain : string "<Chattin' 'Em Plain<#ff0>>" ;

   loc_collation_location : dynamic_string {( "You are in a collation location. The only exit is south. Dough groups sit here " + (point_grow_dupes ? "looking lonely" : "happy together") + "." )} ;
   header_cl : string "<Collation Location<#ff0>>" ;

   loc_demo_meadow : string "Here in the Demo Meadow {meadow_status}.\n{meadow_passages}." ;
   meadow_status : dynamic_string {( point_rocky_caves ? "it's quiet again after you got rid of the cocky raves" : listen_demo_meadow ? "you hear some {puz_point_cocky_raves_l}" : "it feels relatively quiet, and yet, not as quiet and peaceful as it should be" )} ;
   header_demo_meadow : string "<Demo Meadow<#ff0>>" ;
   meadow_passages: dynamic_string {( point_taming_flowers ? "You've found passages {dir_n}, {dir_e} and {dir_w} that lead away. You probably don't need to go back {dir_s} or in" : (!point_rocky_caves && !point_tool_stall) ? "You haven't found anywhere to go from here yet" : !point_rocky_caves ? "You can go {dir_s} to the tool stall" : !point_tool_stall ? "You can go {dir_d} to the rocky caves" : "You can go {dir_s} to the tool stall and {dir_d} to the rocky caves" )} ;

   loc_foldin_gate : dynamic_string {( "A big foldin' gate is to the north. It is " + (bonus_point_golden_fate ? "open, with goldness gleaming behind it" : "closed" ) + ". There's always passage south. Also, a gate brook runs by the gate." )} ;
   header_foldin_gate : string "<Foldin' Gate<#ff0>>" ;

   loc_gnawing_awning : string "A gnawing awning blocks passage every way except back south. It has a gold side, a brick side, and a tail side." ;
   header_gnawing_awning : string "<Gnawing Awning<#ff0>>" ;

   loc_jeerin_region : string "Here in the jeerin' region, {puz_point_spittin_wrecks} mock anything and everything. That you've avoided their mockery feels good until you wonder if they find you not even worth mocking. You can exit north or west." ;
   header_jeerin_region : string "<Jeerin' Region<#ff0>>" ;

   loc_moldin_dolmen : dynamic_string {( "You are by a " + (key_duplicated ? "no longer " : "") + "glowing moldin' dolmen." + (!point_formed_wax ? " A fax machine from behind a wall spits out a fax every few minutes. Weird to have it here! Perhaps you should inspect things." : "") + "\nThe only exit is south." )} ;
   header_moldin_dolmen : string "<Moldin' Dolmen<#ff0>>" ;

   loc_newbies_boonies : dynamic_string {( "Here in the newbies' boonies you can " + (point_push_best ? "go in all four directions with the bush pest gone." : "only go back south for now. There's a {puz_point_bush_pest} dancing around that seems to pop up in the latest direction you're considering going. Well, except back east." ) )} ;
   header_newbies_boonies : string "<Newbies' Boonies<#ff0>>" ;

   loc_oopster_stupor : dynamic_string {( has_visited("foldin_gate") ? "The path north is clear now you passed and destroyed the hard maze. You can go south, too." : point_hard_maze ? "The hard maze is ahead to the north, and the tenser center is back to the south." : "Oh no! There's a marred haze ahead to the north! You haven't stepped in it, but its fogginess still affects you. Whether or not oopster is a word, you're very much in a stupor and doing minor things that make you say oops. Thankfully you're still aware of passage back south." )} ;
   header_oopster_stupor : string "<Oopster Stupor<#ff0>>" ;

   loc_outer_tower : string "Here at the outer tower, barbed wire stretches all around. It looks like you could maybe eventually unlock the tower to go north, though, since it has a keyhole in it. It looks like you'll want to, because the grass really IS greener on the other side! Or maybe you'll need to prep by going back south first." ;
   header_outer_tower : string "<Outer Tower<#ff0>>" ;

   loc_rocky_caves : dynamic_string {( (point_steel_wrench ? "The rocky caves are just caves now. You're used to the smell, but you have nothing more to do here." : smell_rocky_caves ? "The {puz_point_real_stench} is almost overpowering. Could any good possibly come from it?" : "It's damp and dark in here. Yet the dampness and darkness reveal little. Perhaps another sense...") + "\nThere's a sunshine-shun sign here, probably just to reiterate the caves are too dark to explore deeply." )} ;
   header_rocky_caves : string "<Rocky Caves<#ff0>>" ;

   loc_streaky_cove: dynamic_string {( "You are in a streaky cove. " + (point_key_trove ? "You discovered a key trove out back." : point_bake_tons ? "You discovered a tree cove once you blew up the stove." : point_creaky_stove ? "You discovered a creaky stove in the greyness of the right wall" : "The greyness of the right wall is a stark contrast to the colorful left side. What could be there?") + "\nThe only exit is north." )} ;
   header_streaky_cove: string "<Streaky Cove<#ff0>>" ;

   loc_taller_altar : dynamic_string {( "Here in the taller altar you see " + ( point_cool_plan ? "nothing much any more. You're probably done here" : !point_penny_mounds ? "many pounds, both in the animal cage and huge cartoon trap sense. Surely they can be repurposed" : "The bride's pool clan. They're waiting for you to ask for the right favor before you move on" ) + ".\nthe only exit is south." )} ;
   header_taller_altar : string "<Taller Altar<#ff0>>" ;

   loc_tenser_center : dynamic_string {( (point_minister_south ? "I guess this could be the intenser incenter if you want, now that you must be close to your goal, as long as if you don't mind thumbing your nose at a geometry textbook. You can exit in all four directions with the sinister mouth gone, though you probably don't need to go back south." : "You are in the tenser center. A sinister mouth blocks passage further! You can only go south right now." ) )} ;
   header_tenser_center : string "<Tenser Center<#ff0>>" ;

   loc_tool_stall : dynamic_string {( "You're in a tool stall. The exit is back {dir_n}. Nearby you see " + (point_leery_owner ? "the owner, no longer leery" : "an {puz_point_eerie_loner}") + (point_tight_rules || !point_leery_owner ? "" : ". That sign indicates the {puz_point_right_tools} are available, but you haven't figured how to ask for them yet") + "." + (point_tight_rules ? "\nThe owner also showed you a passage to the south." : "") )} ;
   header_tool_stall : string "<Tool Stall<#ff0>>" ;

   loc_yankin_canyon : string "Here in the yankin' canyon, there's a hole which occasionally, well, yanks debris into it. As it does so, there are small whirring and slicing noises. The only exit is back west." ;
   header_yankin_canyon : string "<Yankin' Canyon<#ff0>>" ;

   # puzzle text (core) (alphabetize)

   puz_point_bush_pest : dynamic_string {( opt_color_coding ? "<bush pest<#f80>>" : "bush pest" )} ;
   puz_point_brick_side : dynamic_string {( opt_color_coding ? "<brick side<#f80>>" : "brick side" )} ;
   puz_point_cocky_raves : dynamic_string {( opt_color_coding ? "<Cocky raves<#f80>>" : "Cocky raves" )} ;
   puz_point_cocky_raves_l : dynamic_string {( opt_color_coding ? "<cocky raves<#f80>>" : "cocky raves" )} ;
   puz_point_dodging_lock : dynamic_string {( opt_color_coding ? "<dodging lock<#f80>>" : "dodging lock" )} ;
   puz_point_eerie_loner : dynamic_string {( opt_color_coding ? "<eerie loner<#f80>>" : "eerie loner" )} ;
   puz_point_flaming_towers : dynamic_string {( opt_color_coding ? "<flaming towers<#f80>>" : "flaming towers" )} ;
   puz_point_full_pile : dynamic_string {( opt_color_coding ? "<full pile<#f80>>" : "pull file" )} ;
   puz_point_gate_brook : dynamic_string {( opt_color_coding ? "<great book<#f80>>" : "gate brook" )} ;
   puz_point_gold_side : dynamic_string {( opt_color_coding ? "<gold side<#f80>>" : "gold side" )} ;
   puz_point_grow_dupes : dynamic_string {( opt_color_coding ? "<grow dupes<#f80>>" : "grow dupes" )} ;
   puz_point_hard_maze : dynamic_string {( opt_color_coding ? "<hard maze<#f80>>" : "hard maze" )} ;
   puz_point_kelp_hard : dynamic_string {( opt_color_coding ? "<kelp (hard)<#f80>>" : "kelp (hard)" )} ;
   puz_point_many_pounds : dynamic_string {( opt_color_coding ? "<many pounds<#f80>>" : "many pounds" )} ;
   puz_point_nest_boats : dynamic_string {( opt_color_coding ? "<nest boats<#f80>>" : "nest boats" )} ;
   puz_point_pool_clan : dynamic_string {( opt_color_coding ? "<pool clan<#f80>>" : "pool clan" )} ;
   puz_point_right_tools : dynamic_string {( opt_color_coding ? "<right tools<#f80>>" : "right tools" )} ;
   puz_point_real_stench : dynamic_string {( opt_color_coding ? "<real stench<#f80>>" : "real stench" )} ;
   puz_point_sinister_mouth : dynamic_string {( opt_color_coding ? "<sinister mouth<#f80>>" : "sinister mouth" )} ;
   puz_point_stool_tall : dynamic_string {( opt_color_coding ? "<stool (tall)<#f80>>" : "stool (tall)" )} ;
   puz_point_tail_side : dynamic_string {( opt_color_coding ? "<tail side<#f80>>" : "tail side" )} ;
   puz_point_take_buns : dynamic_string {( opt_color_coding ? "<TAKE BUNS<#f80>>" : "TAKE BUNS" )} ;
   puz_point_tower_porch : dynamic_string {( opt_color_coding ? "<tower porch<#f80>>" : "tower porch" )} ;
   puz_point_tree_cove : dynamic_string {( opt_color_coding ? "<tree cove<#f80>>" : "tree cove" )} ;
   puz_point_warmed_fax : dynamic_string {( opt_color_coding ? "<warmed fax<#f80>>" : "warmed fax" )} ;

   # puzzle text (bonus) (alphabetize)
   puz_point_map_all : dynamic_string {( opt_color_coding && have_won ? "<app mall<#f80>>" : "app mall" )} ;

   # think text
   tht_leery_owner : string "<LEERY OWNER<#f80>>" ;
   already_got_check : dynamic_string {( already_got_command ? " Though you already got the full command, which you can revisit with {vd_think}." : "" )} ;
   for_bonus : dynamic_string {( half_bonus ? " for a bonus point" : "" )} ;

   #conditional location text (core) (alphabetize)
   here_backin_cabin : dynamic_string {( is_at "backin_cabin" ? "here" : "in the backin' cabin" )} ;
   here_demo_meadow : dynamic_string {( is_at "demo_meadow" ? "here" : "in the demo meadow" )} ;
   here_newbies_boonies : dynamic_string {( is_at "backin_cabin" ? "here" : "in the newbies' boonies" )} ;
   here_rocky_caves : dynamic_string {( is_at "rocky_caves" ? "here" : "in the rocky caves" )} ;
   here_tool_stall : dynamic_string {( is_at "tool_stall" ? "here" : "in the tool stall" )} ;

   #conditional location text (bonus) (alphabetize)
   here_app_mall : dynamic_string {( is_at "app_mall" ? "here" : "in the app mall" )} ;

   # Interpretive
   noguess : string "<(unknown)<#888>>" ;
   noguess_c_1 : dynamic_string {( unneeded_half ? "<(unneeded)<#888>>" : "<(unknown)<#888>>" )} ;
   think_here_also : dynamic_string {( think_text_yet ? "Also, here" : "Here" )} ;
   number_as_word : dynamic_string {( collection_get { collection -> ("num_to_word") index -> ( commands_figured ) } )} ;

   # item(s)
   i_widget : string "<wild digit-dialed widget<#c8c>>" ;

   # auxiliary variable(s)
   tempopt : string "" ;
   txt_on_off : dynamic_string {( opt_on_off ? "<ON<#f0f>>" : "<OFF<#f0f>>" )} ;

}

integers {
   score : integer "0" ;
   max_score : integer "28" ;

   bonus_score : integer "0" scope="survivor" ;
   max_bonus_score : integer "4" ;

   # hinting. Magic numbers are 1 = do later, 0 = done, -1 = nothing to do
   # note items are listed in backwards order of how we do things
   widget_num : dynamic_integer {( is_at "demo_meadow" ? widget_demo_meadow : is_at "tool_stall" ? widget_tool_stall : is_at "rocky_caves" ? widget_rocky_caves : -1 )} ;
   widget_rocky_caves : dynamic_integer {( point_steel_wrench ? 0 : smell_rocky_caves ? 56 : 1 )} ;
   widget_tool_stall : dynamic_integer {( point_tight_rules ? 0 : point_leery_owner ? 55 : point_steel_wrench ? 55 : -55 )} ;
   widget_demo_meadow : dynamic_integer {( point_taming_flowers ? 0 : placed_flaming_towers ? 67 : cocky_raves_present ? 55 : (!point_tool_stall) ? 45 : 1 )} ;

   #auxiliary
   tempint : integer "0" ;
   counter : integer "0" ;

   # silliness
   newbies_cutscene : integer "0" ;

   # for half THINK
   part_core_score : dynamic_integer {( ((collection_get{ collection -> ("got_first_core") index -> ( counter ) } == "true") ? 1 : 0) + ((collection_get{ collection -> ("got_second_core") index -> ( counter ) } == "true") ? 2 : 0) )} ; # this is a really bad hack, but I couldn't find a concise way to code things. Maybe I could use a dynamic boolean.
   part_bonus_score : dynamic_integer {( ((collection_get{ collection -> ("got_first_bonus") index -> ( counter ) } == "true") ? 1 : 0) + ((collection_get{ collection -> ("got_second_bonus") index -> ( counter ) } == "true") ? 2 : 0) )} ; # this is a really bad hack, but I couldn't find a concise way to code things. Maybe I could use a dynamic boolean.

   commands_figured : dynamic_integer {( (think_leery_owner ? 1 : 0) )} ;

}

